    private async Task ShowCreateModal()
    {
        editingId = null;
        form = new SyncProject { ObjectClass = "User", IsEnabled = true };

        // IC-as-default-sink pattern. The IC mental model is "I add an AD
        // connection and just create a sync project" — source picks AD, sink
        // picks IC. Default Sink to the most-recently-active IC tenant (via
        // SyncRuns) when more than one IC tenant exists; first IC otherwise.
        // Default Source to the first non-IC, non-Emulator tenant. Leave
        // either unset when no candidate exists.
        var icTenants = allTenants
            .Where(t => string.Equals(t.SystemType, "IdentityCenter", StringComparison.OrdinalIgnoreCase))
            .ToList();
        if (icTenants.Count == 1)
        {
            form.SinkTenantId = icTenants[0].Id;
        }
        else if (icTenants.Count > 1)
        {
            Guid? mostRecent = null;
            try
            {
                mostRecent = await RunRepo.GetMostRecentlyActiveTenantIdAsync(icTenants.Select(t => t.Id));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Most-recently-active IC lookup failed; falling back to first: {ex.Message}");
            }
            form.SinkTenantId = mostRecent ?? icTenants[0].Id;
        }
        var sourceCandidate = allTenants.FirstOrDefault(t =>
            !string.Equals(t.SystemType, "IdentityCenter", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(t.SystemType, "Emulator", StringComparison.OrdinalIgnoreCase));
        if (sourceCandidate is not null && sourceCandidate.Id != form.SinkTenantId)
        {
            form.SourceTenantId = sourceCandidate.Id;
        }
        // Never pre-default both pickers to the SAME connection — a directory
        // syncing to itself is the bug we're guarding against. If the source
        // default collided with the sink default (single-tenant labs), drop the
        // sink default and let the operator pick a distinct one.
        if (form.SourceTenantId != Guid.Empty && form.SourceTenantId == form.SinkTenantId)
        {
            form.SinkTenantId = Guid.Empty;
        }

        // V22: seed the IC table defaults to match whatever sides defaulted to an
        // IC connection above (back-compat: AD → IC/Objects). Non-IC sides stay null.
        form.SourceTable = SourceIsIdentityCenter ? "Objects" : null;
        form.SinkTable = SinkIsIdentityCenter ? "Objects" : null;

        scopeForm = new SyncProjectScope { PageSize = 1000 };
        mappingForm = new List<AttributeMapping>();
        formError = string.Empty;
        formTab = "setup";
        wizardStep = 1;
        showNameValidation = false;
        showSourceValidation = false;
        showSinkValidation = false;
        sourceCredentialNames = new();
        sinkCredentialNames = new();
        // Defaults above may have pre-picked a source/sink — load their credential lists.
        await LoadCredentialsForFormAsync();
        ResetAssignmentTemplateForm();
        ResetWorkflowFormState();
        // Multi-class wizard: default to the Core tier; the actual set is (re)seeded
        // when the operator reaches the Object-Classes step (source is known by then).
        wizardClassMode = Conduit.Sync.Templates.GenerationMode.Core;
        wizardSelectedClasses = new(StringComparer.OrdinalIgnoreCase);
        showFormModal = true;
    }

    private void ResetWorkflowFormState()
    {
        workflowsForm = new List<Workflow>();
        stepsByWorkflow = new Dictionary<Guid, List<WorkflowStep>>();
        selectedWorkflowId = null;
        selectedStepId = null;
        workflowsDirty = false;
        workflowsDeleted.Clear();
        stepsDeleted.Clear();
        selectedTemplateId = WorkflowTemplateCatalog.EmptyId;
        // Phase 8: per-step mapping + scope state.
        stepMappings = new Dictionary<Guid, List<AttributeMapping>>();
        stepScopes = new Dictionary<Guid, SyncProjectScope?>();
        stepMappingsInherit = new Dictionary<Guid, bool>();
        stepScopeInherit = new Dictionary<Guid, bool>();
        stepMappingsLoaded = new HashSet<Guid>();
        stepScopesLoaded = new HashSet<Guid>();
    }

    /// <summary>
    /// Phase 8. Operator picked a workflow template in the create modal. Pre-fill
    /// the ObjectClass so the form's Object Class dropdown reflects the choice;
    /// the workflow tree itself is materialized later by SaveForm (after the
    /// project has a persisted Id). We don't pre-name the project from the
    /// template — the operator-chosen name wins.
    /// </summary>
    private void OnTemplateChanged(ChangeEventArgs e)
    {
        selectedTemplateId = e.Value?.ToString() ?? WorkflowTemplateCatalog.EmptyId;
        var tpl = SelectedTemplate;
        if (!string.IsNullOrEmpty(tpl.SuggestedObjectClass))
        {
            form.ObjectClass = tpl.SuggestedObjectClass;
        }
        // Picking a template can change the object class (e.g. Group Membership
        // Reconcile → Group). Refresh the recommendation marker + hidden count so
        // the list label stays consistent, but DON'T snap away from the operator's
        // explicit pick — it is valid by construction (it came from this list).
        RecommendedTemplateId = WorkflowTemplateCatalog.Recommended(
            SourceSystemType,
            TenantType(form.SinkTenantId),
            form.ObjectClass ?? "User",
            TargetCapabilities,
            TargetSupportsSink).Id;
    }

    /// <summary>
    /// Phase 8. After the new project's Id is known, materialize the picked
    /// template into Workflows + Steps via the repository. Only fires on create
    /// + when a non-Empty template is selected.
    /// </summary>
    private async Task ApplyTemplateAsync(Guid projectId)
    {
        var tpl = SelectedTemplate;
        if (tpl.Id == WorkflowTemplateCatalog.EmptyId) return;
        if (tpl.Workflows.Count == 0) return;
        var (wfs, stepsMap) = WorkflowTemplateCatalog.Materialize(tpl, projectId, form.ObjectClass);
        foreach (var wf in wfs)
        {
            await WorkflowRepo.CreateAsync(wf);
            if (stepsMap.TryGetValue(wf.Id, out var steps))
            {
                foreach (var s in steps) await WorkflowRepo.CreateStepAsync(s);
            }
        }
    }

    /// <summary>
    /// Multi-class wizard create path. Builds an in-memory workflow tree (ONE
    /// workflow, ONE Mapping step per operator-selected class) into workflowsForm /
    /// stepsByWorkflow / stepMappings, exactly like the Workflows-tab "Add all"
    /// (AddStepsForAllClasses) does — but for the wizard's chosen set. SaveForm's
    /// existing PersistWorkflowsAsync(persisted.Id) call then writes the whole tree
    /// + per-step mappings. Each step is stamped with its lowercase native class and
    /// its class-appropriate auto-mapped attributes (inherits project-level mappings
    /// when a class has no template, never blank-runs).
    /// </summary>
    private void BuildWizardClassSteps()
    {
        // Iterate in the connector's canonical order (WizardAllClasses) filtered to
        // the operator's selection, so step ordinals are stable + predictable.
        var classes = WizardAllClasses.Where(c => wizardSelectedClasses.Contains(c)).ToList();
        if (classes.Count == 0) return;

        var workflow = new Workflow
        {
            Id = Guid.NewGuid(),
            Name = $"{ModeLabel(wizardClassMode)} sync",
            Ordinal = 0,
            Enabled = true
        };
        workflowsForm = new List<Workflow> { workflow };
        var steps = new List<WorkflowStep>();
        stepsByWorkflow = new Dictionary<Guid, List<WorkflowStep>> { [workflow.Id] = steps };
        selectedWorkflowId = workflow.Id;

        var sinkType = SinkSystemType;
        for (int i = 0; i < classes.Count; i++)
        {
            var objectClass = classes[i];
            var step = new WorkflowStep
            {
                Id = Guid.NewGuid(),
                WorkflowId = workflow.Id,
                Name = $"{objectClass} mapping",
                StepType = WorkflowStepTypes.Mapping,
                ObjectClass = objectClass, // lowercase native name — matches generator + option set
                Ordinal = i,
                Enabled = true
            };
            steps.Add(step);

            // Pre-fill each step's own class-appropriate mappings (same as Auto-Generate
            // + the bulk builder). When the template is empty the step inherits the
            // project-level mappings rather than blank-running.
            var mappings = AttributeMapper.BuildMappings(SourceSystemType, sinkType, objectClass);
            if (mappings.Count > 0)
            {
                for (int j = 0; j < mappings.Count; j++) mappings[j].SortOrder = j;
                stepMappings[step.Id] = mappings;
                stepMappingsLoaded.Add(step.Id);
                stepMappingsInherit[step.Id] = false; // step owns its class-specific mappings
            }
        }

        workflowsDirty = true; // ensure PersistWorkflowsAsync flushes the tree
    }


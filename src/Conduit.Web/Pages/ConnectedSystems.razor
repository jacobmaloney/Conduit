    // ── Self-service rename ────────────────────────────────────────────────
    private bool showRenameModal;
    private bool renameBusy;
    private TenantStats? renameTarget;
    private string renameNewName = "";
    private string? renameError;
    private string renameSanitizedPreview => Conduit.Sync.Security.IdentityCenterSourceName.Sanitize(renameNewName?.Trim());

    private void ShowRenameModal(TenantStats s)
    {
        renameTarget = s;
        renameNewName = s.Name;
        renameError = null;
        renameBusy = false;
        showRenameModal = true;
    }

    private void CloseRenameModal()
    {
        showRenameModal = false;
        renameTarget = null;
        renameNewName = "";
        renameError = null;
        renameBusy = false;
    }

    // Server-side, fail-closed display-name validation. Returns null when valid,
    // else the rejection reason. Charset: letters, digits, space, and a small set
    // of punctuation used by existing connection names (parens, #, ., _, -).
    private static string? ValidateConnectionName(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return "Name is required.";
        var trimmed = raw.Trim();
        if (trimmed.Length < 1 || trimmed.Length > 100) return "Name must be 1-100 characters.";
        foreach (var c in trimmed)
        {
            if (char.IsControl(c)) return "Name contains a control character.";
            var allowed = char.IsLetterOrDigit(c) || " ().#_-".IndexOf(c) >= 0;
            if (!allowed) return "Name contains an unsupported character.";
        }
        var key = Conduit.Sync.Security.IdentityCenterSourceName.Sanitize(trimmed);
        if (!System.Text.RegularExpressions.Regex.IsMatch(key, "^[A-Za-z0-9_.\\-]{1,100}$"))
            return "Name does not produce a valid credential-map key.";
        return null;
    }

    private async Task RenameConnectionAsync()
    {
        if (renameTarget is null) return;
        renameError = null;

        var newName = (renameNewName ?? "").Trim();
        var validation = ValidateConnectionName(newName);
        if (validation is not null) { renameError = validation; return; }

        // Idempotent no-op: nothing to change.
        if (string.Equals(newName, renameTarget.Name, StringComparison.Ordinal))
        {
            CloseRenameModal();
            return;
        }

        renameBusy = true;
        try
        {
            // Re-resolve the tenant by Id server-side (IDOR guard) and read CURRENT name.
            var tenantId = renameTarget.TenantId;
            var tenant = await TenantRepo.GetByIdAsync(tenantId);
            if (tenant is null) { renameError = "Connection no longer exists."; return; }

            var oldName = tenant.Name;
            var oldKey = Conduit.Sync.Security.IdentityCenterSourceName.Sanitize(oldName);
            var newKey = Conduit.Sync.Security.IdentityCenterSourceName.Sanitize(newName);

            // Collision pre-check 1: another tenant's Name/Slug.
            if (await TenantRepo.NameOrSlugInUseByOtherAsync(newName, tenantId))
            {
                renameError = "Another connection already uses that name.";
                return;
            }
            // Collision pre-check 2: another tenant's credential-map key.
            if (!string.Equals(oldKey, newKey, StringComparison.Ordinal))
            {
                var keyOwner = await CredMapRepo.GetTenantIdByNameAsync(newKey);
                if (keyOwner.HasValue && keyOwner.Value != tenantId)
                {
                    renameError = "The credential-map key for that name is already in use by another connection.";
                    return;
                }
            }

            int projectsRewritten;
            try
            {
                projectsRewritten = await TenantRepo.RenameAsync(tenantId, oldName, newName, oldKey, newKey);
            }
            catch (Conduit.DataAccess.Repositories.SinkConnectionCredentialMapCollisionException)
            {
                renameError = "The credential-map key for that name is already in use by another connection.";
                return;
            }

            await AuditRenameAsync(tenantId, oldName, newName, oldKey, newKey, projectsRewritten);

            CloseRenameModal();
            await Load();
        }
        catch (Exception ex)
        {
            renameError = string.Concat("Rename failed: ", ex.Message);
        }
        finally
        {
            renameBusy = false;
        }
    }

    private async Task AuditRenameAsync(Guid tenantId, string oldName, string newName, string oldKey, string newKey, int projectsRewritten)
    {
        try
        {
            string userName = "unknown";
            try
            {
                var auth = await AuthState.GetAuthenticationStateAsync();
                userName = auth.User?.Identity?.Name ?? "unknown";
            }
            catch { /* best-effort */ }

            var ip = HttpCtx.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? "unknown";
            var ua = HttpCtx.HttpContext?.Request.Headers["User-Agent"].ToString();
            var details = string.Concat(
                "Connection renamed. Credential-map key '", oldKey, "' -> '", newKey,
                "'. SyncProjects rewritten: ", projectsRewritten.ToString(), ".");

            await Audit.LogAsync(
                action: "ConnectionRenamed",
                resourceType: "Tenant",
                resourceId: tenantId.ToString(),
                userName: userName,
                ipAddress: ip,
                userAgent: ua,
                statusCode: 200,
                details: details,
                oldValue: oldName,
                newValue: newName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Audit write failed for ConnectionRenamed on {tenantId}: {ex.Message}");
        }
    }


    private Tenant? AutoGenSource =>
        autoGenSourceId == Guid.Empty ? null : allTenants.FirstOrDefault(t => t.Id == autoGenSourceId);

    // Core + Full apply to every connector; the middle tier is connector-specific
    // (AD Infrastructure / Entra Security / SharePoint Collaboration) and only appears
    // when the chosen source connector defines it.
    private IReadOnlyList<Conduit.Sync.Templates.GenerationMode> AvailableModes
    {
        get
        {
            var modes = new List<Conduit.Sync.Templates.GenerationMode>
            {
                Conduit.Sync.Templates.GenerationMode.Core,
                Conduit.Sync.Templates.GenerationMode.Full
            };
            var type = AutoGenSource?.SystemType;
            if (type == "ActiveDirectory")
            {
                modes.Insert(1, Conduit.Sync.Templates.GenerationMode.AdInfrastructure);
            }
            else if (type == "EntraID")
            {
                modes.Insert(1, Conduit.Sync.Templates.GenerationMode.EntraSecurity);
            }
            else if (type == "SharePoint")
            {
                modes.Insert(1, Conduit.Sync.Templates.GenerationMode.SharePointCollaboration);
            }
            return modes;
        }
    }

    private static string ModeLabel(Conduit.Sync.Templates.GenerationMode mode) => mode switch
    {
        Conduit.Sync.Templates.GenerationMode.Core => "Core",
        Conduit.Sync.Templates.GenerationMode.AdInfrastructure => "Infrastructure",
        Conduit.Sync.Templates.GenerationMode.EntraSecurity => "Security",
        Conduit.Sync.Templates.GenerationMode.SharePointCollaboration => "Collaboration",
        _ => "Full"
    };

    private string AutoGeneratePreviewText
    {
        get
        {
            var source = AutoGenSource;
            if (source is null)
            {
                return "Select a source Connected System to preview the generated object classes.";
            }
            var classes = ProjectGenerator.GetObjectClasses(source.SystemType, autoGenMode);
            var joined = string.Join(", ", classes);
            return $"Generates {classes.Count} sync project(s): {joined}";
        }
    }

    private void OnAutoGenSourceChanged()
    {
        if (!AvailableModes.Contains(autoGenMode))
        {
            autoGenMode = Conduit.Sync.Templates.GenerationMode.Core;
        }
    }

    // Filtered project lists by tab.
    // Conduit has no "internal" projects today — symmetric router means every project
    // has a source + sink Tenant. The internal tab is kept for UX parity with IC and
    // shows an empty-state explaining where those flows live.
    private List<SyncProject> targetProjects => filteredProjects;
    private List<SyncProject> internalProjects => new();

    private IReadOnlyList<CcStatRow.StatItem> statRows = Array.Empty<CcStatRow.StatItem>();

    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    private async Task Reload()
    {
        try
        {
            allTenants = await TenantRepo.GetAllAsync(includeInactive: true);
            tenantById = allTenants.ToDictionary(t => t.Id);
            allProjects = await ProjectRepo.GetAllAsync();
            ApplyFilter();
            RecomputeStats();
            if (selectedProject is not null)
            {
                selectedProject = allProjects.FirstOrDefault(p => p.Id == selectedProject.Id);
                if (selectedProject is not null) await LoadRecentRuns();
            }
        }
        catch (Exception ex)
        {
            toastError = $"Reload failed: {ex.Message}";
        }
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredProjects = allProjects;
            return;
        }
        var q = searchTerm.Trim();
        filteredProjects = allProjects
            .Where(p => (p.Name?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
                     || (p.Description?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();
    }

    private void RecomputeStats()
    {
        statRows = new[]
        {
            new CcStatRow.StatItem("Projects",  allProjects.Count.ToString("N0")),
            new CcStatRow.StatItem("Enabled",   allProjects.Count(p => p.IsEnabled).ToString("N0")),
            new CcStatRow.StatItem("Running",   allProjects.Count(p => p.IsRunning).ToString("N0"),  ValueColor: "text-info"),
            new CcStatRow.StatItem("Scheduled", allProjects.Count(p => !string.IsNullOrEmpty(p.CronSchedule)).ToString("N0"))
        };
    }

    private async Task HandleSearchChanged(string value)
    {
        searchTerm = value;
        ApplyFilter();
        await Task.CompletedTask;
    }

    private async Task HandleSelect(SyncProject p)
    {
        selectedProject = p;
        await LoadRecentRuns();
    }

    private async Task LoadRecentRuns()
    {
        if (selectedProject is null) { recentRuns = new(); return; }
        try { recentRuns = await RunRepo.GetByProjectAsync(selectedProject.Id, take: 10); }
        catch (Exception ex)
        {
            toastError = $"Run history load failed: {ex.Message}";
            recentRuns = new();
        }
    }


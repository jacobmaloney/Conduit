    /// <summary>
    /// V23: load the selected project's Mapping steps (one per object class) so the
    /// detail panel can present the project AS its per-class steps. Flattens every
    /// workflow's steps; the panel filters to Mapping steps for the class summary.
    /// </summary>
    private async Task LoadSelectedProjectSteps()
    {
        if (selectedProject is null) { selectedProjectSteps = new(); return; }
        try
        {
            var workflows = await WorkflowRepo.GetByProjectAsync(selectedProject.Id);
            var all = new List<WorkflowStep>();
            foreach (var wf in workflows)
                all.AddRange(await WorkflowRepo.GetStepsAsync(wf.Id));
            selectedProjectSteps = all;
        }
        catch (Exception ex)
        {
            toastError = $"Step load failed: {ex.Message}";
            selectedProjectSteps = new();
        }
    }

    /// <summary>
    /// The distinct object classes this project syncs, derived from its Mapping steps
    /// (V23). Falls back to the project-level ObjectClass for legacy projects whose
    /// steps carry no class. Used by the detail badge + per-step view.
    /// </summary>
    private IReadOnlyList<string> SelectedMappingClasses
    {
        get
        {
            if (selectedProject is null) return Array.Empty<string>();
            var classes = selectedProjectSteps
                .Where(s => s.StepType == WorkflowStepTypes.Mapping)
                .Select(s => string.IsNullOrWhiteSpace(s.ObjectClass) ? selectedProject.ObjectClass : s.ObjectClass!)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
            return classes.Count > 0 ? classes : new List<string> { selectedProject.ObjectClass };
        }
    }


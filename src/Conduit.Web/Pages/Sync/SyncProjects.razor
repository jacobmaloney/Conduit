    // ─── Slice 4: connector-capability-aware pickers ─────────────────────────
    //
    // The symmetric router lets any Connected System be a source AND a sink, but
    // a given connector adapter may only implement one side (e.g. the Emulator
    // is sink-only; a read-only LDAP is source-only). Filter each picker to the
    // tenants whose adapter advertises the relevant capability so the operator
    // can't build a project the orchestrator would reject at run time. The
    // adapter is resolved by SystemType via the injected ConnectorRegistry.

    private IConnectorAdapter? AdapterFor(Guid tenantId) =>
        tenantById.TryGetValue(tenantId, out var t) ? Connectors.Get(t.SystemType) : null;

    private bool TenantSupportsSource(Tenant t)
    {
        var a = Connectors.Get(t.SystemType);
        // Unknown SystemType (no registered adapter) → don't hide it; the operator
        // may have a tenant whose adapter isn't loaded in this build. Fail open on
        // the list, fail closed on the explicit guard banner below.
        return a is null || a.SupportsSource;
    }

    private bool TenantSupportsSink(Tenant t)
    {
        var a = Connectors.Get(t.SystemType);
        return a is null || a.SupportsSink;
    }

    // Pickers iterate these instead of the raw allTenants list. Beyond the
    // capability filter (slice 4), each side EXCLUDES the connection already
    // chosen on the opposite side so the operator can't pick the same tenant as
    // both source and sink (a directory syncing to itself). The exclusion is
    // skipped while a side is unset (Guid.Empty) and never hides the currently
    // selected value from its own picker.
    private IReadOnlyList<Tenant> SourceTenants =>
        allTenants
            .Where(TenantSupportsSource)
            .Where(t => form.SinkTenantId == Guid.Empty || t.Id != form.SinkTenantId)
            .ToList();

    private IReadOnlyList<Tenant> SinkTenants =>
        allTenants
            .Where(TenantSupportsSink)
            .Where(t => form.SourceTenantId == Guid.Empty || t.Id != form.SourceTenantId)
            .ToList();

    // Auto-Generate modal pickers — same capability filter as the wizard, but
    // keyed off the modal's own autoGenSourceId / autoGenSinkId so each side
    // excludes the connection chosen on the other (no self-sync).
    private bool AutoGenIsSelfSync =>
        autoGenSourceId != Guid.Empty && autoGenSourceId == autoGenSinkId;

    private IReadOnlyList<Tenant> AutoGenSourceTenants =>
        allTenants
            .Where(TenantSupportsSource)
            .Where(t => autoGenSinkId == Guid.Empty || t.Id != autoGenSinkId)
            .ToList();

    private IReadOnlyList<Tenant> AutoGenSinkTenants =>
        allTenants
            .Where(TenantSupportsSink)
            .Where(t => autoGenSourceId == Guid.Empty || t.Id != autoGenSourceId)
            .ToList();

    // Capability pills for the currently-selected source / sink, rendered beside
    // each picker so the operator sees what the chosen connector can do.
    private IReadOnlyList<CapabilityPill> SourceCapabilityPills => CapabilityPillsFor(form.SourceTenantId, isSource: true);
    private IReadOnlyList<CapabilityPill> SinkCapabilityPills => CapabilityPillsFor(form.SinkTenantId, isSource: false);

    private record CapabilityPill(string Label, string CssClass, string Icon);

    private IReadOnlyList<CapabilityPill> CapabilityPillsFor(Guid tenantId, bool isSource)
    {
        if (tenantId == Guid.Empty) return Array.Empty<CapabilityPill>();
        var adapter = AdapterFor(tenantId);
        if (adapter is null) return Array.Empty<CapabilityPill>();

        var pills = new List<CapabilityPill>();
        var caps = adapter.Capabilities;

        if (isSource)
        {
            pills.Add(adapter.SupportsSource
                ? new CapabilityPill("Source", "cap-pill-ok", "fas fa-arrow-up-from-bracket")
                : new CapabilityPill("Not a source", "cap-pill-bad", "fas fa-ban"));
            if (adapter.SupportsSource && caps.SupportsIncremental)
            {
                pills.Add(new CapabilityPill("Incremental", "cap-pill-info", "fas fa-bolt"));
            }
        }
        else
        {
            pills.Add(adapter.SupportsSink
                ? new CapabilityPill("Sink", "cap-pill-ok", "fas fa-arrow-down-to-bracket")
                : new CapabilityPill("Not a sink", "cap-pill-bad", "fas fa-ban"));
            if (adapter.SupportsSink && caps.SupportsBulk)
            {
                pills.Add(new CapabilityPill("Bulk", "cap-pill-info", "fas fa-layer-group"));
            }
        }
        return pills;
    }

    // Hard guard: lights up when the operator has (e.g. via an unknown-adapter
    // tenant or a stale selection) picked a side the adapter can't fulfil. Drives
    // a banner on the Setup step and blocks Next/Create.
    private bool SourceCapabilityInvalid
    {
        get
        {
            if (form.SourceTenantId == Guid.Empty) return false;
            var a = AdapterFor(form.SourceTenantId);
            return a is not null && !a.SupportsSource;
        }
    }

    private bool SinkCapabilityInvalid
    {
        get
        {
            if (form.SinkTenantId == Guid.Empty) return false;
            var a = AdapterFor(form.SinkTenantId);
            return a is not null && !a.SupportsSink;
        }
    }

    private string CurrentTabForStep(int step) =>
        WizardStepDefs.FirstOrDefault(s => s.Number == step)?.Tab ?? "setup";

    private async Task GoToWizardStep(int step)
    {
        // Only allow jumping backward to an already-completed step via the header.
        if (step >= wizardStep) return;
        wizardStep = step;
        formTab = CurrentTabForStep(step);
        if (formTab == "object") { RecomputeTemplateApplicability(); EnsureWizardClassesSeeded(); }
        await Task.CompletedTask;
    }

    private bool ValidateWizardStep(int step)
    {
        formError = string.Empty;
        switch (step)
        {
            case 1:
                showNameValidation = true;
                showSourceValidation = true;
                showSinkValidation = true;
                if (string.IsNullOrWhiteSpace(form.Name))
                {
                    formError = "A project name is required.";
                    return false;
                }
                if (form.SourceTenantId == Guid.Empty || form.SinkTenantId == Guid.Empty)
                {
                    formError = "Pick both a source and a sink Connected System.";
                    return false;
                }
                if (SourceCapabilityInvalid)
                {
                    formError = $"{TenantName(form.SourceTenantId)} ({TenantType(form.SourceTenantId)}) cannot act as a source — its connector is sink-only. Pick a different source.";
                    return false;
                }
                if (SinkCapabilityInvalid)
                {
                    formError = $"{TenantName(form.SinkTenantId)} ({TenantType(form.SinkTenantId)}) cannot act as a sink — its connector is source-only. Pick a different sink.";
                    return false;
                }
                if (IsSelfSync)
                {
                    formError = "Source and target must be different connections.";
                    return false;
                }
                return true;
            case 3:
                if (scopeForm.PageSize < 1)
                {
                    formError = "Page size must be at least 1.";
                    return false;
                }
                if (scopeForm.MaxObjects < 0)
                {
                    formError = "Max objects can't be negative.";
                    return false;
                }
                return true;
            case 5:
                if (!ScheduledSyncRunnerJob.TryValidate(form.CronSchedule, out var cronErr))
                {
                    formError = cronErr ?? "Invalid schedule.";
                    return false;
                }
                return true;
            default:
                return true;
        }
    }

    private void NextWizardStep()
    {
        if (!ValidateWizardStep(wizardStep)) return;
        if (wizardStep >= WizardStepCount) return;
        wizardStep++;
        formTab = CurrentTabForStep(wizardStep);
        // Entering the Object Classes step: derive the legal template set from the
        // Source + Target + Object Class triple and seed the class checklist from
        // the source connector's Core tier (operator can change the tier / pick).
        if (formTab == "object") { RecomputeTemplateApplicability(); EnsureWizardClassesSeeded(); }
    }

    /// <summary>
    /// Seed the wizard's class checklist the first time the operator lands on the
    /// Object-Classes step (source is known by then). Defaults to the current tier
    /// preset. Leaves an existing operator selection alone on re-entry.
    /// </summary>
    private void EnsureWizardClassesSeeded()
    {
        if (wizardSelectedClasses.Count > 0) return;
        if (SourceSystemType.Length == 0) return;
        if (!WizardClassModes.Contains(wizardClassMode))
            wizardClassMode = Conduit.Sync.Templates.GenerationMode.Core;
        wizardSelectedClasses = new HashSet<string>(
            WizardClassesForMode(wizardClassMode),
            StringComparer.OrdinalIgnoreCase);
    }

    private void PrevWizardStep()
    {
        if (wizardStep <= 1) return;
        wizardStep--;
        formTab = CurrentTabForStep(wizardStep);
    }

    private string ScopeSummary()
    {
        var parts = new List<string>();
        if (SourceIsLdap)
        {
            parts.Add(string.IsNullOrWhiteSpace(scopeForm.BaseDN) ? "Base DN: auto-detect" : $"Base DN: {scopeForm.BaseDN}");
            if (!string.IsNullOrWhiteSpace(scopeForm.LdapFilter)) parts.Add($"LDAP filter: {scopeForm.LdapFilter}");
        }
        else if (!string.IsNullOrWhiteSpace(scopeForm.QueryExpression))
        {
            parts.Add($"Query: {scopeForm.QueryExpression}");
        }
        parts.Add($"Page size {scopeForm.PageSize}");
        if (scopeForm.MaxObjects > 0) parts.Add($"Max {scopeForm.MaxObjects}");
        if (scopeForm.IncludeDeleted) parts.Add("includes deleted");
        return string.Join(" · ", parts);
    }

    private string MappingSummary
    {
        get
        {
            var n = mappingForm.Count(m => !string.IsNullOrWhiteSpace(m.SourceAttribute) || !string.IsNullOrWhiteSpace(m.SinkAttribute));
            return n == 0 ? "Passthrough (no rules)" : $"{n} rule(s)";
        }
    }

    // Hint line for the API-shaped (non-LDAP, non-Entra) scope editor.
    private string ScopeApiHint =>
        string.IsNullOrEmpty(SourceSystemType)
            ? "Pick a source on the first step to tailor these fields."
            : string.Concat(SourceSystemType, " reads via its API.");

    private async Task SaveForm()
    {
        formError = string.Empty;
        if (string.IsNullOrWhiteSpace(form.Name))
        {
            showNameValidation = true;
            formError = "Name is required.";
            formTab = "setup";
            wizardStep = 1;
            return;
        }
        if (form.SourceTenantId == Guid.Empty || form.SinkTenantId == Guid.Empty)
        {
            showSourceValidation = true;
            showSinkValidation = true;
            formError = "Both source and sink connections are required.";
            formTab = "setup";
            wizardStep = 1;
            return;
        }
        // Slice 4: enforce connector capability on save too (Next-button guard is
        // the primary gate, but a tabbed-edit jump or a stale selection could land
        // here directly). Only meaningful on create — source/sink are locked on edit.
        if (!editingId.HasValue && (SourceCapabilityInvalid || SinkCapabilityInvalid))
        {
            formError = SourceCapabilityInvalid
                ? $"{TenantName(form.SourceTenantId)} cannot act as a source — its connector is sink-only."
                : $"{TenantName(form.SinkTenantId)} cannot act as a sink — its connector is source-only.";
            showSourceValidation = true;
            showSinkValidation = true;
            formTab = "setup";
            wizardStep = 1;
            return;
        }
        // Source and target must be DISTINCT connections — a directory syncing to
        // itself is never valid. Primary gate is the wizard Next button; this catches
        // a tabbed-edit jump or stale selection that lands here directly. Only
        // meaningful on create — source/sink are locked on edit.
        if (!editingId.HasValue && IsSelfSync)
        {
            formError = "Source and target must be different connections.";
            showSourceValidation = true;
            showSinkValidation = true;
            formTab = "setup";
            wizardStep = 1;
            return;
        }
        if (!ScheduledSyncRunnerJob.TryValidate(form.CronSchedule, out var cronError))
        {
            formError = cronError ?? "Invalid schedule.";
            formTab = "schedule";
            wizardStep = 5;
            return;
        }

        // Multi-class wizard: stamp the project-level ObjectClass with the first
        // selected class so the legacy/back-compat fallback (detail view, project
        // mapping) stays coherent with the per-class steps we're about to build.
        if (!editingId.HasValue && isWizard && wizardSelectedClasses.Count > 0)
        {
            var firstClass = WizardAllClasses.FirstOrDefault(c => wizardSelectedClasses.Contains(c));
            if (!string.IsNullOrWhiteSpace(firstClass)) form.ObjectClass = firstClass;
        }

        saving = true;
        try
        {
            SyncProject persisted;
            bool isCreate = !editingId.HasValue;
            if (editingId.HasValue)
            {
                form.Id = editingId.Value;
                await ProjectRepo.UpdateAsync(form);
                persisted = form;
            }
            else
            {
                persisted = await ProjectRepo.CreateAsync(form);
            }

            // Phase 8 / multi-class wizard: materialize the workflow tree on first save.
            // The wizard's Object-Classes step yields N selected classes → build ONE
            // workflow with ONE Mapping step per class, each auto-mapped to its own
            // class-appropriate template (the same one-project/N-steps shape Auto-
            // Generate produces). Falls back to the single-template path only when no
            // classes were chosen. Empty template is a no-op; the orchestrator's V17
            // backfill stamps a Default workflow on first run if nothing else exists.
            if (isCreate)
            {
                if (isWizard && wizardSelectedClasses.Count > 0)
                {
                    BuildWizardClassSteps();
                }
                else
                {
                    await ApplyTemplateAsync(persisted.Id);
                }
            }

            scopeForm.SyncProjectId = persisted.Id;
            await ProjectRepo.UpsertScopeAsync(scopeForm);

            var cleanedMappings = mappingForm
                .Where(m => !string.IsNullOrWhiteSpace(m.SourceAttribute) || !string.IsNullOrWhiteSpace(m.SinkAttribute))
                .ToList();
            await ProjectRepo.ReplaceMappingsAsync(persisted.Id, cleanedMappings);

            // Phase 7: persist the workflow tree if the operator opened the tab.
            await PersistWorkflowsAsync(persisted.Id);

            showFormModal = false;
            toastSuccess = editingId.HasValue
                ? $"Sync project '{persisted.Name}' saved."
                : $"Sync project '{persisted.Name}' created.";
            await Reload();
            selectedProject = allProjects.FirstOrDefault(p => p.Id == persisted.Id);
            // V23 fix: refresh the per-class steps for the just-saved project so the
            // detail view's "Workflow steps" section + the object-class badge reflect
            // what was materialized on create instead of the previously-selected
            // project's (stale) steps. Reload() only reloads steps when selectedProject
            // is already set on entry; on first create it is set AFTER Reload, so do it here.
            await LoadSelectedProjectSteps();
            await LoadRecentRuns();
        }
        catch (Exception ex)
        {
            formError = $"Save failed: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }


        showScheduleModal = false;
        scheduleError = string.Empty;
    }

    private async Task SaveSchedule()
    {
        if (selectedProject is null) return;
        if (!ScheduledSyncRunnerJob.TryValidate(scheduleForm, out var err))
        {
            scheduleError = err ?? "Invalid schedule.";
            return;
        }
        scheduleSaving = true;
        try
        {
            var copy = new SyncProject
            {
                Id = selectedProject.Id,
                Name = selectedProject.Name,
                Description = selectedProject.Description,
                SourceTenantId = selectedProject.SourceTenantId,
                SinkTenantId = selectedProject.SinkTenantId,
                ObjectClass = selectedProject.ObjectClass,
                CronSchedule = string.IsNullOrWhiteSpace(scheduleForm) ? null : scheduleForm.Trim(),
                IsEnabled = selectedProject.IsEnabled
            };
            await ProjectRepo.UpdateAsync(copy);
            showScheduleModal = false;
            toastSuccess = $"Schedule saved for '{selectedProject.Name}'.";
            await Reload();
        }
        catch (Exception ex)
        {
            scheduleError = $"Save failed: {ex.Message}";
        }
        finally
        {
            scheduleSaving = false;
        }
    }

    // ─── Auto-generate modal ────────────────────────────────────────────────

    private void ShowAutoGenerateModal()
    {
        autoGenMode = Conduit.Sync.Templates.GenerationMode.Core;
        autoGenSourceId = Guid.Empty;
        autoGenSinkId = Guid.Empty;
        autoGenCronSchedule = string.Empty;
        autoGenEnable = true;
        autoGenError = string.Empty;
        showAutoGenerateModal = true;
    }

    private void CloseAutoGenerateModal()
    {
        if (autoGenInProgress) return;
        showAutoGenerateModal = false;
    }

    private async Task GenerateAutoSyncProject()
    {
        autoGenError = string.Empty;
        if (autoGenSourceId == Guid.Empty || autoGenSinkId == Guid.Empty)
        {
            autoGenError = "Both source and sink are required.";
            return;
        }

        var src = allTenants.FirstOrDefault(t => t.Id == autoGenSourceId);
        var sink = allTenants.FirstOrDefault(t => t.Id == autoGenSinkId);
        if (src is null || sink is null)
        {
            autoGenError = "Selected systems no longer exist.";
            return;
        }

        // Self-sync is allowed (mastered transforms). The modal's live preview line
        // already shows the operator the object-class count + names for (source, mode)
        // before they confirm. Build the whole graph in memory via the Phase 3
        // generator, then persist project -> workflow -> step -> scope -> mappings
        // through the repositories. Only Mapping steps are emitted -- no governance.
        var existingNames = allProjects.Select(p => p.Name).ToList();
        var generated = ProjectGenerator.Generate(src, sink, autoGenMode, autoGenCronSchedule, existingNames);
        if (generated.Count == 0)
        {
            autoGenError = "This source connector + mode produced no object classes.";
            return;
        }

        autoGenInProgress = true;
        try
        {
            foreach (var g in generated)
            {
                g.Project.IsEnabled = autoGenEnable;
                await ProjectRepo.CreateAsync(g.Project);
                await WorkflowRepo.CreateAsync(g.Workflow);
                await WorkflowRepo.CreateStepAsync(g.Step);
                await WorkflowRepo.UpsertScopeForStepAsync(g.Project.Id, g.Step.Id, g.Scope);
                if (g.Mappings.Count > 0)
                {
                    await WorkflowRepo.ReplaceMappingsForStepAsync(g.Project.Id, g.Step.Id, g.Mappings);
                }
            }

            showAutoGenerateModal = false;
            toastSuccess = $"Auto-generated {generated.Count} sync project(s) ({ModeLabel(autoGenMode)}) from {src.Name} to {sink.Name}.";
            await Reload();
        }
        catch (Exception ex)
        {
            autoGenError = $"Auto-generate failed: {ex.Message}";
        }
        finally
        {
            autoGenInProgress = false;
        }
    }
}

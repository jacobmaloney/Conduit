    private async Task EditCurrent()
    {
        if (selectedProject is null) return;
        editingId = selectedProject.Id;
        form = new SyncProject
        {
            Id = selectedProject.Id,
            Name = selectedProject.Name,
            Description = selectedProject.Description,
            SourceTenantId = selectedProject.SourceTenantId,
            SinkTenantId = selectedProject.SinkTenantId,
            SourceCredentialName = selectedProject.SourceCredentialName,
            SinkCredentialName = selectedProject.SinkCredentialName,
            SourceTable = selectedProject.SourceTable,
            SinkTable = selectedProject.SinkTable,
            ObjectClass = selectedProject.ObjectClass,
            CronSchedule = selectedProject.CronSchedule,
            IsEnabled = selectedProject.IsEnabled,
            SkipUnchanged = selectedProject.SkipUnchanged
        };
        await LoadCredentialsForFormAsync();
        // An exception that escapes an @onclick dispatch kills the whole circuit
        // (and the framework's EndInvokeDotNet ack then masks it with an NRE), so
        // surface load failures in the modal's error banner instead of throwing.
        formError = string.Empty;
        try
        {
            scopeForm = await ProjectRepo.GetScopeAsync(selectedProject.Id)
                        ?? new SyncProjectScope { SyncProjectId = selectedProject.Id, PageSize = 1000 };
            mappingForm = await ProjectRepo.GetMappingsAsync(selectedProject.Id);
        }
        catch (Exception ex)
        {
            scopeForm = new SyncProjectScope { SyncProjectId = selectedProject.Id, PageSize = 1000 };
            mappingForm = new List<AttributeMapping>();
            formError = $"Failed to load the project's scope/mappings: {ex.Message}";
        }
        formTab = "setup";
        ResetAssignmentTemplateForm();
        ResetWorkflowFormState();
        // Pre-fill constant fields from existing default:* mappings when present so the
        // template panel is editable in-place on already-templated projects.
        TryHydrateAssignmentTemplateFromMappings();
        showFormModal = true;
    }

    private void TryHydrateAssignmentTemplateFromMappings()
    {
        var acct = mappingForm.FirstOrDefault(m => string.Equals(m.SinkAttribute, "accountId", StringComparison.OrdinalIgnoreCase));
        var ps   = mappingForm.FirstOrDefault(m => string.Equals(m.SinkAttribute, "permissionSetArn", StringComparison.OrdinalIgnoreCase));
        var pt   = mappingForm.FirstOrDefault(m => string.Equals(m.SinkAttribute, "principalType", StringComparison.OrdinalIgnoreCase));
        var pid  = mappingForm.FirstOrDefault(m => string.Equals(m.SinkAttribute, "principalId", StringComparison.OrdinalIgnoreCase));

        string? Default(AttributeMapping? m) =>
            (m?.TransformExpr ?? "").StartsWith("default:", StringComparison.OrdinalIgnoreCase)
                ? m!.TransformExpr!.Substring("default:".Length)
                : null;

        var acctVal = Default(acct);
        var psVal   = Default(ps);
        var ptVal   = Default(pt);

        if (acctVal is not null) assignAccountId = acctVal;
        if (psVal   is not null) assignPermissionSetArn = psVal;
        if (!string.IsNullOrEmpty(ptVal)) assignPrincipalType = ptVal;
        if (pid is not null && !string.IsNullOrWhiteSpace(pid.SourceAttribute))
            assignPrincipalIdSource = pid.SourceAttribute;

        if (acctVal is not null && psVal is not null)
            assignTemplateMode = "constant";
    }


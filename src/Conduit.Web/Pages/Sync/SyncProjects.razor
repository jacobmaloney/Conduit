    /// <summary>
    /// Phase 8. Operator picked a workflow template in the create modal. Pre-fill
    /// the ObjectClass so the form's Object Class dropdown reflects the choice;
    /// the workflow tree itself is materialized later by SaveForm (after the
    /// project has a persisted Id). We don't pre-name the project from the
    /// template — the operator-chosen name wins.
    /// </summary>
    private void OnTemplateChanged(ChangeEventArgs e)
    {
        selectedTemplateId = e.Value?.ToString() ?? WorkflowTemplateCatalog.EmptyId;
        var tpl = SelectedTemplate;
        if (!string.IsNullOrEmpty(tpl.SuggestedObjectClass))
        {
            form.ObjectClass = tpl.SuggestedObjectClass;
        }
    }

    /// <summary>
    /// Phase 8. After the new project's Id is known, materialize the picked
    /// template into Workflows + Steps via the repository. Only fires on create
    /// + when a non-Empty template is selected.
    /// </summary>
    private async Task ApplyTemplateAsync(Guid projectId)
    {
        var tpl = SelectedTemplate;
        if (tpl.Id == WorkflowTemplateCatalog.EmptyId) return;
        if (tpl.Workflows.Count == 0) return;
        var (wfs, stepsMap) = WorkflowTemplateCatalog.Materialize(tpl, projectId);
        foreach (var wf in wfs)
        {
            await WorkflowRepo.CreateAsync(wf);
            if (stepsMap.TryGetValue(wf.Id, out var steps))
            {
                foreach (var s in steps) await WorkflowRepo.CreateStepAsync(s);
            }
        }
    }


            {
                Conduit.Sync.Templates.GenerationMode.Core,
                Conduit.Sync.Templates.GenerationMode.Full
            };
            switch (SourceSystemType)
            {
                case "ActiveDirectory":
                case "ActiveRoles":
                    modes.Insert(1, Conduit.Sync.Templates.GenerationMode.AdInfrastructure);
                    break;
                case "EntraID":
                    modes.Insert(1, Conduit.Sync.Templates.GenerationMode.EntraSecurity);
                    break;
                case "SharePoint":
                    modes.Insert(1, Conduit.Sync.Templates.GenerationMode.SharePointCollaboration);
                    break;
            }
            return modes;
        }
    }

    /// <summary>Inline preview of what "Add all" will create for the current tier.</summary>
    private string BulkBuilderPreviewText
    {
        get
        {
            if (SourceSystemType.Length == 0)
                return "Pick a source Connected System on the Setup tab to enable all-class build.";
            var classes = WizardClassesForMode(workflowsClassMode);
            return $"{classes.Count} class(es): {string.Join(", ", classes)}";
        }
    }

    /// <summary>
    /// IC-parity: add ONE Mapping step per object class in the chosen tier that the
    /// ACTIVE workflow doesn't already have, each pre-stamped with its lowercase
    /// native class and auto-mapped attributes for the (source → sink → class)
    /// triple. Skips classes already present (idempotent), so re-running only fills
    /// the gaps. Mirrors IC's "already has workflows for every object class —
    /// nothing to add" backfill behaviour and message.
    /// </summary>
    private async Task AddStepsForAllClasses()
    {
        bulkBuilderMessage = string.Empty;
        if (!editingId.HasValue) return;
        if (SourceSystemType.Length == 0)
        {
            bulkBuilderMessage = "Pick a source Connected System on the Setup tab first.";
            return;
        }

        // Resolve (or create) the workflow the steps attach to. Prefer the selected
        // workflow; otherwise the first; otherwise stand one up (matches AddStep's
        // single-step path but for the whole class set).
        var workflow = SelectedWorkflow ?? workflowsForm.FirstOrDefault();
        if (workflow is null)
        {
            workflow = new Workflow
            {
                Id = Guid.NewGuid(),
                SyncProjectId = editingId.Value,
                Name = $"{ModeLabel(workflowsClassMode)} sync",
                Ordinal = workflowsForm.Count,
                Enabled = true
            };
            workflowsForm.Add(workflow);
            stepsByWorkflow[workflow.Id] = new List<WorkflowStep>();
        }
        selectedWorkflowId = workflow.Id;

        if (!stepsByWorkflow.TryGetValue(workflow.Id, out var list))
        {
            list = new List<WorkflowStep>();
            stepsByWorkflow[workflow.Id] = list;
        }

        // Classes this workflow already covers (case-insensitive on native names).
        var existing = new HashSet<string>(
            list.Where(s => string.Equals(s.StepType, WorkflowStepTypes.Mapping, StringComparison.OrdinalIgnoreCase)
                            && !string.IsNullOrWhiteSpace(s.ObjectClass))
                .Select(s => s.ObjectClass!),
            StringComparer.OrdinalIgnoreCase);

        var classes = WizardClassesForMode(workflowsClassMode);
        var sinkType = SinkSystemType;
        var added = 0;
        WorkflowStep? lastAdded = null;

        foreach (var objectClass in classes)
        {
            if (existing.Contains(objectClass)) continue;

            var step = new WorkflowStep
            {
                Id = Guid.NewGuid(),
                WorkflowId = workflow.Id,
                Name = $"{objectClass} mapping",
                StepType = WorkflowStepTypes.Mapping,
                ObjectClass = objectClass, // lowercase native name — matches generator + option set
                Ordinal = list.Count,
                Enabled = true
            };
            list.Add(step);
            existing.Add(objectClass);
            lastAdded = step;
            added++;

            // Pre-fill each new step's own class-appropriate mappings, exactly like
            // Auto-Generate does. Seed even when the auto-map comes back empty (the
            // step then inherits the project-level mappings, never blank-runs).
            var mappings = AttributeMapper.BuildMappings(SourceSystemType, sinkType, objectClass);
            if (mappings.Count > 0)
            {
                for (int i = 0; i < mappings.Count; i++) mappings[i].SortOrder = i;
                stepMappings[step.Id] = mappings;
                stepMappingsLoaded.Add(step.Id);
                stepMappingsInherit[step.Id] = false; // step owns its class-specific mappings
            }
        }

        if (added == 0)
        {
            bulkBuilderMessage = "This workflow already has steps for every object class in that tier. Nothing to add.";
            return;
        }

        if (lastAdded is not null) await SelectStep(lastAdded.Id);
        workflowsDirty = true;
        bulkBuilderMessage = added == 1
            ? "Added 1 object-class step (auto-mapped). Click Save changes to persist."
            : $"Added {added} object-class steps (auto-mapped). Click Save changes to persist.";
    }

    /// <summary>
    /// Auto-map EVERY Mapping step in the project using each step's OWN object class
    /// (the bulk analogue of the per-step "Auto-map for this class"). Each step that
    /// resolves to a non-empty template gets its mappings replaced and flips off
    /// "inherit from project". Steps whose class has no template are left untouched.
    /// </summary>
    private async Task AutoMapAllSteps()
    {
        bulkBuilderMessage = string.Empty;
        if (SourceSystemType.Length == 0)
        {
            bulkBuilderMessage = "Pick a source Connected System on the Setup tab first.";
            return;
        }

        var mappingSteps = stepsByWorkflow.Values
            .SelectMany(l => l)
            .Where(s => string.Equals(s.StepType, WorkflowStepTypes.Mapping, StringComparison.OrdinalIgnoreCase))
            .ToList();
        if (mappingSteps.Count == 0)
        {
            bulkBuilderMessage = "No Mapping steps to auto-map.";
            return;
        }

        var anyEdits = mappingSteps.Any(s =>
            GetStepMappings(s.Id).Any(m =>
                !string.IsNullOrWhiteSpace(m.SourceAttribute) || !string.IsNullOrWhiteSpace(m.SinkAttribute)));
        if (anyEdits)
        {
            var ok = await JS.InvokeAsync<bool>("confirm",
                "Re-map every Mapping step from its object-class template? This replaces any per-step mappings you've edited. Choose Cancel to keep them.");
            if (!ok) return;
        }

        var sinkType = SinkSystemType;
        var mapped = 0;
        var skipped = 0;
        foreach (var step in mappingSteps)
        {
            var stepClass = string.IsNullOrWhiteSpace(step.ObjectClass) ? "user" : step.ObjectClass!;
            var suggested = AttributeMapper.BuildMappings(SourceSystemType, sinkType, stepClass);
            if (suggested.Count == 0) { skipped++; continue; }

            for (int i = 0; i < suggested.Count; i++) suggested[i].SortOrder = i;
            stepMappings[step.Id] = suggested;
            stepMappingsLoaded.Add(step.Id);
            stepMappingsInherit[step.Id] = false;
            mapped++;
        }

        workflowsDirty = true;
        bulkBuilderMessage = skipped == 0
            ? $"Auto-mapped {mapped} step(s). Click Save changes to persist."
            : $"Auto-mapped {mapped} step(s); {skipped} had no template for their class. Click Save changes to persist.";
    }

    private void SelectWorkflow(Guid id)
    {
        selectedWorkflowId = id;
        selectedStepId = null;
    }

    private async Task SelectStep(Guid id)
    {
        selectedStepId = id;
        // Find parent workflow so detail panel breadcrumbs stay coherent.
        foreach (var (wfId, list) in stepsByWorkflow)
        {
            if (list.Any(s => s.Id == id)) { selectedWorkflowId = wfId; break; }
        }
        // Phase 8: lazy-load per-step mapping + scope state when a Mapping step
        // is opened. Skip for transient (just-added, not-yet-persisted) steps;
        // their per-step rows can only exist after Save anyway.
        var step = SelectedStep;
        if (step is not null && string.Equals(step.StepType, WorkflowStepTypes.Mapping, StringComparison.OrdinalIgnoreCase))
        {
            await EnsureStepMappingsLoadedAsync(step.Id);
            await EnsureStepScopeLoadedAsync(step.Id);
        }
    }

    /// <summary>
    /// Phase 8. Lazy-load this step's persisted mappings on first open. Empty
    /// row set + no persisted record = "inherit from project" (toggle defaults
    /// to true). Non-empty = "step owns its own" (toggle defaults to false).
    /// </summary>
    private async Task EnsureStepMappingsLoadedAsync(Guid stepId)
    {
        if (stepMappingsLoaded.Contains(stepId)) return;
        stepMappingsLoaded.Add(stepId);
        try
        {
            // GetMappingsByStepAsync returns rows scoped to this WorkflowStep.Id.
            // Transient (Guid.NewGuid in-memory) steps return empty; that's fine.
            var rows = await WorkflowRepo.GetMappingsByStepAsync(stepId);
            stepMappings[stepId] = rows;
            stepMappingsInherit[stepId] = rows.Count == 0;
        }
        catch
        {
            stepMappings[stepId] = new List<AttributeMapping>();
            stepMappingsInherit[stepId] = true;
        }
    }

    private async Task EnsureStepScopeLoadedAsync(Guid stepId)
    {
        if (stepScopesLoaded.Contains(stepId)) return;
        stepScopesLoaded.Add(stepId);
        try
        {
            var sc = await WorkflowRepo.GetScopeByStepAsync(stepId);
            stepScopes[stepId] = sc;
            stepScopeInherit[stepId] = sc is null;
        }
        catch
        {
            stepScopes[stepId] = null;
            stepScopeInherit[stepId] = true;
        }
    }

    private List<AttributeMapping> GetStepMappings(Guid stepId)
    {
        if (!stepMappings.TryGetValue(stepId, out var list))
        {
            list = new List<AttributeMapping>();
            stepMappings[stepId] = list;
        }
        return list;
    }

    private SyncProjectScope GetStepScope(Guid stepId)
    {
        if (stepScopes.TryGetValue(stepId, out var sc) && sc is not null) return sc;
        var fresh = new SyncProjectScope { PageSize = 1000 };
        stepScopes[stepId] = fresh;
        return fresh;
    }

    private void AddStepMappingRow(Guid stepId)
    {
        var list = GetStepMappings(stepId);
        list.Add(new AttributeMapping { Id = Guid.NewGuid(), SortOrder = list.Count });
        workflowsDirty = true;
    }

    private void RemoveStepMappingRow(Guid stepId, int index)
    {
        var list = GetStepMappings(stepId);
        if (index < 0 || index >= list.Count) return;
        list.RemoveAt(index);
        workflowsDirty = true;
    }

    /// <summary>
    /// Populate a step's own mappings from the attribute template for THIS step's
    /// object class (context-aware: source family → target family → step class).
    /// Flips the step off "inherit from project" so the seeded rows are what runs.
    /// This is the per-step analogue of the wizard's project-level Auto-map; it is
    /// what makes object class a step-level decision — each step gets the mappings
    /// for its own class.
    /// </summary>
    private async Task AutoMapStepForClass(Guid stepId)
    {
        var step = StepById(stepId);
        if (step is null) return;

        var sourceType = tenantById.TryGetValue(form.SourceTenantId, out var src) ? src.SystemType : string.Empty;
        var sinkType = tenantById.TryGetValue(form.SinkTenantId, out var snk) ? snk.SystemType : string.Empty;
        if (string.IsNullOrWhiteSpace(sourceType))
        {
            await JS.InvokeVoidAsync("alert", "Pick a source Connected System on the Setup tab first.");
            return;
        }

        var stepClass = string.IsNullOrWhiteSpace(step.ObjectClass) ? "User" : step.ObjectClass!;
        var suggested = AttributeMapper.BuildMappings(sourceType, sinkType, stepClass);
        if (suggested.Count == 0)
        {
            var msg = string.Concat("No attribute template available for ", sourceType, " ", stepClass, ".");
            await JS.InvokeVoidAsync("alert", msg);
            return;
        }

        var current = GetStepMappings(stepId);
        var hasEdits = current.Any(m =>
            !string.IsNullOrWhiteSpace(m.SourceAttribute) || !string.IsNullOrWhiteSpace(m.SinkAttribute));
        var replace = true;
        if (hasEdits)
        {
            replace = await JS.InvokeAsync<bool>("confirm",
                "Replace this step's mappings with the auto-mapped set for its object class? Choose Cancel to keep what's there.");
            if (!replace) return;
        }

        // Re-stamp SortOrder so the seeded rows persist in template order.
        for (int i = 0; i < suggested.Count; i++) suggested[i].SortOrder = i;
        stepMappings[stepId] = suggested;
        stepMappingsLoaded.Add(stepId);
        stepMappingsInherit[stepId] = false; // step now OWNS its class-specific mappings
        workflowsDirty = true;
    }

    private WorkflowStep? StepById(Guid stepId)
    {
        foreach (var kv in stepsByWorkflow)
        {
            var hit = kv.Value.FirstOrDefault(s => s.Id == stepId);
            if (hit is not null) return hit;
        }
        return null;
    }

    /// <summary>One per-step Object Class &lt;option&gt;: the persisted value + its label.</summary>
    private sealed record StepClassOption(string Value, string Label);

    /// <summary>
    /// V23 fix: the per-step Object Class option set. Values are the LOWERCASE native
    /// class names the generator and <c>SyncProjectGenerator.GetObjectClasses</c> actually
    /// persist (user, group, computer, organizationalUnit, contact) — IC uses the same
    /// lowercase convention. Sink-specific extras are appended for AWS SSO / Entra. If
    /// the step's current class falls outside this set (e.g. an AD-infrastructure class
    /// on a non-AD sink), it is appended as a "(current)" option so a freshly-generated
    /// step never renders a blank select or silently loses its class on edit.
    /// </summary>
    private List<StepClassOption> StepObjectClassOptionsFor(string? currentClass)
    {
        // IDENTITIES RULE: an IC/Identities-targeted project may only carry user
        // steps — offer user alone (the "(current)" fallback below still preserves
        // any pre-existing non-user step's value so the select never renders blank).
        if (WizardIcIdentitiesInvolved)
        {
            var idOptions = new List<StepClassOption> { new("user", "User") };
            if (!string.IsNullOrWhiteSpace(currentClass)
                && !string.Equals(currentClass, "user", StringComparison.OrdinalIgnoreCase))
            {
                idOptions.Add(new(currentClass!, $"{currentClass} (current)"));
            }
            return idOptions;
        }

        var options = new List<StepClassOption>
        {
            new("user", "User"),
            new("group", "Group"),
            new("computer", "Computer"),
            new("organizationalUnit", "Organizational Unit"),
            new("contact", "Contact")
        };
        if (SinkIsAwsSso)
        {
            options.Add(new("assignment", "Assignment (AWS SSO)"));
            options.Add(new("groupMembership", "Group Membership"));
        }
        else if (SinkIsEntraID)
        {
            options.Add(new("servicePrincipal", "Service Principal"));
            options.Add(new("application", "Application"));
            options.Add(new("device", "Device"));
            options.Add(new("m365usage", "M365 Usage (per-user)"));
        }
        if (!string.IsNullOrWhiteSpace(currentClass)
            && !options.Any(o => string.Equals(o.Value, currentClass, StringComparison.OrdinalIgnoreCase)))
        {
            options.Add(new(currentClass!, $"{currentClass} (current)"));
        }
        return options;
    }

    /// <summary>
    /// Phase 8. Operator flipped the "inherit from project" toggle for a step's
    /// mappings. When checked → we'll write zero rows on Save (orchestrator
    /// falls through to project-level). When unchecked → preserve whatever the
    /// operator typed; if the list is empty, seed one blank row to make the
    /// table visible.
    /// </summary>
    private void OnStepMappingsInheritChanged(Guid stepId, ChangeEventArgs e)
    {
        var inherit = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;
        stepMappingsInherit[stepId] = inherit;
        if (!inherit && GetStepMappings(stepId).Count == 0)
        {
            AddStepMappingRow(stepId);
        }
        workflowsDirty = true;
    }

    private void OnStepScopeInheritChanged(Guid stepId, ChangeEventArgs e)
    {
        var inherit = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;
        stepScopeInherit[stepId] = inherit;
        // GetStepScope materializes a fresh blank scope on first edit when needed.
        workflowsDirty = true;
    }

    private void AddStep(Guid workflowId)
    {
        if (!stepsByWorkflow.TryGetValue(workflowId, out var list))
        {
            list = new List<WorkflowStep>();
            stepsByWorkflow[workflowId] = list;
        }
        var step = new WorkflowStep
        {
            Id = Guid.NewGuid(),
            WorkflowId = workflowId,
            Name = $"Step {list.Count + 1}",
            StepType = WorkflowStepTypes.Mapping,
            ObjectClass = "user", // lowercase native class name (matches generator + option set)
            Ordinal = list.Count,
            Enabled = true
        };
        list.Add(step);
        selectedWorkflowId = workflowId;
        selectedStepId = step.Id;
        workflowsDirty = true;
    }

    private void DeleteStep()
    {
        if (SelectedStep is null) return;
        var st = SelectedStep;
        if (stepsByWorkflow.TryGetValue(st.WorkflowId, out var list))
        {
            list.Remove(st);
            stepsDeleted.Add(st.Id);
            workflowsDirty = true;
            selectedStepId = list.FirstOrDefault()?.Id;
        }
    }

    private void DeleteWorkflow()
    {
        if (SelectedWorkflow is null) return;
        var wf = SelectedWorkflow;
        workflowsForm.Remove(wf);
        if (stepsByWorkflow.Remove(wf.Id, out var steps))
        {
            foreach (var s in steps) stepsDeleted.Add(s.Id);
        }
        workflowsDeleted.Add(wf.Id);
        workflowsDirty = true;
        selectedWorkflowId = workflowsForm.FirstOrDefault()?.Id;
        selectedStepId = null;
    }

    private void MoveStepUp() => ReorderStep(-1);
    private void MoveStepDown() => ReorderStep(+1);
    private void ReorderStep(int delta)
    {
        if (SelectedStep is null) return;
        var st = SelectedStep;
        if (!stepsByWorkflow.TryGetValue(st.WorkflowId, out var list)) return;
        var idx = list.IndexOf(st);
        var target = idx + delta;
        if (target < 0 || target >= list.Count) return;
        list[idx] = list[target];
        list[target] = st;
        for (int i = 0; i < list.Count; i++) list[i].Ordinal = i;
        workflowsDirty = true;
    }

    private void MoveWorkflowUp() => ReorderWorkflow(-1);
    private void MoveWorkflowDown() => ReorderWorkflow(+1);
    private void ReorderWorkflow(int delta)
    {
        if (SelectedWorkflow is null) return;
        var wf = SelectedWorkflow;
        var idx = workflowsForm.IndexOf(wf);
        var target = idx + delta;
        if (target < 0 || target >= workflowsForm.Count) return;
        workflowsForm[idx] = workflowsForm[target];
        workflowsForm[target] = wf;
        for (int i = 0; i < workflowsForm.Count; i++) workflowsForm[i].Ordinal = i;
        workflowsDirty = true;
    }

    /// <summary>
    /// Phase 7. Called from SaveForm to persist the workflow tree on Save. Idempotent —
    /// uses Insert-or-Update via repo per row, then issues deletes for anything dropped.
    /// </summary>
    private async Task PersistWorkflowsAsync(Guid projectId)
    {
        if (!workflowsDirty && workflowsForm.Count == 0) return;

        // Deletions first so a re-add with the same name doesn't collide.
        foreach (var id in stepsDeleted)        await WorkflowRepo.DeleteStepAsync(id);
        foreach (var id in workflowsDeleted)    await WorkflowRepo.DeleteAsync(id);
        stepsDeleted.Clear();
        workflowsDeleted.Clear();

        for (int i = 0; i < workflowsForm.Count; i++)
        {
            var wf = workflowsForm[i];
            wf.SyncProjectId = projectId;
            wf.Ordinal = i;
            var existing = await WorkflowRepo.GetByIdAsync(wf.Id);
            if (existing is null) await WorkflowRepo.CreateAsync(wf);
            else                  await WorkflowRepo.UpdateAsync(wf);

            if (stepsByWorkflow.TryGetValue(wf.Id, out var steps))
            {
                for (int j = 0; j < steps.Count; j++)
                {
                    var s = steps[j];
                    s.WorkflowId = wf.Id;
                    s.Ordinal = j;
                    var existingStep = await WorkflowRepo.GetStepByIdAsync(s.Id);
                    if (existingStep is null) await WorkflowRepo.CreateStepAsync(s);
                    else                       await WorkflowRepo.UpdateStepAsync(s);

                    // Phase 8: per-step mapping + scope persistence. Only flush
                    // what the operator actually opened in the editor — untouched
                    // steps stay as-is (the loaded-set guards keep this cheap).
                    if (string.Equals(s.StepType, WorkflowStepTypes.Mapping, StringComparison.OrdinalIgnoreCase)
                        && stepMappingsLoaded.Contains(s.Id))
                    {
                        var inherit = !stepMappingsInherit.TryGetValue(s.Id, out var inhM) || inhM;
                        // Inherit-from-project → write zero rows (orchestrator falls through).
                        // Otherwise → push cleaned-up rows.
                        if (inherit)
                        {
                            await WorkflowRepo.ReplaceMappingsForStepAsync(projectId, s.Id, Array.Empty<AttributeMapping>());
                        }
                        else
                        {
                            var rows = GetStepMappings(s.Id)
                                .Where(m => !string.IsNullOrWhiteSpace(m.SourceAttribute) || !string.IsNullOrWhiteSpace(m.SinkAttribute))
                                .ToList();
                            await WorkflowRepo.ReplaceMappingsForStepAsync(projectId, s.Id, rows);
                        }
                    }

                    if (string.Equals(s.StepType, WorkflowStepTypes.Mapping, StringComparison.OrdinalIgnoreCase)
                        && stepScopesLoaded.Contains(s.Id))
                    {
                        var inherit = !stepScopeInherit.TryGetValue(s.Id, out var inhS) || inhS;
                        if (!inherit)
                        {
                            await WorkflowRepo.UpsertScopeForStepAsync(projectId, s.Id, GetStepScope(s.Id));
                        }
                        // Inherit path intentionally leaves the per-step scope row
                        // alone — repo wipes happen only if the operator explicitly
                        // edited then re-checked inherit. Simpler to leave a stale
                        // row (orchestrator only consults it when present) than to
                        // forge a DELETE here. If staleness becomes a problem we
                        // can add WorkflowRepository.DeleteScopeForStepAsync later.
                    }
                }
            }
        }
    }


@*
    CcDirectoryBrowserModal — shared live directory/OU container browser.

    Ports IdentityCenter's OU browser UX into Conduit. Given a source tenant id,
    it resolves that tenant's connector adapter, asks for an IConnectorContainerBrowser,
    and lazy-loads OUs/containers one level at a time via a live bind against the
    source. The operator drills down, picks a container, and the chosen DN is
    returned to the caller — used by the Sync wizard's Base DN field.

    Usage:
      <CcDirectoryBrowserModal @ref="_dnBrowser" OnSelected="dn => { scopeForm.BaseDN = dn; }" />
      ...
      await _dnBrowser.ShowAsync(form.SourceTenantId, form.SourceCredentialName);

    Reusable: any future "pick a container/Base DN" need (sink target OU, etc.)
    can take a @ref to this same component.
*@

@implements IDisposable
@using Conduit.Shared.SyncUI
@using Conduit.Web.Shared.Design
@inject Conduit.Sync.Connectors.ConnectorRegistry ConnectorRegistry
@inject Conduit.DataAccess.Repositories.TenantRepository TenantRepo

@if (IsVisible)
{
    <div class="modal-backdrop fade show" @onclick="Cancel"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-diagram-3 me-2"></i>@(ScopeMode ? "Select Scope Locations" : "Browse containers")
                    </h5>
                    <button type="button" class="btn-close" @onclick="Cancel" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (ScopeMode)
                    {
                        @* OPTION-A PILOT: scope mode now renders the SHARED ScopeTree
                           (Conduit.Shared.SyncUI) — the same component IC runs — driven by
                           a ConduitScopeDataSource over the live container browser. The
                           component carries its own legend, 4-state icons (self-contained
                           inline SVG, no font dependency → fixes the blank-icon drift), and
                           the "N included, M blocked" summary. *@
                        @if (IsLoadingRoot)
                        {
                            <div class="text-center p-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading…</span>
                                </div>
                                <p class="mt-2 mb-0 text-muted">Binding to the source directory…</p>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="alert alert-danger mb-0" role="alert">
                                <i class="bi bi-exclamation-triangle me-2"></i>@ErrorMessage
                            </div>
                        }
                        else if (_scopeDataSource is not null)
                        {
                            <ScopeTree DataSource="_scopeDataSource"
                                       SelectedScopes="includedScopes"
                                       BlockedScopes="blockedScopes"
                                       DefaultRootWhenEmpty="false"
                                       ContextKey="@_scopeContextKey" />
                        }
                    }
                    else
                    {
                        <p class="text-muted small mb-3">
                            Select a container to use as the Base DN for this read.
                            Only objects within it (and its children) are synchronized.
                        </p>

                        @if (IsLoadingRoot)
                        {
                            <div class="text-center p-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading…</span>
                                </div>
                                <p class="mt-2 mb-0 text-muted">Binding and loading containers…</p>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="alert alert-danger mb-0" role="alert">
                                <i class="bi bi-exclamation-triangle me-2"></i>@ErrorMessage
                            </div>
                        }
                        else if (rootNodes.Count == 0)
                        {
                            <div class="alert alert-info mb-0" role="alert">
                                <i class="bi bi-info-circle me-2"></i>
                                No containers found under the directory root.
                            </div>
                        }
                        else
                        {
                            <div class="cc-dn-tree">
                                @foreach (var node in rootNodes)
                                {
                                    @RenderNode(node, 0)
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(selectedDn))
                        {
                            <div class="cc-dn-selected mt-3">
                                <i class="bi bi-check2-circle cc-dn-selected-icon"></i>
                                <span class="cc-dn-selected-label">Selected</span>
                                <code class="cc-dn-selected-dn">@selectedDn</code>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="Cancel">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    @if (ScopeMode)
                    {
                        <button type="button" class="btn btn-primary" @onclick="ApplyScopes">
                            <i class="bi bi-check-circle me-1"></i>Apply Scopes
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" disabled="@(string.IsNullOrEmpty(selectedDn))" @onclick="Apply">
                            <i class="bi bi-check-circle me-1"></i>Use this container
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>Fires with the chosen distinguished name when the operator clicks "Use this container" (single-pick mode).</summary>
    [Parameter] public EventCallback<string> OnSelected { get; set; }

    /// <summary>
    /// Fires with (Included DNs, Blocked DNs) when the operator clicks "Apply Scopes"
    /// in multi-select scope mode. Inherited is not returned — it is the computed
    /// state of a child whose ancestor is Included, derived in the UI and re-derived
    /// at read time, never persisted as its own entry. Mirrors IC's MultiScopeBrowser.
    /// </summary>
    [Parameter] public EventCallback<(HashSet<string> Included, HashSet<string> Blocked)> OnScopesSelected { get; set; }

    private bool IsVisible { get; set; }
    private bool IsLoadingRoot { get; set; }
    private string? ErrorMessage { get; set; }
    private string? selectedDn;

    // Multi-select scope mode (IC parity). When true, the tree shows a 4-state
    // cycle icon per node instead of single-select rows. The two sets ARE the
    // model the caller persists; Inherited is computed, never stored.
    private bool ScopeMode { get; set; }
    private readonly HashSet<string> includedScopes = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> blockedScopes = new(StringComparer.OrdinalIgnoreCase);

    private Guid _tenantId;
    private string? _credentialName;
    private Conduit.Sync.Connectors.IConnectorContainerBrowser? _browser;

    // Option-A pilot: in scope mode the shared ScopeTree owns the loading via this
    // adapter. _scopeContextKey changes per open so ScopeTree reloads from root.
    private IScopeDataSource? _scopeDataSource;
    private string? _scopeContextKey;

    private readonly List<Node> rootNodes = new();

    private sealed class Node
    {
        public string Name { get; set; } = "";
        public string Dn { get; set; } = "";
        public string? Description { get; set; }
        public bool HasChildren { get; set; }
        public bool IsExpanded { get; set; }
        public bool IsLoading { get; set; }
        public bool Loaded { get; set; }
        public string? LoadError { get; set; }
        public List<Node> Children { get; } = new();
    }

    /// <summary>
    /// Open the browser for the given source tenant. <paramref name="credentialName"/>
    /// is the per-project source credential override (may be null/blank for the
    /// default 'ldap' credential).
    /// </summary>
    public async Task ShowAsync(Guid tenantId, string? credentialName = null)
    {
        ScopeMode = false;
        includedScopes.Clear();
        blockedScopes.Clear();
        _tenantId = tenantId;
        _credentialName = credentialName;
        selectedDn = null;
        ErrorMessage = null;
        rootNodes.Clear();
        _browser = null;
        _scopeDataSource = null;
        IsVisible = true;
        IsLoadingRoot = true;
        StateHasChanged();

        await ResolveBrowserAndLoadRootAsync();

        IsLoadingRoot = false;
        StateHasChanged();
    }

    /// <summary>
    /// Open the browser in IC-style multi-select scope mode, pre-seeded with the
    /// currently-Included and currently-Blocked DN sets. The tree shows the 4-state
    /// cycle and returns the edited sets via <see cref="OnScopesSelected"/>.
    /// </summary>
    public async Task ShowForScopeAsync(
        Guid tenantId,
        string? credentialName,
        IEnumerable<string>? included,
        IEnumerable<string>? blocked)
    {
        ScopeMode = true;
        includedScopes.Clear();
        blockedScopes.Clear();
        if (included is not null)
            foreach (var dn in included.Where(d => !string.IsNullOrWhiteSpace(d)))
                includedScopes.Add(dn.Trim());
        if (blocked is not null)
            foreach (var dn in blocked.Where(d => !string.IsNullOrWhiteSpace(d)))
                blockedScopes.Add(dn.Trim());

        _tenantId = tenantId;
        _credentialName = credentialName;
        selectedDn = null;
        ErrorMessage = null;
        rootNodes.Clear();
        _browser = null;
        _scopeDataSource = null;
        IsVisible = true;
        IsLoadingRoot = true;
        StateHasChanged();

        await ResolveBrowserAndLoadRootAsync();

        IsLoadingRoot = false;
        StateHasChanged();
    }

    private async Task ResolveBrowserAndLoadRootAsync()
    {
        if (_tenantId == Guid.Empty)
        {
            ErrorMessage = "No source system selected.";
            return;
        }

        var tenant = await TenantRepo.GetByIdAsync(_tenantId);
        if (tenant is null)
        {
            ErrorMessage = "Source system not found.";
            return;
        }

        var adapter = ConnectorRegistry.Get(tenant.SystemType);
        if (adapter is null)
        {
            ErrorMessage = string.Concat("No connector registered for '", tenant.SystemType, "'.");
            return;
        }

        // Phase 3 honors per-project credential-name override during the live bind.
        using var scope = Conduit.Sync.Security.CredentialNameContext.Push(_credentialName, null);

        _browser = adapter.CreateContainerBrowser(_tenantId);
        if (_browser is null)
        {
            ErrorMessage = string.Concat(tenant.SystemType, " does not support container browsing. Enter the Base DN manually.");
            return;
        }

        // Option-A pilot: scope mode delegates ALL loading to the shared ScopeTree
        // via the adapter — the modal no longer hand-loads/renders the scope tree.
        if (ScopeMode)
        {
            _scopeDataSource = new ConduitScopeDataSource(_browser, _credentialName);
            _scopeContextKey = Guid.NewGuid().ToString("N");
            return;
        }

        // Single-pick (Base DN) mode keeps the modal's own lazy tree unchanged.
        try
        {
            var result = await _browser.BrowseContainersAsync(null, CancellationToken.None);
            if (!string.IsNullOrEmpty(result.ErrorMessage))
            {
                ErrorMessage = result.ErrorMessage;
                return;
            }
            foreach (var n in result.Nodes)
                rootNodes.Add(ToNode(n));
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private static Node ToNode(Conduit.Sync.Connectors.DirectoryContainerNode n) => new()
    {
        Name = n.Name,
        Dn = n.DistinguishedName,
        Description = n.Description,
        HasChildren = n.HasChildren
    };

    private async Task ToggleAsync(Node node)
    {
        if (_browser is null) return;

        if (!node.IsExpanded && !node.Loaded)
        {
            node.IsLoading = true;
            node.LoadError = null;
            StateHasChanged();
            using var scope = Conduit.Sync.Security.CredentialNameContext.Push(_credentialName, null);
            try
            {
                var result = await _browser.BrowseContainersAsync(node.Dn, CancellationToken.None);
                node.Children.Clear();
                if (!string.IsNullOrEmpty(result.ErrorMessage))
                {
                    // Surface the child-load failure on the node instead of
                    // silently collapsing it to a phantom leaf. A swallowed error
                    // here is exactly what reads as "can't expand the tree".
                    node.LoadError = result.ErrorMessage;
                    node.Loaded = false; // allow retry on next expand
                }
                else
                {
                    foreach (var c in result.Nodes)
                        node.Children.Add(ToNode(c));
                    node.HasChildren = node.Children.Count > 0;
                    node.Loaded = true;
                }
            }
            catch (Exception ex)
            {
                node.Children.Clear();
                node.LoadError = ex.Message;
                node.Loaded = false; // allow retry on next expand
            }
            finally
            {
                node.IsLoading = false;
            }
        }

        node.IsExpanded = !node.IsExpanded;
        StateHasChanged();
    }

    private async Task RetryAsync(Node node)
    {
        // Node is still unloaded after a failed expand (Loaded==false), so just
        // re-run the load path. Collapse first so ToggleAsync takes the load branch.
        node.IsExpanded = false;
        node.LoadError = null;
        await ToggleAsync(node);
    }

    private void Select(Node node)
    {
        selectedDn = node.Dn;
        StateHasChanged();
    }

    private async Task Apply()
    {
        if (string.IsNullOrEmpty(selectedDn)) return;
        IsVisible = false;
        var dn = selectedDn;
        StateHasChanged();
        await OnSelected.InvokeAsync(dn);
    }

    private async Task ApplyScopes()
    {
        IsVisible = false;
        StateHasChanged();
        await OnScopesSelected.InvokeAsync(
            (new HashSet<string>(includedScopes, StringComparer.OrdinalIgnoreCase),
             new HashSet<string>(blockedScopes, StringComparer.OrdinalIgnoreCase)));
    }

    /// <summary>
    /// IC-parity 4-state cycle on the node's explicit state:
    /// NotSelected → Included → Blocked → NotSelected.
    /// Inherited is never an explicit state — it falls out of an Included ancestor.
    /// </summary>
    private void CycleScope(Node node)
    {
        var dn = node.Dn;
        if (string.IsNullOrWhiteSpace(dn)) return;

        if (blockedScopes.Contains(dn))
        {
            blockedScopes.Remove(dn); // Blocked → NotSelected
        }
        else if (includedScopes.Contains(dn))
        {
            includedScopes.Remove(dn); // Included → Blocked
            blockedScopes.Add(dn);
        }
        else
        {
            includedScopes.Add(dn);    // NotSelected → Included
        }
        StateHasChanged();
    }

    /// <summary>True when an ancestor DN of <paramref name="dn"/> is explicitly Included.</summary>
    private bool IsAncestorIncluded(string dn) => IsAncestorInSet(dn, includedScopes);

    /// <summary>True when an ancestor DN of <paramref name="dn"/> is explicitly Blocked.</summary>
    private bool IsAncestorBlocked(string dn) => IsAncestorInSet(dn, blockedScopes);

    private static bool IsAncestorInSet(string dn, HashSet<string> set)
    {
        if (string.IsNullOrEmpty(dn) || set.Count == 0) return false;
        var parts = dn.Split(',');
        for (int i = 1; i < parts.Length; i++)
        {
            var ancestor = string.Join(",", parts.Skip(i));
            if (set.Contains(ancestor)) return true;
        }
        return false;
    }

    private void Cancel()
    {
        IsVisible = false;
        StateHasChanged();
    }

    public void Dispose() { }

    private RenderFragment RenderNode(Node node, int depth) => __builder =>
    {
        var isSelectedRow = !ScopeMode && node.Dn == selectedDn;
        var rowClass = isSelectedRow ? "cc-dn-row selected" : "cc-dn-row";
        var indent = string.Concat((depth * 18).ToString(), "px");
        // In scope mode the whole row toggles expand (drill-in); state is set via the
        // icon. In single-pick mode the row selects.
        Action rowClick = ScopeMode ? (() => { _ = ToggleAsync(node); }) : (() => Select(node));

        <div class="@rowClass" style="padding-left:@indent" @onclick="@rowClick">
            @if (node.HasChildren)
            {
                <span class="cc-dn-chevron" role="button" aria-expanded="@node.IsExpanded" @onclick="@(() => ToggleAsync(node))" @onclick:stopPropagation>
                    <i class="bi @(node.IsExpanded ? "bi-chevron-down" : "bi-chevron-right")"></i>
                </span>
            }
            else
            {
                <span class="cc-dn-chevron cc-dn-chevron-empty"></span>
            }
            @if (ScopeMode)
            {
                var isBlocked = blockedScopes.Contains(node.Dn);
                var isIncluded = includedScopes.Contains(node.Dn);
                var ancestorBlocked = !isBlocked && !isIncluded && IsAncestorBlocked(node.Dn);
                var ancestorIncluded = !isBlocked && !isIncluded && !ancestorBlocked && IsAncestorIncluded(node.Dn);
                var scopeIcon =
                    isBlocked        ? "bi-slash-circle-fill text-danger"
                  : isIncluded       ? "bi-check-circle-fill text-success"
                  : ancestorBlocked  ? "bi-dash-circle text-danger"
                  : ancestorIncluded ? "bi-check-circle text-success"
                  :                    "bi-circle text-muted";
                var scopeTitle =
                    isBlocked        ? "Explicitly Blocked — click to clear"
                  : isIncluded       ? "Explicitly Included — click to block"
                  : ancestorBlocked  ? "Inherited Blocked (ancestor blocked)"
                  : ancestorIncluded ? "Inherited (ancestor included)"
                  :                    "Not selected — click to include";
                <span class="cc-dn-scope" role="button" title="@scopeTitle" @onclick="@(() => CycleScope(node))" @onclick:stopPropagation>
                    <i class="bi @scopeIcon"></i>
                </span>
            }
            <span class="cc-dn-icon"><i class="bi @(node.IsExpanded ? "bi-folder2-open" : "bi-folder-fill")"></i></span>
            <span class="cc-dn-text" title="@node.Dn">
                <span class="cc-dn-name">@node.Name</span>
                @if (!string.IsNullOrEmpty(node.Description))
                {
                    <span class="cc-dn-desc">@node.Description</span>
                }
            </span>
        </div>

        @if (node.IsExpanded && node.IsLoading)
        {
            var loadIndent = string.Concat(((depth + 1) * 18).ToString(), "px");
            <div class="cc-dn-row cc-dn-status" style="padding-left:@loadIndent">
                <span class="cc-dn-chevron cc-dn-chevron-empty"></span>
                <i class="bi bi-arrow-repeat cc-dn-spin me-1"></i>
                <span class="cc-dn-statustext">Loading…</span>
            </div>
        }
        else if (node.IsExpanded && !string.IsNullOrEmpty(node.LoadError))
        {
            var errIndent = string.Concat(((depth + 1) * 18).ToString(), "px");
            <div class="cc-dn-row cc-dn-error" style="padding-left:@errIndent" title="@node.LoadError">
                <span class="cc-dn-chevron cc-dn-chevron-empty"></span>
                <i class="bi bi-exclamation-triangle me-1"></i>
                <span class="cc-dn-errtext">@node.LoadError</span>
                <button type="button" class="btn btn-link btn-sm p-0 ms-2 cc-dn-retry" @onclick="@(() => RetryAsync(node))" @onclick:stopPropagation>retry</button>
            </div>
        }
        else if (node.IsExpanded)
        {
            @foreach (var child in node.Children)
            {
                @RenderNode(child, depth + 1)
            }
        }
    };
}

<style>
    .cc-dn-tree {
        border: 1px solid var(--border, rgba(120,160,220,0.10));
        border-radius: 10px;
        padding: .4rem;
        max-height: 440px;
        overflow-y: auto;
        background: var(--surface-inset, var(--panel-2, #131F36));
    }

    /* Row: comfortable height, whole row is the select target, clear hover/selected. */
    .cc-dn-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .45rem .55rem;
        border-radius: 8px;
        cursor: pointer;
        white-space: nowrap;
        transition: background-color .12s ease;
    }
    .cc-dn-row:hover {
        background: var(--accent-50, rgba(34,211,238,0.06));
    }
    .cc-dn-row.selected {
        background: var(--accent-100, rgba(34,211,238,0.14));
        box-shadow: inset 2px 0 0 var(--accent, #22d3ee);
    }

    /* Chevron: obvious hit target, rotates open/closed, dims when no children. */
    .cc-dn-chevron {
        flex: 0 0 auto;
        width: 1.4rem;
        height: 1.4rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        cursor: pointer;
        color: var(--text-secondary, var(--text-2, #9DB0CC));
        transition: background-color .12s ease, color .12s ease;
    }
    .cc-dn-chevron:hover {
        background: var(--accent-100, rgba(34,211,238,0.14));
        color: var(--accent, #22d3ee);
    }
    .cc-dn-chevron-empty {
        cursor: inherit;
        pointer-events: none;
    }
    .cc-dn-chevron-empty:hover {
        background: transparent;
    }

    /* Folder/container icon — distinct, warm, sized to read as a node marker. */
    .cc-dn-icon {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        color: #f0b450;
        font-size: 1.02rem;
    }

    /* Text block: name on top (primary), description demoted to a legible second line. */
    .cc-dn-text {
        display: flex;
        flex-direction: column;
        line-height: 1.25;
        min-width: 0;
        overflow: hidden;
    }
    .cc-dn-name {
        font-weight: 600;
        font-size: .92rem;
        color: var(--text-primary, var(--text, #E4EDFB));
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .cc-dn-desc {
        font-size: .78rem;
        color: var(--text-secondary, var(--text-2, #9DB0CC));
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Loading / status rows */
    .cc-dn-status { cursor: default; color: var(--text-secondary, var(--text-2, #9DB0CC)); }
    .cc-dn-status:hover { background: transparent; }
    .cc-dn-statustext { font-size: .85rem; }
    .cc-dn-spin { animation: cc-dn-spin 1s linear infinite; display: inline-block; }
    @@keyframes cc-dn-spin { to { transform: rotate(360deg); } }

    /* Error row + retry */
    .cc-dn-error {
        color: var(--bs-danger, #f1707a);
        white-space: normal;
        cursor: default;
    }
    .cc-dn-error:hover { background: transparent; }
    .cc-dn-errtext { font-size: .82rem; }
    .cc-dn-retry { font-size: .82rem; font-weight: 600; }

    /* Selected-DN confirmation strip in the modal body. */
    .cc-dn-selected {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .55rem .7rem;
        border-radius: 8px;
        background: var(--accent-100, rgba(34,211,238,0.14));
        border: 1px solid var(--accent-200, rgba(34,211,238,0.22));
    }
    .cc-dn-selected-icon { color: var(--accent, #22d3ee); font-size: 1.05rem; flex: 0 0 auto; }
    .cc-dn-selected-label {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--accent, #22d3ee);
        flex: 0 0 auto;
    }
    .cc-dn-selected-dn {
        font-size: .85rem;
        color: var(--text-primary, var(--text, #E4EDFB));
        background: transparent;
        padding: 0;
        word-break: break-all;
        white-space: normal;
    }

    /* ─── Multi-select scope mode ─── */
    .cc-scope-legend {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem 1rem;
        padding: .6rem .7rem;
        border-radius: 8px;
        background: var(--surface-inset, var(--panel-2, #131F36));
        border: 1px solid var(--border, rgba(120,160,220,0.10));
    }
    .cc-scope-legend-item {
        font-size: .8rem;
        color: var(--text-secondary, var(--text-2, #9DB0CC));
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }
    .cc-scope-legend-hint {
        flex-basis: 100%;
        font-size: .76rem;
        color: var(--text-secondary, var(--text-2, #9DB0CC));
        opacity: .85;
        margin-top: .15rem;
    }
    /* The 4-state cycle icon — obvious hit target, sits before the folder icon. */
    .cc-dn-scope {
        flex: 0 0 auto;
        width: 1.5rem;
        height: 1.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        cursor: pointer;
        font-size: 1.02rem;
        transition: background-color .12s ease;
    }
    .cc-dn-scope:hover {
        background: var(--accent-100, rgba(34,211,238,0.14));
    }
</style>

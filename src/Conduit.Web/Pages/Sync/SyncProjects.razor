    private async Task StopSyncConfirmed()
    {
        if (selectedProject is null) return;
        stopInProgress = true;
        stopError = string.Empty;
        try
        {
            // Trip the SAME cancellation token the orchestrator threads through
            // every step / sink loop. The orchestrator's existing
            // OperationCanceledException handler marks the run "Cancelled" and
            // releases IsRunning — no parallel stop path. A false return means the
            // run is not executing in this process (e.g. a scheduler tick on
            // another node, single-node assumption aside, or it already finished).
            var signalled = CancellationRegistry.RequestCancel(selectedProject.Id);
            if (signalled)
            {
                var name = selectedProject.Name;
                showStopConfirmModal = false;
                toastSuccess = $"Stop requested for '{name}'. The run will cancel at its next checkpoint.";
            }
            else
            {
                stopError = "No in-flight run was found for this project in this process. It may have already finished — refresh to confirm.";
            }
            await Reload();
        }
        catch (Exception ex)
        {
            stopError = $"Stop failed: {ex.Message}";
        }
        finally
        {
            stopInProgress = false;
        }
    }


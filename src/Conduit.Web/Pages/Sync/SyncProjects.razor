    // generator uses, so the preview matches exactly what Auto-Generate builds.
    // Before a source is chosen the cards fall back to the generic set so the
    // user still sees representative classes.
    private IReadOnlyList<string> AutoGenClassesForMode(Conduit.Sync.Templates.GenerationMode mode)
    {

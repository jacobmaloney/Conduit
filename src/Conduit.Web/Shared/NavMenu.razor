@using Conduit.Core.Models
@using Conduit.Core.Services
@using Conduit.DataAccess.Repositories
@using Conduit.Web.Services
@inject TenantRepository TenantRepo
@inject UserRepository UserRepo
@inject GroupRepository GroupRepo
@inject ActiveSystemState ActiveSystem
@inject DataChangeNotifier DataChange
@inject OpenAccessState OpenAccess
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment
@implements IDisposable

<div class="nav-wrapper">
    <div class="nav-header">
        <div class="nav-brand-block">
            @* Conduit lockup — kept at the larger 72px size the user
               explicitly upsized to earlier this session. The design source
               shows 38px, but the user has been clear they want the mark big. *@
            <a class="nav-brand" href="">
                <ConduitMark Size="72" Color="var(--accent)" HubFill="var(--bg-2)" />
                <span><b>Conduit</b></span>
            </a>
        </div>
        <button class="nav-toggle" @onclick="ToggleNavMenu">
            <span class="nav-toggle-icon"></span>
        </button>
    </div>

    @* SCIM-origin chrome (Open-access pill + connected-system switcher) gated to
       Development only for the directory-sync product. IC has no parallel; this
       moves it off the primary sync nav without deleting it (item 6 decision,
       2026-05-31). Re-surface later behind a proper emulator/dev-tools flag. *@
    @if (ShowDevChrome && OpenAccess.IsEnabled)
    {
        <a class="open-access-pill" href="configuration" title="Portal authentication is OFF — click to manage in Configuration">
            <i class="oi oi-warning"></i>
            <span>Open access</span>
        </a>
    }

    <AuthorizeView>
        <Authorized>
            @if (ShowDevChrome)
            {
            <div class="system-switcher">
                <button class="ss-button" @onclick="ToggleSwitcher" @onclick:stopPropagation="true">
                    <span class="ss-glyph">@GlyphFor(ActiveSystem.ActiveSystem)</span>
                    <span class="ss-meta">
                        <span class="ss-name">@(ActiveSystem.ActiveSystem?.Name ?? "All connections")</span>
                        <span class="ss-domain">@SubtitleFor(ActiveSystem.ActiveSystem)</span>
                    </span>
                    <i class="oi oi-chevron-bottom ss-chev"></i>
                </button>
                @if (switcherOpen)
                {
                    <div class="ss-menu" @onclick:stopPropagation="true">
                        <div class="ss-menu-label">Connections</div>
                        <button class="ss-menu-item @(ActiveSystem.ActiveSystem == null ? "active" : "")"
                                @onclick="() => SelectSystemAsync(null)">
                            <span class="ss-glyph ss-glyph-sm">★</span>
                            <span class="ss-menu-meta">
                                <span>All connections</span>
                                <span class="ss-menu-domain">admin · cross-system</span>
                            </span>
                            <span class="kind-pill">Admin</span>
                        </button>
                        @foreach (var sys in tenants)
                        {
                            <button class="ss-menu-item @(ActiveSystem.ActiveSystem?.Id == sys.Id ? "active" : "")"
                                    title="@sys.Name"
                                    @onclick="() => SelectSystemAsync(sys)">
                                <span class="ss-glyph ss-glyph-sm">@GlyphFor(sys)</span>
                                <span class="ss-menu-meta">
                                    <span>@sys.Name</span>
                                    <span class="ss-menu-domain">@(sys.Domain ?? sys.Slug)</span>
                                </span>
                                <span class="kind-pill @(sys.SystemType == "Real" ? "kind-real" : "kind-emulator")">@sys.SystemType</span>
                            </button>
                        }
                        <div class="ss-menu-divider"></div>
                        <a class="ss-menu-add" href="connected-systems" @onclick="CloseSwitcher">
                            <i class="oi oi-plus"></i> Connect a system
                        </a>
                    </div>
                }
            </div>
            }
        </Authorized>
    </AuthorizeView>

    <nav class="nav-menu @NavMenuCssClass">
        @* SYNC is the primary experience for a directory-sync pump. Dashboard is
           the landing; everything else about MOVING identities lives under the
           Synchronization Center hub (which hosts Projects / History / Schedules /
           Processing / Connections as tabs — see SynchronizationCenter.razor).
           We deliberately surface ONE Sync front door instead of five nav links
           that all open tabs of the same hub (dedup decision 2026-06-20). *@
        <div class="nav-section nav-section-main">
            <div class="nav-section-title">Main</div>
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                <i class="oi oi-dashboard"></i>
                <span>Dashboard</span>
            </NavLink>
        </div>

        <div class="nav-section nav-section-sync">
            <div class="nav-section-title">Sync</div>
            @* Canonical home. The hub's tabs replace the old standalone
               Sync Projects / Sync History / Schedule Manager / Processing Center
               links — those routes still resolve for deep links, they're just no
               longer a second front door (dedup, 2026-06-20). *@
            <NavLink class="nav-item" href="synchronization-center">
                <i class="oi oi-loop-circular"></i>
                <span>Synchronization Center</span>
            </NavLink>
            <NavLink class="nav-item" href="connected-systems">
                <i class="oi oi-globe"></i>
                <span>Connections</span>
            </NavLink>
        </div>

        @* Directory browse pages are SCIM-server DNA (a sync PUMP doesn't lead
           with "Users / Groups" the way a SCIM server does). Demoted out of the
           top "Main" block into their own clearly-secondary section so the Sync
           experience reads as primary (declutter decision 2026-06-20). Still one
           click away; counts preserved. *@
        <div class="nav-section nav-section-directory">
            <div class="nav-section-title">Directory</div>
            <NavLink class="nav-item" href="users">
                <i class="oi oi-people"></i>
                <span>Users</span>
                @if (userCount is { } uc)
                {
                    <span class="nav-count" title="@CountTooltip">@uc.ToString("N0")</span>
                }
            </NavLink>
            <NavLink class="nav-item" href="groups">
                <i class="oi oi-badge"></i>
                <span>Groups</span>
                @if (groupCount is { } gc)
                {
                    <span class="nav-count" title="@CountTooltip">@gc.ToString("N0")</span>
                }
            </NavLink>
        </div>

        <div class="nav-section nav-section-tools">
            <div class="nav-section-title">Tools</div>
            @if (ActiveSystem.ActiveSystem is not null)
            {
                <NavLink class="nav-item" href="user-generation">
                    <i class="oi oi-people"></i>
                    <span>Generate Users</span>
                </NavLink>
                <NavLink class="nav-item" href="group-generation">
                    <i class="oi oi-layers"></i>
                    <span>Generate Groups</span>
                </NavLink>
            }
            <NavLink class="nav-item" href="quick-connect">
                <i class="oi oi-link-intact"></i>
                <span>Quick Connect</span>
            </NavLink>
            @* API Explorer + API Tokens are SCIM-origin chrome — kept (not
               deleted) but gated to Development so they don't clutter the
               primary directory-sync nav (item 6 decision, 2026-05-31). *@
            @if (ShowDevChrome)
            {
                <NavLink class="nav-item" href="api-explorer">
                    <i class="oi oi-code"></i>
                    <span>API Explorer</span>
                </NavLink>
                <NavLink class="nav-item" href="tokens">
                    <i class="oi oi-key"></i>
                    <span>API Tokens</span>
                </NavLink>
            }
        </div>

        <div class="nav-section nav-section-settings">
            <div class="nav-section-title">Settings</div>
            @* Connections moved up to the Sync section (it's core to the pump,
               not a setting). Not duplicated here to avoid a second front door. *@
            <NavLink class="nav-item" href="configuration">
                <i class="oi oi-cog"></i>
                <span>Configuration</span>
            </NavLink>
            <NavLink class="nav-item" href="admin/identity-providers">
                <i class="oi oi-key"></i>
                <span>Identity Providers</span>
            </NavLink>
            <NavLink class="nav-item" href="database-settings">
                <i class="oi oi-hard-drive"></i>
                <span>Database</span>
            </NavLink>
            <NavLink class="nav-item" href="audit-log">
                <i class="oi oi-list-rich"></i>
                <span>Audit Log</span>
            </NavLink>
            <NavLink class="nav-item" href="logs">
                <i class="oi oi-bug"></i>
                <span>Debug Logs</span>
            </NavLink>
        </div>
    </nav>

    <div class="nav-footer">
        <AuthorizeView>
            <Authorized>
                <div class="mb-2">
                    <small class="text-muted d-block">Signed in as</small>
                    <strong>@context.User.Identity?.Name</strong>
                </div>
                <a class="btn btn-sm btn-outline-secondary w-100" href="/logout">Sign out</a>
            </Authorized>
            <NotAuthorized>
                <a class="btn btn-sm btn-outline-primary w-100" href="/login">Sign in</a>
            </NotAuthorized>
        </AuthorizeView>
        <div class="nav-footer-info mt-2">
            <small>Identity synchronization</small>
            <small>Version 1.0.0</small>
        </div>
    </div>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    // SCIM-origin chrome (system switcher, Open-access pill, API Explorer,
    // API Tokens) is gated to Development for the directory-sync product.
    // Not deleted — just kept off the production sync nav (item 6, 2026-05-31).
    private bool ShowDevChrome => Environment.IsDevelopment();

    // System switcher state. The selected system is held in the scoped
    // ActiveSystemState service so the Users / Groups pages can read it.
    private bool switcherOpen;
    private List<Tenant> tenants = new();
    private int? userCount;
    private int? groupCount;

    private string CountTooltip => ActiveSystem.ActiveSystem is { } s
        ? $"Total in {s.Name}"
        : "Total across all connections";

    protected override void OnInitialized()
    {
        ActiveSystem.OnChangeAsync += HandleActiveChangedAsync;
        DataChange.OnChangedAsync += HandleDataChangedAsync;
    }

    private async Task HandleDataChangedAsync(DataChangeKind kind)
    {
        if (kind == DataChangeKind.Tenants)
        {
            try { tenants = await TenantRepo.GetAllAsync(); }
            catch (Exception ex) { Console.WriteLine($"NavMenu: tenant refresh failed — {ex.Message}"); }
        }
        await LoadCountsAsync();
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            tenants = await TenantRepo.GetAllAsync();
            await LoadCountsAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Sidebar must never crash the layout if the DB is unreachable —
            // e.g. before setup wizard completes. Log and render the empty state.
            Console.WriteLine($"NavMenu: failed to load tenants — {ex.Message}");
        }
    }

    public void Dispose()
    {
        ActiveSystem.OnChangeAsync -= HandleActiveChangedAsync;
        DataChange.OnChangedAsync -= HandleDataChangedAsync;
    }

    private async Task HandleActiveChangedAsync()
    {
        await LoadCountsAsync();
        await InvokeAsync(StateHasChanged);
    }

    // Fetches a count-only page (Count=1 keeps the SELECT cheap, totalCount comes
    // from the COUNT(*) in the same multi-result query). Scope honors the sidebar
    // selection so the badges reflect "this connector".
    private async Task LoadCountsAsync()
    {
        try
        {
            var scope = ActiveSystem.ActiveSystem?.Id;
            var (_, uTotal) = await UserRepo.GetAllAsync(
                new ScimQueryOptions { StartIndex = 1, Count = 1 }, tenantIdOverride: scope);
            var (_, gTotal) = await GroupRepo.GetAllAsync(
                new ScimQueryOptions { StartIndex = 1, Count = 1 }, tenantIdOverride: scope);
            userCount = uTotal;
            groupCount = gTotal;
        }
        catch
        {
            userCount = null;
            groupCount = null;
        }
    }

    private void ToggleSwitcher() => switcherOpen = !switcherOpen;
    private void CloseSwitcher() => switcherOpen = false;

    private async Task SelectSystemAsync(Tenant? sys)
    {
        switcherOpen = false;
        await ActiveSystem.SetAsync(sys);
    }

    private static string GlyphFor(Tenant? t)
    {
        if (t == null) return "★";
        var name = t.Name?.Trim();
        if (string.IsNullOrEmpty(name)) return "?";
        return char.ToUpperInvariant(name[0]).ToString();
    }

    private static string SubtitleFor(Tenant? t)
    {
        if (t == null) return "admin · view all";
        if (!string.IsNullOrWhiteSpace(t.Domain)) return t.Domain!;
        return t.Slug;
    }
}

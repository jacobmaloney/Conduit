@inherits LayoutComponentBase

<PageTitle>Conduit</PageTitle>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-bar">
            <div class="top-bar-content">
                <div class="breadcrumb"></div>
                <div class="top-bar-actions">
                    @* Mono-uppercase right-aligned utility links, per design.
                       .health adds the green dot affordance with the ring. *@
                    <a href="/api-explorer" class="top-bar-link mono">
                        <i class="oi oi-code"></i> API Docs
                    </a>
                    <a href="/health" target="_blank" class="top-bar-link mono health">
                        Health
                    </a>
                </div>
            </div>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<GenerationStatusIndicator />
@*
    CcConduitMark — the Conduit brand mark.
    Three input lines into a hub, one normalized output pipe.
    "Many sources → one schema." Use anywhere the Conduit brand mark appears.
    Sizing through @Size only — never wrap in inline style="".
*@

<svg class="cc-conduit-mark @CssClass"
     width="@Size" height="@Height"
     viewBox="0 0 180 160" fill="none" aria-hidden="true"
     xmlns="http://www.w3.org/2000/svg">
    <g stroke="@Color" stroke-width="6" fill="none" stroke-linecap="round">
        <path d="M 14 40 L 60 78"/>
        <path d="M 14 80 L 60 80"/>
        <path d="M 14 120 L 60 82"/>
    </g>
    <g fill="@Color" opacity=".55">
        <circle cx="14" cy="40" r="9"/>
        <circle cx="14" cy="80" r="9"/>
        <circle cx="14" cy="120" r="9"/>
    </g>
    <circle cx="78" cy="80" r="20" fill="@HubFill" stroke="@Color" stroke-width="6"/>
    <circle cx="78" cy="80" r="8" fill="@Color"/>
    <rect x="98" y="72" width="68" height="16" rx="8" fill="@Color"/>
    <polygon points="166,62 178,80 166,98" fill="@Color"/>
</svg>

@code {
    /// <summary>Width in pixels. Height is computed from the 180:160 viewBox aspect.</summary>
    [Parameter] public int Size { get; set; } = 32;

    /// <summary>Cyan stroke colour. Defaults to brand cyan; pass a CSS variable for theme-aware use.</summary>
    [Parameter] public string Color { get; set; } = "#22D3EE";

    /// <summary>Fill of the hub interior (knockout). Defaults to dark app background.</summary>
    [Parameter] public string HubFill { get; set; } = "#0B1424";

    /// <summary>Optional CSS class for callers that want to position or animate the mark.</summary>
    [Parameter] public string CssClass { get; set; } = "";

    private int Height => (int)System.Math.Round(Size * 160.0 / 180.0);
}

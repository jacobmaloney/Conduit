    // The default derived name — must match the generator's format EXACTLY:
    // "{src.Name} to {sink.Name} ({ModeLabel(mode)})". No literal double-quotes in
    // the interpolation (Razor SG would mis-tokenize them inside @code).
    private string AutoGenDefaultName()
    {
        var s = allTenants.FirstOrDefault(t => t.Id == autoGenSourceId);
        var k = allTenants.FirstOrDefault(t => t.Id == autoGenSinkId);
        if (s is null || k is null) return string.Empty;
        return $"{s.Name} to {k.Name} ({ModeLabel(autoGenMode)})";
    }


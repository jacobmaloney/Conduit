@page "/"
@attribute [Authorize]
@inject Conduit.DataAccess.Repositories.UserRepository UserRepository
@inject Conduit.DataAccess.Repositories.TenantRepository TenantRepo
@inject IWebHostEnvironment Environment

<PageTitle>Conduit — move identities across connected systems.</PageTitle>

<div class="hero-section mx-n4 mt-n4">
    <div class="hero-content">
        <h1 class="hero-title">Conduit</h1>
        <p class="hero-subtitle">Move identities, accounts, and entitlements across every connected system — one project, one clean schema.</p>
        <div class="hero-actions">
            <a href="/synchronization-center" class="btn btn-hero-primary">
                <i class="oi oi-loop-circular"></i> Synchronization Center
            </a>
            <a href="/connected-systems" class="btn btn-hero-secondary">
                <i class="oi oi-plug"></i> Connections
            </a>
        </div>
    </div>
</div>

<div class="container-fluid features-section">
    <div class="section-header">
        <h2>What Conduit does</h2>
        <p>Move identity, accounts, and entitlements across connected systems.</p>
    </div>

    <div class="row">
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="feature-card">
                <div class="feature-icon bg-primary-gradient">
                    <i class="oi oi-people"></i>
                </div>
                <h3>Users</h3>
                <p>Create, read, update, and deactivate user records. Custom attributes and the SCIM enterprise extension are supported.</p>
                <a href="/users" class="feature-link">Manage users <i class="oi oi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="feature-card">
                <div class="feature-icon bg-success-gradient">
                    <i class="oi oi-badge"></i>
                </div>
                <h3>Groups</h3>
                <p>Manage groups and membership. Nested groups and owner references work as expected.</p>
                <a href="/groups" class="feature-link">Manage groups <i class="oi oi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="feature-card">
                <div class="feature-icon bg-warning-gradient">
                    <i class="oi oi-plug"></i>
                </div>
                <h3>Connections</h3>
                <p>Connect Active Directory, Entra ID, Okta, Google, SCIM, databases, and more. Test the bind, then sync.</p>
                <a href="/connected-systems" class="feature-link">Manage connections <i class="oi oi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="feature-card">
                <div class="feature-icon bg-info-gradient">
                    <i class="oi oi-loop-square"></i>
                </div>
                <h3>Sync Projects</h3>
                <p>Define source → target, auto-map attributes per object class, schedule it, and watch every run.</p>
                <a href="/sync-projects" class="feature-link">Open sync projects <i class="oi oi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="feature-card">
                <div class="feature-icon bg-danger-gradient">
                    <i class="oi oi-cog"></i>
                </div>
                <h3>Configuration</h3>
                <p>Schemas, attributes, and server settings. Edit them where you need to.</p>
                <a href="/configuration" class="feature-link">Configure <i class="oi oi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="feature-card">
                <div class="feature-icon bg-purple-gradient">
                    <i class="oi oi-graph"></i>
                </div>
                <h3>Audit trail</h3>
                <p>Every operation is logged: who, what, when, and the request body.</p>
                <a href="/audit-log" class="feature-link">View logs <i class="oi oi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="stats-section">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card">
                    <div class="stat-icon text-primary">
                        <i class="oi oi-people"></i>
                    </div>
                    <div class="stat-content">
                        <h3>@userCount</h3>
                        <p>Total Users</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card">
                    <div class="stat-icon text-success">
                        <i class="oi oi-plug"></i>
                    </div>
                    <div class="stat-content">
                        <h3>@connectionCount</h3>
                        <p>Connections</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card">
                    <div class="stat-icon text-warning">
                        <i class="oi oi-badge"></i>
                    </div>
                    <div class="stat-content">
                        <h3>@groupCount</h3>
                        <p>Groups</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card">
                    <div class="stat-icon text-info">
                        <i class="oi oi-key"></i>
                    </div>
                    <div class="stat-content">
                        <h3>@tokenCount</h3>
                        <p>API Tokens</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid mt-4">
    <div class="section-header">
        <h2>Connected systems</h2>
        <p>External identity targets this server talks to. <a href="/connected-systems">Manage →</a></p>
    </div>
    @if (systemStats.Count == 0)
    {
        <div class="alert alert-info">
            No connected systems configured yet. <a href="/connected-systems">Connect one →</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var s in systemStats)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="card-title mb-1">@s.Name</h5>
                                    <small class="text-muted"><code>@s.Slug</code></small>
                                </div>
                                @if (s.SystemType == "Real")
                                {
                                    <span class="badge bg-success">REAL</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">EMULATOR</span>
                                }
                            </div>
                            <div class="row text-center mt-3">
                                <div class="col"><div class="fw-bold">@s.UserCount</div><small class="text-muted">Users</small></div>
                                <div class="col"><div class="fw-bold">@s.GroupCount</div><small class="text-muted">Groups</small></div>
                                <div class="col"><div class="fw-bold">@s.TokenCount</div><small class="text-muted">Tokens</small></div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* SCIM endpoint reference is developer chrome (SCIMServer origin) — kept for
   dev/debugging but gated off the production front door so the directory-sync
   story leads during a walkthrough. *@
@if (Environment.IsDevelopment())
{
<div class="api-section">
    <div class="container-fluid">
        <div class="section-header">
            <h2>SCIM 2.0 endpoints</h2>
            <p>Standard verb set on Users and Groups. RFC 7644 compliant.</p>
        </div>
        <div class="api-grid">
            <div class="api-endpoint">
                <span class="method get">GET</span>
                <code>/scim/v2/Users</code>
                <span class="description">List all users with pagination and filtering</span>
            </div>
            <div class="api-endpoint">
                <span class="method post">POST</span>
                <code>/scim/v2/Users</code>
                <span class="description">Create a new user resource</span>
            </div>
            <div class="api-endpoint">
                <span class="method get">GET</span>
                <code>/scim/v2/Users/{id}</code>
                <span class="description">Retrieve a specific user by ID</span>
            </div>
            <div class="api-endpoint">
                <span class="method put">PUT</span>
                <code>/scim/v2/Users/{id}</code>
                <span class="description">Replace an entire user resource</span>
            </div>
            <div class="api-endpoint">
                <span class="method patch">PATCH</span>
                <code>/scim/v2/Users/{id}</code>
                <span class="description">Partially update a user resource</span>
            </div>
            <div class="api-endpoint">
                <span class="method delete">DELETE</span>
                <code>/scim/v2/Users/{id}</code>
                <span class="description">Remove a user from the system</span>
            </div>
        </div>
    </div>
</div>
}

@code {
    private int userCount = 0;
    private int connectionCount = 0;
    private int groupCount = 0;
    private int tokenCount = 0;
    private List<Conduit.DataAccess.Repositories.TenantStats> systemStats = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Count-only fetch: the total comes from the COUNT(*) in the same query,
            // not from the returned page (Count=1 keeps the SELECT cheap).
            var (_, count) = await UserRepository.GetAllAsync(new Conduit.Core.Models.ScimQueryOptions { Count = 1 });
            userCount = count;
        }
        catch
        {
            userCount = 0;
        }
        try
        {
            systemStats = await TenantRepo.GetStatsAsync();
            connectionCount = systemStats.Count;
            groupCount = systemStats.Sum(s => s.GroupCount);
            tokenCount = systemStats.Sum(s => s.TokenCount);
        }
        catch
        {
            systemStats = new();
        }
    }
}
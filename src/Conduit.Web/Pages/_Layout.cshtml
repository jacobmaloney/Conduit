@using Microsoft.AspNetCore.Components.Web
@namespace Conduit.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <title>Conduit</title>
    @* Favicon stack — SVG primary (per Conduit Handoff §6.1), legacy .ico
       fallback for browsers that don't accept image/svg+xml. PNG sizes are
       not yet generated; the SVG covers modern browsers including PWAs. *@
    <link rel="icon" type="image/svg+xml" href="~/assets/brand/conduit-mark.svg" />
    <link rel="alternate icon" href="~/favicon.ico" />
    <link rel="apple-touch-icon" href="~/assets/brand/conduit-mark-reverse.svg" />
    <meta name="theme-color" content="#22D3EE" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=Inter+Tight:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    @* Vendor stylesheets first (Bootstrap grid + open-iconic), then the single
       canonical Conduit stylesheet last so its rules win where they need to. *@
    @* Brand tokens FIRST — the single source of truth for the whole palette
       (css/brand-tokens.css). Everything below consumes these variables; change
       the brand in that one file. Must load before Bootstrap so our tokens are
       defined when later rules reference them. *@
    <link rel="stylesheet" href="css/brand-tokens.css" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="css/open-iconic/font/css/open-iconic-bootstrap.min.css" />
    @* Font Awesome — the shared center-shared.css and the ported IdentityCenter
       workflow/step action buttons use fa-* glyphs; without this they render as
       empty boxes. Loaded locally (lib/fontawesome) to match IC, no CDN. *@
    <link rel="stylesheet" href="lib/fontawesome/css/all.min.css" />
    @* Shared design system stylesheet (cc-* components), then Conduit-owned
       overrides so consumer rules win where they overlap. *@
    <link rel="stylesheet" href="css/conduit-design.css" />
    @* Shared component CSS (the "center" look — synced from the brand repo at
       build, single-sourced with IdentityCenter). Loaded AFTER the design
       system so its component rules layer on the cc-* base, and BEFORE
       conduit.css so Conduit-owned overrides still win where they overlap. *@
    <link href="css/center-shared.css" rel="stylesheet" />
    <link href="css/conduit.css" rel="stylesheet" />
    <link href="Conduit.Web.styles.css" rel="stylesheet" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
    @* Bridges the [data-pct] attribute on progress bars to an inline width.
       Kept here (not in a .razor file) so .razor files stay free of inline
       style="" attributes. Runs on initial paint and on any DOM mutation so
       Blazor re-renders pick up new percentages. *@
    <script>
      (function () {
        function applyPct(el) {
          var v = el.getAttribute('data-pct');
          if (v == null) return;
          el.style.width = v + '%';
        }
        function scan(root) {
          (root || document).querySelectorAll('[data-pct]').forEach(applyPct);
        }
        document.addEventListener('DOMContentLoaded', function () { scan(document); });
        new MutationObserver(function (muts) {
          for (var i = 0; i < muts.length; i++) {
            var m = muts[i];
            if (m.type === 'attributes' && m.target && m.target.hasAttribute && m.target.hasAttribute('data-pct')) {
              applyPct(m.target);
            }
            if (m.addedNodes) {
              m.addedNodes.forEach(function (n) {
                if (n.nodeType === 1) {
                  if (n.hasAttribute && n.hasAttribute('data-pct')) applyPct(n);
                  if (n.querySelectorAll) scan(n);
                }
              });
            }
          }
        }).observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ['data-pct'] });
      })();
    </script>
</body>
</html>

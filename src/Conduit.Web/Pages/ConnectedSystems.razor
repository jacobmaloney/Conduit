    private async Task ConfirmQuickSync()
    {
        if (quickSyncFor is null) return;
        if (!quickSyncIncludeUser && !quickSyncIncludeGroup)
        {
            quickSyncError = "Pick at least one object class.";
            return;
        }

        // Phase 6 belt-and-suspenders: re-check the missing-fields gate at click
        // time too. Catches the case where the card was edited between modal
        // open and Confirm.
        var missing = GetMissingRequiredTenantFields(quickSyncFor);
        if (missing.Count > 0)
        {
            quickSyncError = $"{quickSyncFor.SystemType} requires {string.Join(", ", missing)} to be set on this Connected System before Quick Sync can run.";
            return;
        }

        quickSyncInProgress = true;
        quickSyncError = string.Empty;
        quickSyncStatus = string.Empty;
        StateHasChanged();

        try
        {
            var sourceTenantId = quickSyncFor.TenantId;
            var sourceName = quickSyncFor.Name;
            var cacheName = QuickSyncLocalCacheName(sourceName);
            var cacheSlug = Slugify(cacheName);

            // Idempotent emulator tenant: look up by slug, create if missing.
            var cacheTenant = await TenantRepo.GetBySlugAsync(cacheSlug);
            if (cacheTenant is null)
            {
                cacheTenant = await TenantRepo.CreateAsync(new Tenant
                {
                    Name = cacheName,
                    Slug = cacheSlug,
                    SystemType = "Emulator",
                    Description = $"Local browser cache auto-created by Quick Sync from '{sourceName}'.",
                    IsActive = true
                });
                quickSyncStatus = $"Created local cache tenant '{cacheName}'.";
            }
            else
            {
                quickSyncStatus = $"Reusing existing local cache tenant '{cacheName}'.";
            }
            StateHasChanged();

            // Object class names are lowercase native names ("user", "group") —
            // the orchestrator/workflow layer treats them as such everywhere.
            var classes = new List<string>();
            if (quickSyncIncludeUser) classes.Add("user");
            if (quickSyncIncludeGroup && QuickSyncSupportsGroup(quickSyncFor.SystemType)) classes.Add("group");

            var firstProjectId = Guid.Empty;
            var cron = string.IsNullOrWhiteSpace(quickSyncCronSchedule) ? null : quickSyncCronSchedule.Trim();
            // Phase 6: smart credential auto-pick. Use the picker's choice when
            // present; otherwise the single stored cred name when exactly one;
            // otherwise null so the adapter falls back to its default name.
            string? credForProject;
            if (quickSyncAvailableCredNames.Count > 1
                && !string.IsNullOrWhiteSpace(quickSyncSelectedCredName))
            {
                credForProject = quickSyncSelectedCredName.Trim();
            }
            else if (quickSyncAvailableCredNames.Count == 1)
            {
                credForProject = quickSyncAvailableCredNames[0];
            }
            else
            {
                credForProject = null;
            }
            foreach (var oc in classes)
            {
                var p = new Conduit.Core.SyncModels.SyncProject
                {
                    Name = $"Quick Sync: {sourceName} → {cacheName} ({oc})",
                    Description = $"Auto-generated by Quick Sync. Pulls {oc} objects from {sourceName} into the local browser cache.",
                    SourceTenantId = sourceTenantId,
                    SinkTenantId = cacheTenant.Id,
                    SourceCredentialName = credForProject,
                    ObjectClass = oc,
                    IsEnabled = true,
                    CronSchedule = cron
                };
                var saved = await ProjectRepo.CreateAsync(p);
                await ProjectRepo.UpsertScopeAsync(new Conduit.Core.SyncModels.SyncProjectScope { SyncProjectId = saved.Id, PageSize = 1000 });
                await ProjectRepo.ReplaceMappingsAsync(saved.Id, Array.Empty<Conduit.Core.SyncModels.AttributeMapping>());
                if (firstProjectId == Guid.Empty) firstProjectId = saved.Id;

                // Fire-and-forget Run Now — the History page will render the live
                // run. Fix 5: the background task must NOT use this circuit's
                // scoped orchestrator (we navigate away below and the circuit
                // scope — with its DB plumbing — can be torn down mid-run). Same
                // fresh-scope pattern as SyncProjects.RunNowConfirmed: resolve a
                // new orchestrator from a dedicated DI scope the task owns and
                // disposes itself. No pre-claim here: the project was created
                // milliseconds ago, so the orchestrator's own CAS is the guard.
                var quickSyncProjectId = saved.Id;
                _ = Task.Run(async () =>
                {
                    try
                    {
                        using var scope = ScopeFactory.CreateScope();
                        var orchestrator = scope.ServiceProvider.GetRequiredService<Conduit.Sync.Orchestration.SyncProjectOrchestrator>();
                        await orchestrator.ExecuteAsync(quickSyncProjectId, "QuickSync", CancellationToken.None);
                    }
                    catch (Exception ex)
                    {
                        // Page has navigated away — never touch circuit UI state here.
                        Logger.LogError(ex, "Quick Sync run failed for project {ProjectId}", quickSyncProjectId);
                    }
                });
            }

            await DataChange.NotifyAsync(DataChangeKind.Tenants);
            quickSyncFor = null;
            // Land the operator on the runs page watching the first project complete.
            if (firstProjectId != Guid.Empty)
            {
                Navigation.NavigateTo($"/sync-history?project={firstProjectId}");
            }
            else
            {
                Navigation.NavigateTo("/sync-history");
            }
        }
        catch (Exception ex)
        {
            quickSyncError = $"Quick Sync failed: {ex.Message}";
        }
        finally
        {
            quickSyncInProgress = false;
            StateHasChanged();
        }
    }


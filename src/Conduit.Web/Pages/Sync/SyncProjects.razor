    private async Task GenerateAutoSyncProject()
    {
        // Re-entrancy guard FIRST — set before any validation or await, exactly as IC
        // does (SystemCenter.CreateObjectSyncProjectFromWizard sets isCreatingProject
        // as its first statement). A fast double-click / Blazor double-dispatch can
        // enqueue two @onclick invocations before the DOM re-renders with the disabled
        // attribute; without raising the flag synchronously up front, both invocations
        // sail past and persist two projects (the second getting the "#2" dedup suffix).
        if (autoGenInProgress) return;
        autoGenInProgress = true;
        StateHasChanged();

        try
        {
            autoGenError = string.Empty;
            if (autoGenSourceId == Guid.Empty || autoGenSinkId == Guid.Empty)
            {
                autoGenError = "Both source and sink are required.";
                return;
            }

            if (AutoGenIsSelfSync)
            {
                autoGenError = "Source and target must be different connections.";
                return;
            }

            var src = allTenants.FirstOrDefault(t => t.Id == autoGenSourceId);
            var sink = allTenants.FirstOrDefault(t => t.Id == autoGenSinkId);
            if (src is null || sink is null)
            {
                autoGenError = "Selected systems no longer exist.";
                return;
            }

            // Effective name = the operator's edited value, trimmed; fall back to the
            // derived default if blank/whitespace so we never persist an empty name.
            var defaultName = $"{src.Name} to {sink.Name} ({ModeLabel(autoGenMode)})";
            var chosenName = string.IsNullOrWhiteSpace(autoGenProjectName)
                ? defaultName
                : autoGenProjectName.Trim();

            // Idempotency, defensively like IC: if a project already exists for this
            // exact source -> sink + CHOSEN name, do not create a second one. Guards the
            // residual double-fire window AND a deliberate re-click of an already-created
            // pair. A different name for the same pair is allowed. The generator's
            // UniqueName would otherwise silently mint a "#2" duplicate.
            var alreadyExists = allProjects.Any(p =>
                p.SourceTenantId == src.Id &&
                p.SinkTenantId == sink.Id &&
                string.Equals(p.Name, chosenName, StringComparison.OrdinalIgnoreCase));
            if (alreadyExists)
            {
                showAutoGenerateModal = false;
                toastSuccess = $"A sync project named '{chosenName}' already exists from {src.Name} to {sink.Name}.";
                return;
            }

            // The modal's live preview line already shows the operator the object-class
            // count + names for (source, mode) before they confirm. Build the whole
            // graph in memory via the Phase 3
            // generator, then persist project -> workflow -> step -> scope -> mappings
            // through the repositories. Only Mapping steps are emitted -- no governance.
            var existingNames = allProjects.Select(p => p.Name).ToList();
            var generated = ProjectGenerator.Generate(src, sink, autoGenMode, autoGenCronSchedule, existingNames);
            if (generated.Count == 0)
            {
                autoGenError = "This source connector + mode produced no object classes.";
                return;
            }

            // V22: stamp the per-endpoint IC table onto each generated project. Only
            // when that side is an IdentityCenter connector; otherwise leave null so
            // the column stays meaningless for non-IC connectors.
            var srcTable = AutoGenSourceIsIdentityCenter ? autoGenSourceTable : null;
            var sinkTable = AutoGenSinkIsIdentityCenter ? autoGenSinkTable : null;

            // V23: each generated graph is ONE project + ONE workflow + N Mapping
            // steps (one per object class). Persist project -> workflow -> each step
            // (+ its per-step scope + mappings). Today the generator yields a single
            // project, but we loop to stay forward-compatible.
            // IDENTITIES RULE: the generator is table-blind (shared IC-parity signature),
            // so when an IC/Identities endpoint is involved we drop every non-user step
            // here — Identities holds people only. Same single source of truth the modal
            // preview + cards already filter through (ApplyIdentitiesConstraint).
            var identitiesOnly = AutoGenIcIdentitiesInvolved;
            var totalSteps = 0;
            foreach (var g in generated)
            {
                g.Project.IsEnabled = autoGenEnable;
                g.Project.SourceTable = srcTable;
                g.Project.SinkTable = sinkTable;
                // Override the generator's derived name with the operator's chosen name.
                // Post-redesign the generator yields ONE project, so this names it; the
                // loop stays forward-compatible. Empty→default already resolved above.
                g.Project.Name = chosenName;
                if (identitiesOnly)
                {
                    g.Steps = g.Steps
                        .Where(s => string.IsNullOrWhiteSpace(s.Step.ObjectClass)
                                    || string.Equals(s.Step.ObjectClass, "user", StringComparison.OrdinalIgnoreCase))
                        .ToList();
                }
                await ProjectRepo.CreateAsync(g.Project);
                await WorkflowRepo.CreateAsync(g.Workflow);
                foreach (var st in g.Steps)
                {
                    await WorkflowRepo.CreateStepAsync(st.Step);
                    await WorkflowRepo.UpsertScopeForStepAsync(g.Project.Id, st.Step.Id, st.Scope);
                    if (st.Mappings.Count > 0)
                    {
                        await WorkflowRepo.ReplaceMappingsForStepAsync(g.Project.Id, st.Step.Id, st.Mappings);
                    }
                    totalSteps++;
                }
            }

            // Close the modal only AFTER the single successful persist.
            showAutoGenerateModal = false;
            toastSuccess = $"Auto-generated 1 sync project with {totalSteps} per-class step(s) ({ModeLabel(autoGenMode)}) from {src.Name} to {sink.Name}.";
            await Reload();
        }
        catch (Exception ex)
        {
            autoGenError = $"Auto-generate failed: {ex.Message}";
        }
        finally
        {
            autoGenInProgress = false;
        }
    }

    // ───────── Create-from-blueprint ─────────

    private void ShowBlueprintModal()
    {
        selectedBlueprint = null;
        blueprintSourceId = Guid.Empty;
        blueprintSinkId = Guid.Empty;
        blueprintCronSchedule = string.Empty;
        blueprintError = string.Empty;
        showBlueprintModal = true;
    }

    private void CloseBlueprintModal()
    {
        if (blueprintInProgress) return;
        showBlueprintModal = false;
    }

    private void SelectBlueprint(Conduit.Sync.Templates.SyncProjectBlueprint bp)
    {
        selectedBlueprint = bp;
        blueprintError = string.Empty;
        blueprintCronSchedule = bp.DefaultCronSchedule ?? string.Empty;

        // Pre-pick the obvious choices when there's exactly one candidate per side.
        var sources = BlueprintSourceTenants;
        blueprintSourceId = sources.Count == 1 ? sources[0].Id : Guid.Empty;
        var sinks = BlueprintSinkTenants;
        blueprintSinkId = sinks.Count == 1 ? sinks[0].Id : Guid.Empty;
    }

    private void ClearBlueprintSelection()
    {
        if (blueprintInProgress) return;
        selectedBlueprint = null;
        blueprintError = string.Empty;
    }

    private async Task CreateFromBlueprint()
    {
        // Re-entrancy guard FIRST — same discipline as GenerateAutoSyncProject.
        if (blueprintInProgress) return;
        blueprintInProgress = true;
        StateHasChanged();

        try
        {
            blueprintError = string.Empty;
            var bp = selectedBlueprint;
            if (bp is null)
            {
                blueprintError = "Pick a blueprint first.";
                return;
            }
            if (blueprintSourceId == Guid.Empty || blueprintSinkId == Guid.Empty)
            {
                blueprintError = "Both a source and an IdentityCenter target are required.";
                return;
            }
            if (blueprintSourceId == blueprintSinkId)
            {
                blueprintError = "Source and target must be different connections.";
                return;
            }

            var src = allTenants.FirstOrDefault(t => t.Id == blueprintSourceId);
            var sink = allTenants.FirstOrDefault(t => t.Id == blueprintSinkId);
            if (src is null || sink is null)
            {
                blueprintError = "Selected systems no longer exist.";
                return;
            }

            // Expand the blueprint to the SAME GeneratedSyncProject shape Auto-Generate
            // produces, reusing the matching ISyncProjectGenerator.Generate overload.
            var existingNames = allProjects.Select(p => p.Name).ToList();
            var generated = bp.Expand(ProjectGenerator, src, sink, blueprintCronSchedule, existingNames);
            if (generated.Count == 0)
            {
                blueprintError = "This blueprint produced no object classes for the chosen source.";
                return;
            }

            // V22: stamp the per-endpoint IC table. Sink is always IdentityCenter here.
            var sinkTable = string.Equals(sink.SystemType, "IdentityCenter", StringComparison.OrdinalIgnoreCase)
                ? "Objects"
                : null;

            // IDENTITIES RULE: same single source of truth — if the IC target lands in the
            // people-only Identities table, drop every non-user step. Sink table is Objects
            // here, so this is a no-op today, but routed through the same guard for safety.
            var identitiesOnly = IsIcIdentitiesTable(true, sinkTable);
            var totalSteps = 0;
            foreach (var g in generated)
            {
                g.Project.SinkTable = sinkTable;
                if (identitiesOnly)
                {
                    g.Steps = g.Steps
                        .Where(s => string.IsNullOrWhiteSpace(s.Step.ObjectClass)
                                    || string.Equals(s.Step.ObjectClass, "user", StringComparison.OrdinalIgnoreCase))
                        .ToList();
                }
                await ProjectRepo.CreateAsync(g.Project);
                await WorkflowRepo.CreateAsync(g.Workflow);
                foreach (var st in g.Steps)
                {
                    await WorkflowRepo.CreateStepAsync(st.Step);
                    await WorkflowRepo.UpsertScopeForStepAsync(g.Project.Id, st.Step.Id, st.Scope);
                    if (st.Mappings.Count > 0)
                    {
                        await WorkflowRepo.ReplaceMappingsForStepAsync(g.Project.Id, st.Step.Id, st.Mappings);
                    }
                    totalSteps++;
                }
            }

            showBlueprintModal = false;
            toastSuccess = $"Created '{bp.Name}' with {totalSteps} per-class step(s) from {src.Name} to {sink.Name}.";
            await Reload();
        }
        catch (Exception ex)
        {
            blueprintError = $"Create from blueprint failed: {ex.Message}";
        }
        finally
        {
            blueprintInProgress = false;
        }
    }
}

@page "/login"
@model Conduit.Web.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Sign in - Conduit</title>
    <base href="~/" />
    <link rel="icon" type="image/svg+xml" href="~/assets/brand/conduit-mark.svg" />
    <link rel="alternate icon" href="~/favicon.ico" />
    <meta name="theme-color" content="#22D3EE" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=Inter+Tight:wght@500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="css/open-iconic/font/css/open-iconic-bootstrap.min.css" />
    <link href="css/conduit.css" rel="stylesheet" />
</head>
<body>
    <div class="login-page">
        <div class="login-card">
            <div class="login-header">
                <div class="login-icon">
                    <svg width="40" height="36" viewBox="0 0 180 160" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                        <g stroke="#FFFFFF" stroke-width="6" fill="none" stroke-linecap="round">
                            <path d="M 14 40 L 60 78" />
                            <path d="M 14 80 L 60 80" />
                            <path d="M 14 120 L 60 82" />
                        </g>
                        <g fill="#FFFFFF" opacity=".55">
                            <circle cx="14" cy="40" r="9" />
                            <circle cx="14" cy="80" r="9" />
                            <circle cx="14" cy="120" r="9" />
                        </g>
                        <circle cx="78" cy="80" r="20" fill="none" stroke="#FFFFFF" stroke-width="6" />
                        <circle cx="78" cy="80" r="8" fill="#FFFFFF" />
                        <rect x="98" y="72" width="68" height="16" rx="8" fill="#FFFFFF" />
                        <polygon points="166,62 178,80 166,98" fill="#FFFFFF" />
                    </svg>
                </div>
                <h2>Conduit</h2>
                <p>Sign in to your account</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
            }
            @if (Model.SsoError)
            {
                @* Generic, non-enumerating message: never reveals whether the
                   federated identity exists, only that sign-in did not complete. *@
                <div class="alert alert-danger py-2">Single sign-on could not complete. Contact your administrator or sign in below.</div>
            }

            @if (Model.ExternalProviders.Count > 0)
            {
                <div class="text-center">
                    <p class="mb-3" style="color: var(--text-2);">Sign in with your organization account</p>
                    @foreach (var idp in Model.ExternalProviders)
                    {
                        <a class="login-external-btn"
                           href="@($"/login/sso?provider={Uri.EscapeDataString(idp.Name)}&returnUrl={Uri.EscapeDataString(Model.ReturnUrl ?? "/")}")">
                            <i class="oi oi-account-login"></i>Sign in with @idp.Name
                        </a>
                    }
                    <div class="login-divider">
                        <span>or sign in with a local account</span>
                    </div>
                </div>
            }

            <form method="post" class="login-form">
                <div class="form-floating">
                    <input type="text" class="form-control" id="Username" name="Username" value="@Model.Username" placeholder="Username" autofocus required />
                    <label for="Username">Username</label>
                </div>
                <div class="form-floating">
                    <input type="password" class="form-control" id="Password" name="Password" placeholder="Password" required />
                    <label for="Password">Password</label>
                </div>
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                <button type="submit" class="login-btn">Sign in</button>
            </form>
        </div>
    </div>
</body>
</html>

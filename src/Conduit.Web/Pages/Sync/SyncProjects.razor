    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    private async Task Reload()
    {
        try
        {
            allTenants = await TenantRepo.GetAllAsync(includeInactive: true);
            tenantById = allTenants.ToDictionary(t => t.Id);
            allProjects = await ProjectRepo.GetAllAsync();
            ApplyFilter();
            RecomputeStats();
            if (selectedProject is not null)
            {
                selectedProject = allProjects.FirstOrDefault(p => p.Id == selectedProject.Id);
                if (selectedProject is not null)
                {
                    await LoadSelectedProjectSteps();
                    await LoadRecentRuns();
                }
                else
                {
                    selectedProjectSteps = new();
                }
            }
        }
        catch (Exception ex)
        {
            toastError = $"Reload failed: {ex.Message}";
        }
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredProjects = allProjects;
            return;
        }
        var q = searchTerm.Trim();
        filteredProjects = allProjects
            .Where(p => (p.Name?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
                     || (p.Description?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();
    }

    private void RecomputeStats()
    {
        statRows = new[]
        {
            new CcStatRow.StatItem("Projects",  allProjects.Count.ToString("N0")),
            new CcStatRow.StatItem("Enabled",   allProjects.Count(p => p.IsEnabled).ToString("N0")),
            new CcStatRow.StatItem("Running",   allProjects.Count(p => p.IsRunning).ToString("N0"),  ValueColor: "text-info"),
            new CcStatRow.StatItem("Scheduled", allProjects.Count(p => !string.IsNullOrEmpty(p.CronSchedule)).ToString("N0"))
        };
    }

    private async Task HandleSearchChanged(string value)
    {
        searchTerm = value;
        ApplyFilter();
        await Task.CompletedTask;
    }


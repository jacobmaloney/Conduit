        return ProjectGenerator.GetObjectClasses(type, mode);
    }

    // A friendly, capped, comma-joined class list for a template card.
    private static string AutoGenClassListLabel(IReadOnlyList<string> classes)
    {
        if (classes.Count == 0)
        {
            return "No object classes";
        }
        const int cap = 6;
        if (classes.Count <= cap)
        {
            return string.Join(", ", classes);
        }
        var shown = string.Join(", ", classes.Take(cap));
        var remaining = classes.Count - cap;
        return string.Concat(shown, ", +", remaining.ToString(), " more");
    }


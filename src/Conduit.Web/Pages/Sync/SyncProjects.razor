    // ─────────────────────────────────────────────────────────────────────────
    // SINGLE SOURCE OF TRUTH: IdentityCenter "Identities" table = PEOPLE only.
    // The Objects table holds every AD object class (user/group/computer/contact/
    // OU/…); the Identities table holds only people, so the only object class you
    // can create or sync there is "user". Whenever EITHER project endpoint is an
    // IdentityCenter connector whose table = Identities, the class set collapses
    // to { user }. Every place that offers an object-class set (Auto-Generate
    // cards + preview, the manual multi-class grid, and the Workflows-tab add-all
    // + per-step Object Class select) routes its GetObjectClasses(...) result
    // through ApplyIdentitiesConstraint so the rule is enforced in ONE place.
    // ─────────────────────────────────────────────────────────────────────────
    private static readonly IReadOnlyList<string> IdentitiesOnlyClasses = new[] { "user" };

    /// <summary>True when a chosen IC endpoint's table is the people-only "Identities" table.</summary>
    private static bool IsIcIdentitiesTable(bool endpointIsIdentityCenter, string? table) =>
        endpointIsIdentityCenter
        && string.Equals(table, "Identities", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// THE table-aware filter. Given a source-derived class set and whether an
    /// IC/Identities endpoint is involved, returns the set unchanged for Objects
    /// (or non-IC) endpoints, or collapsed to { user } when Identities is in play.
    /// Intersects rather than blindly replaces, so a source that genuinely emits
    /// no users yields an empty set instead of a phantom user step.
    /// </summary>
    private static IReadOnlyList<string> ApplyIdentitiesConstraint(
        IReadOnlyList<string> classes, bool icIdentitiesEndpointInvolved)
    {
        if (!icIdentitiesEndpointInvolved) return classes;
        var filtered = classes
            .Where(c => string.Equals(c, "user", StringComparison.OrdinalIgnoreCase))
            .ToList();
        // The IC connector can always CREATE a user in Identities even if the
        // counterpart's catalog happens to omit it, so guarantee the people class.
        return filtered.Count > 0 ? filtered : IdentitiesOnlyClasses;
    }

    /// <summary>Wizard / Workflows-tab context: does the editing project's source OR sink land in IC Identities?</summary>
    private bool WizardIcIdentitiesInvolved =>
        IsIcIdentitiesTable(SourceIsIdentityCenter, form.SourceTable)
        || IsIcIdentitiesTable(SinkIsIdentityCenter, form.SinkTable);

    /// <summary>Auto-Generate-modal context: does the modal's source OR sink land in IC Identities?</summary>
    private bool AutoGenIcIdentitiesInvolved =>
        IsIcIdentitiesTable(AutoGenSourceIsIdentityCenter, autoGenSourceTable)
        || IsIcIdentitiesTable(AutoGenSinkIsIdentityCenter, autoGenSinkTable);

    /// <summary>Wizard / Workflows-tab class set: GetObjectClasses(source, mode) filtered by the Identities rule.</summary>
    private IReadOnlyList<string> WizardClassesForMode(Conduit.Sync.Templates.GenerationMode mode) =>
        ApplyIdentitiesConstraint(
            SourceSystemType.Length == 0
                ? Array.Empty<string>()
                : ProjectGenerator.GetObjectClasses(SourceSystemType, mode),
            WizardIcIdentitiesInvolved);

    /// <summary>Auto-Generate class set for a tier: GetObjectClasses(source, mode) filtered by the Identities rule.</summary>
    private IReadOnlyList<string> AutoGenConstrainedClassesForMode(Conduit.Sync.Templates.GenerationMode mode) =>
        ApplyIdentitiesConstraint(AutoGenClassesForMode(mode), AutoGenIcIdentitiesInvolved);

    private bool ShowAssignmentTemplatePanel =>
        SinkIsAwsSso
        && string.Equals(form.ObjectClass, "Assignment", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Phase 5. "Constant mode" lower: rewrite mappingForm so the orchestrator
    /// stamps the three constant attributes via the transform DSL's `default:`
    /// op + leaves principalId as a source-attribute passthrough. No schema
    /// change; the existing AttributeTransformer interprets these at sync time.
    /// </summary>
    private void ApplyAssignmentTemplate()
    {
        assignTemplateMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(assignAccountId)
            || string.IsNullOrWhiteSpace(assignPermissionSetArn)
            || string.IsNullOrWhiteSpace(assignPrincipalIdSource))
        {
            formError = "Assignment template requires accountId, permissionSetArn, and principalId source attribute.";
            return;
        }

        // Replace any existing assignment-attribute rows so a second Apply
        // doesn't dogpile duplicates. We only strip the three keys we own.
        var keep = mappingForm
            .Where(m => !IsAssignmentAttr(m.SinkAttribute))
            .ToList();

        var nextOrder = keep.Count;
        keep.Add(new AttributeMapping
        {
            Id = Guid.NewGuid(),
            SortOrder = nextOrder++,
            SourceAttribute = string.Empty,
            SinkAttribute = "accountId",
            TransformExpr = $"default:{assignAccountId.Trim()}",
            IsRequired = true
        });
        keep.Add(new AttributeMapping
        {
            Id = Guid.NewGuid(),
            SortOrder = nextOrder++,
            SourceAttribute = string.Empty,
            SinkAttribute = "permissionSetArn",
            TransformExpr = $"default:{assignPermissionSetArn.Trim()}",
            IsRequired = true
        });
        keep.Add(new AttributeMapping
        {
            Id = Guid.NewGuid(),
            SortOrder = nextOrder++,
            SourceAttribute = string.Empty,
            SinkAttribute = "principalType",
            TransformExpr = $"default:{assignPrincipalType}",
            IsRequired = false
        });
        keep.Add(new AttributeMapping
        {
            Id = Guid.NewGuid(),
            SortOrder = nextOrder++,
            SourceAttribute = assignPrincipalIdSource.Trim(),
            SinkAttribute = "principalId",
            TransformExpr = string.Empty,
            IsRequired = true
        });

        mappingForm = keep;
        formError = string.Empty;
        assignTemplateMessage = "Template applied. Review the four assignment rows below before saving.";
    }

    private static bool IsAssignmentAttr(string? sink) =>
        !string.IsNullOrEmpty(sink) && (
            sink.Equals("accountId", StringComparison.OrdinalIgnoreCase)
            || sink.Equals("permissionSetArn", StringComparison.OrdinalIgnoreCase)
            || sink.Equals("principalType", StringComparison.OrdinalIgnoreCase)
            || sink.Equals("principalId", StringComparison.OrdinalIgnoreCase));


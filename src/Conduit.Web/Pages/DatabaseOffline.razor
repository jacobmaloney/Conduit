@page "/db-offline"
@using Conduit.Web.Services
@inject SetupService SetupService
@inject NavigationManager Navigation
@layout SetupLayout

@*
    Database Offline page.

    Shown by SetupMiddleware when the configured database is UNREACHABLE (host down /
    connection cannot be opened) — as opposed to "reachable but not yet set up", which
    routes to /setup. This page must NEVER be the setup wizard: a transient network blip
    must not expose first-run setup.

    Anonymous by design (you can't authenticate without a database anyway) and uses the
    same SetupLayout chrome as the wizard. A <meta http-equiv="refresh"> drives automatic
    recovery: once the host returns, the next request re-probes (the SetupService status
    cache TTL has long since expired) and the middleware lets the operator straight through
    to the app or the wizard, as appropriate — no manual reload required.
*@

<HeadContent>
    <meta http-equiv="refresh" content="10" />
</HeadContent>

<div class="offline-shell">
    <div class="offline-card">
        <div class="offline-mark">
            <ConduitMark Size="64" Color="var(--accent)" HubFill="var(--bg-2)" />
        </div>

        <div class="offline-badge">
            <span class="offline-dot"></span>
            Database offline
        </div>

        <h1 class="offline-title">Waiting for the database</h1>

        <p class="offline-lead">
            Conduit can't reach its database@(string.IsNullOrEmpty(_server) ? "" : _serverPhrase) right now.
            This usually means the database server is temporarily down or unreachable on the network.
        </p>

        <p class="offline-sub">
            Nothing is lost. Conduit is retrying automatically and will recover on its own as soon
            as the database is back online &mdash; you don't need to do anything.
        </p>

        <div class="offline-retry">
            <span class="offline-spinner"></span>
            <span>Retrying&hellip; this page refreshes every 10&nbsp;seconds.</span>
        </div>

        <a class="offline-manual" href="/db-offline">Check again now</a>
    </div>
</div>

<style>
    .offline-shell {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px;
        background: var(--bg, #0A1322);
    }

    .offline-card {
        width: 100%;
        max-width: 480px;
        background: var(--bg-2, #0E1A2D);
        border: 1px solid rgba(157, 176, 204, 0.14);
        border-radius: 16px;
        padding: 40px 36px;
        text-align: center;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    }

    .offline-mark { margin-bottom: 20px; }

    .offline-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 5px 12px;
        border-radius: 999px;
        background: rgba(245, 158, 11, 0.12);
        border: 1px solid rgba(245, 158, 11, 0.35);
        color: var(--warn, #F59E0B);
        font-size: 12.5px;
        font-weight: 600;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        margin-bottom: 22px;
    }

    .offline-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--warn, #F59E0B);
        box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.5);
        animation: offline-pulse 1.6s infinite;
    }

    @@keyframes offline-pulse {
        0%   { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.5); }
        70%  { box-shadow: 0 0 0 8px rgba(245, 158, 11, 0); }
        100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); }
    }

    .offline-title {
        color: var(--text, #E4EDFB);
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 14px;
    }

    .offline-lead {
        color: var(--text-2, #9DB0CC);
        font-size: 15px;
        line-height: 1.6;
        margin: 0 0 12px;
    }

    .offline-sub {
        color: var(--text-3, #6B809E);
        font-size: 13.5px;
        line-height: 1.6;
        margin: 0 0 24px;
    }

    .offline-retry {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        color: var(--text-2, #9DB0CC);
        font-size: 13px;
        margin-bottom: 18px;
    }

    .offline-spinner {
        width: 15px;
        height: 15px;
        border-radius: 50%;
        border: 2px solid rgba(34, 211, 238, 0.25);
        border-top-color: var(--accent, #22D3EE);
        animation: offline-spin 0.8s linear infinite;
    }

    @@keyframes offline-spin {
        to { transform: rotate(360deg); }
    }

    .offline-manual {
        display: inline-block;
        color: var(--accent, #22D3EE);
        font-size: 13px;
        font-weight: 600;
    }
</style>

@code {
    private string _server = string.Empty;
    private string _serverPhrase = string.Empty;

    protected override void OnInitialized()
    {
        _server = SetupService.GetConfiguredServerName();
        if (!string.IsNullOrEmpty(_server))
        {
            _serverPhrase = " at " + _server;
        }
    }
}

@if (credentialsFor is not null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Credentials & test — @credentialsFor.Name</h5>
                    <button class="btn-close" @onclick="CloseCredentialsModal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">
                        Credentials are stored as AES-GCM ciphertext, keyed by a credential
                        name. A single tenant can hold multiple credentials (e.g. read-only
                        + read-write, or IAM + Identity Center) — pick the name in a Sync
                        Project to choose which one a run uses.
                    </p>
                    @if (storedCredentialNames.Count > 0)
                    {
                        <div class="mb-3">
                            <label class="form-label">Existing credentials</label>
                            <div>
                                @foreach (var name in storedCredentialNames)
                                {
                                    <span class="badge bg-secondary me-2">@name</span>
                                }
                            </div>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Credential name</label>
                        <input class="form-control" @bind="credForm.CredentialName"
                               placeholder="@CredentialNameFor(credentialsFor.SystemType)" />
                        <small class="text-muted">
                            Default = <code>@CredentialNameFor(credentialsFor.SystemType)</code>.
                            Override to store a second credential under a different name.
                        </small>
                    </div>
                    @* Phase 3: prefer the generic renderer when the adapter declares CredentialTypes.
                       Falls through to the legacy per-type @@switch when not. Eventually every connector
                       declares its types and the switch can be deleted. *@
                    @{
                        var adapterForRender = ConnectorRegistry.Get(credentialsFor.SystemType);
                        var credTypes = adapterForRender?.CredentialTypes;
                        var useGenericRenderer = credTypes is { Count: > 0 };
                    }
                    @if (useGenericRenderer)
                    {
                        @* Single-type adapters render directly; multi-type adapters (e.g. AWS later) would pick first. *@
                        var type = credTypes![0];
                        @foreach (var field in type.Fields)
                        {
                            <div class="@(field.IsBoolean ? "form-check mb-3" : "mb-3")">
                                @if (field.IsBoolean)
                                {
                                    <input class="form-check-input" type="checkbox" id="@($"cf_{field.Key}")"
                                           checked="@GetGenericBool(field.Key, field.DefaultValue == "true")"
                                           @onchange="e => SetGenericBool(field.Key, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label" for="@($"cf_{field.Key}")">@field.Label</label>
                                }
                                else
                                {
                                    <label class="form-label">@field.Label@(field.IsRequired ? " *" : string.Empty)</label>
                                    @if (field.IsMultiline)
                                    {
                                        <textarea class="form-control" rows="6"
                                                  placeholder="@field.Placeholder"
                                                  value="@GetGenericString(field.Key, field.DefaultValue ?? string.Empty)"
                                                  @oninput="e => SetGenericString(field.Key, e.Value?.ToString() ?? string.Empty)"></textarea>
                                    }
                                    else
                                    {
                                        <input class="form-control"
                                               type="@(field.IsSecret ? "password" : "text")"
                                               autocomplete="@(field.IsSecret ? "new-password" : "off")"
                                               placeholder="@field.Placeholder"
                                               value="@GetGenericString(field.Key, field.DefaultValue ?? string.Empty)"
                                               @oninput="e => SetGenericString(field.Key, e.Value?.ToString() ?? string.Empty)" />
                                    }
                                    @if (!string.IsNullOrEmpty(field.Help))
                                    {
                                        <small class="text-muted">@field.Help</small>
                                    }
                                }
                            </div>
                        }
                    }
                    else
                    {
                    @* Legacy hardcoded path — kept for adapters that haven't declared CredentialTypes yet. *@
                    @switch (credentialsFor.SystemType)
                    {
                        case "ActiveDirectory":
                        case "Real":
                            <div class="mb-3">
                                <label class="form-label">Username</label>
                                <input class="form-control" @bind="credForm.Username" placeholder="DEMO\sync-svc" autocomplete="off" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input class="form-control" type="password" @bind="credForm.Password" autocomplete="new-password" />
                            </div>
                            break;
                        case "EntraID":
                        case "SharePoint":
                            <div class="mb-3">
                                <label class="form-label">Tenant ID</label>
                                <input class="form-control" @bind="credForm.TenantId" placeholder="00000000-0000-0000-0000-000000000000" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Client ID (Application ID)</label>
                                <input class="form-control" @bind="credForm.ClientId" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Client Secret</label>
                                <input class="form-control" type="password" @bind="credForm.ClientSecret" autocomplete="new-password" />
                            </div>
                            break;
                        case "Okta":
                            <div class="mb-3">
                                <label class="form-label">Org URL</label>
                                <input class="form-control" @bind="credForm.OrgUrl" placeholder="https://your-org.okta.com" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">API Token (SSWS)</label>
                                <input class="form-control" type="password" @bind="credForm.ApiToken" autocomplete="new-password" />
                            </div>
                            break;
                        case "GoogleWorkspace":
                            <div class="mb-3">
                                <label class="form-label">Service Account JSON</label>
                                <textarea class="form-control" rows="6" @bind="credForm.ServiceAccountJson" placeholder='{"type":"service_account",...}'></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Admin Email (impersonation target)</label>
                                <input class="form-control" @bind="credForm.AdminEmail" placeholder="admin@your-domain.com" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Domain (optional, leave blank for my_customer)</label>
                                <input class="form-control" @bind="credForm.Domain" />
                            </div>
                            break;
                        case "GenericLdap":
                            <div class="mb-3">
                                <label class="form-label">Server URL</label>
                                <input class="form-control" @bind="credForm.ServerUrl" placeholder="ldap://host:389 or ldaps://host:636" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Bind DN</label>
                                <input class="form-control" @bind="credForm.BindDN" placeholder="cn=admin,dc=example,dc=org" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Bind Password</label>
                                <input class="form-control" type="password" @bind="credForm.BindPassword" autocomplete="new-password" />
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="useTls" @bind="credForm.UseTls" />
                                <label class="form-check-label" for="useTls">Use StartTLS</label>
                            </div>
                            break;
                        case "Scim":
                            <div class="mb-3">
                                <label class="form-label">Base URL</label>
                                <input class="form-control" @bind="credForm.BaseUrl" placeholder="https://target.example.com/scim/v2" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Bearer Token</label>
                                <input class="form-control" type="password" @bind="credForm.BearerToken" autocomplete="new-password" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">User Endpoint (default <code>/Users</code>)</label>
                                <input class="form-control" @bind="credForm.UserEndpoint" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Group Endpoint (default <code>/Groups</code>)</label>
                                <input class="form-control" @bind="credForm.GroupEndpoint" />
                            </div>
                            break;
                        case "Database":
                            <div class="mb-3">
                                <label class="form-label">Connection String</label>
                                <input class="form-control" type="password" @bind="credForm.ConnectionString" autocomplete="new-password" placeholder="Server=...;Database=...;User Id=...;Password=...;Encrypt=true;" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">User Query (SELECT, must yield objectGuid)</label>
                                <textarea class="form-control" rows="3" @bind="credForm.UserQuery"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Group Query (optional)</label>
                                <textarea class="form-control" rows="2" @bind="credForm.GroupQuery"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Upsert User Statement (optional — sink)</label>
                                <textarea class="form-control" rows="2" @bind="credForm.UpsertUserStatement" placeholder="MERGE / INSERT / UPDATE with @@objectGuid, @@userName, ..."></textarea>
                            </div>
                            break;
                        case "CSV":
                            <div class="mb-3">
                                <label class="form-label">File Path</label>
                                <input class="form-control" @bind="credForm.FilePath" placeholder="C:\path\to\users.csv" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Delimiter</label>
                                <input class="form-control" @bind="credForm.Delimiter" placeholder="," />
                            </div>
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="hasHeader" @bind="credForm.HasHeader" />
                                <label class="form-check-label" for="hasHeader">First row is header</label>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">ID Column (column to use as objectGuid)</label>
                                <input class="form-control" @bind="credForm.IdColumn" placeholder="EmployeeId" />
                            </div>
                            break;
                        case "AWS":
                            <div class="mb-3">
                                <label class="form-label">Access Key ID</label>
                                <input class="form-control" @bind="credForm.AccessKeyId" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Secret Access Key</label>
                                <input class="form-control" type="password" @bind="credForm.SecretAccessKey" autocomplete="new-password" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Region</label>
                                <input class="form-control" @bind="credForm.Region" placeholder="us-east-1" />
                            </div>
                            break;
                        case "AWSIdentityCenter":
                            <div class="mb-3">
                                <label class="form-label">Access Key ID</label>
                                <input class="form-control" @bind="credForm.AccessKeyId" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Secret Access Key</label>
                                <input class="form-control" type="password" @bind="credForm.SecretAccessKey" autocomplete="new-password" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Region</label>
                                <input class="form-control" @bind="credForm.Region" placeholder="us-east-1" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Identity Store ID <span class="text-muted">(auto-discover if blank)</span></label>
                                <input class="form-control" @bind="credForm.IdentityStoreId" placeholder="d-xxxxxxxxxx" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">SSO Instance ARN <span class="text-muted">(auto-discover if blank)</span></label>
                                <input class="form-control" @bind="credForm.SSOInstanceArn" placeholder="arn:aws:sso:::instance/ssoins-..." />
                            </div>
                            break;
                        case "IdentityCenter":
                            <div class="mb-3">
                                <label class="form-label">Base URL</label>
                                <input class="form-control" @bind="credForm.BaseUrl" placeholder="https://identitycenter.local:7048" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">API Key (X-API-Key, admin scope)</label>
                                <input class="form-control" type="password" @bind="credForm.ApiKey" autocomplete="new-password" />
                            </div>
                            break;
                        default:
                            <div class="alert alert-warning">No credential fields configured for system type <code>@credentialsFor.SystemType</code>.</div>
                            break;
                    }
                    }
                    @if (!string.IsNullOrEmpty(credSaveMessage))
                    {
                        <div class="alert alert-success py-2">@credSaveMessage</div>
                    }
                    @if (!string.IsNullOrEmpty(credTestMessage))
                    {
                        <div class="alert @(credTestSuccess ? "alert-success" : "alert-danger") py-2">@credTestMessage</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-primary" @onclick="TestCredentialsAsync" disabled="@credBusy">
                        @if (credBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Save & Test
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseCredentialsModal" disabled="@credBusy">Close</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@* ─── Quick Sync modal ──────────────────────────────────────────────────
   Connector-tenant operator wants to "just see what's in this system" without
   wiring an explicit sink. We auto-mint (or reuse) a local Emulator tenant
   named "<source> Local Cache" and create one sync project per checked object
   class with passthrough mapping, then kick off Run Now.
   (SCIM-server chrome — dev-only.) *@
@if (ShowDevChrome && quickSyncFor is not null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        Sync @quickSyncFor.Name into a local browser
                    </h5>
                    <button class="btn-close" @onclick="CloseQuickSyncModal" disabled="@quickSyncInProgress"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">
                        Creates a local Emulator tenant called
                        <code>@QuickSyncLocalCacheName(quickSyncFor.Name)</code>,
                        wires sync projects from <strong>@quickSyncFor.Name</strong> into it
                        with passthrough mappings, and runs them now. Use this when you want
                        to browse what's in this connector without configuring a separate
                        destination. Re-running is safe — the local tenant is reused if it
                        already exists.
                    </p>

                    <div class="section-eyebrow">Object classes</div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="qsClassUser"
                               @bind="quickSyncIncludeUser" />
                        <label class="form-check-label" for="qsClassUser">User</label>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="qsClassGroup"
                               @bind="quickSyncIncludeGroup"
                               disabled="@(!QuickSyncSupportsGroup(quickSyncFor.SystemType))" />
                        <label class="form-check-label" for="qsClassGroup">
                            Group
                            @if (!QuickSyncSupportsGroup(quickSyncFor.SystemType))
                            {
                                <span class="text-muted">(not available for @quickSyncFor.SystemType)</span>
                            }
                        </label>
                    </div>

                    @if (quickSyncAvailableCredNames.Count > 1)
                    {
                        <div class="section-eyebrow">Credential</div>
                        <div class="mb-3">
                            <label class="form-label">Pick a stored credential</label>
                            <select class="form-select" @bind="quickSyncSelectedCredName">
                                @foreach (var n in quickSyncAvailableCredNames)
                                {
                                    <option value="@n">@n</option>
                                }
                            </select>
                            <small class="text-muted">This tenant has more than one stored credential. The picked one will be set as the source credential on the new sync projects.</small>
                        </div>
                    }
                    else if (quickSyncAvailableCredNames.Count == 1
                             && !string.Equals(quickSyncAvailableCredNames[0],
                                               CredentialNameFor(quickSyncFor.SystemType),
                                               StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="alert alert-info py-2 mb-3">
                            Using stored credential <code>@quickSyncAvailableCredNames[0]</code>.
                        </div>
                    }

                    <div class="section-eyebrow">Schedule</div>
                    <div class="mb-3">
                        <label class="form-label">Cron preset</label>
                        <select class="form-select" @bind="quickSyncCronPreset" @bind:after="ApplyQuickSyncPreset">
                            <option value="">Manual only (run on demand)</option>
                            <option value="@("@hourly")">Hourly</option>
                            <option value="0 */4 * * *">Every 4 hours</option>
                            <option value="0 2 * * *">Daily at 02:00 UTC</option>
                            <option value="*/15 * * * *">Every 15 minutes</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cron expression</label>
                        <input class="form-control" @bind="quickSyncCronSchedule"
                               placeholder="Leave blank for manual-only" />
                        <small class="text-muted">5-field cron or <code>@@hourly</code> / <code>@@every:Nm</code>.</small>
                    </div>

                    @if (!string.IsNullOrEmpty(quickSyncError))
                    {
                        <div class="alert alert-danger py-2 mb-0">@quickSyncError</div>
                    }
                    @if (!string.IsNullOrEmpty(quickSyncStatus))
                    {
                        <div class="alert alert-info py-2 mb-0">@quickSyncStatus</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseQuickSyncModal" disabled="@quickSyncInProgress">Cancel</button>
                    <button class="btn btn-primary" @onclick="ConfirmQuickSync"
                            disabled="@(quickSyncInProgress || (!quickSyncIncludeUser && !quickSyncIncludeGroup))">
                        @if (quickSyncInProgress)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Setting up…</span>
                        }
                        else
                        {
                            <i class="oi oi-data-transfer-download"></i>
                            <span class="ms-1">Create + Run Now</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<TenantStats> stats = new();
    private bool loading = true;
    private bool showModal;
    private bool saving;
    private bool seeding;
    private Guid? editingId;
    private Tenant form = new();

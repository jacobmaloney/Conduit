    private async Task AutoMapAttributes()
    {
        var sourceType = tenantById.TryGetValue(form.SourceTenantId, out var src) ? src.SystemType : string.Empty;
        var sinkType = tenantById.TryGetValue(form.SinkTenantId, out var snk) ? snk.SystemType : string.Empty;

        if (string.IsNullOrWhiteSpace(sourceType))
        {
            await JS.InvokeVoidAsync("alert", "Pick a source Connected System on the Setup tab first.");
            return;
        }

        var suggested = AttributeMapper.BuildMappings(sourceType, sinkType, form.ObjectClass);
        if (suggested.Count == 0)
        {
            var msg = string.Concat("No attribute template available for ", sourceType, " ", form.ObjectClass, ".");
            await JS.InvokeVoidAsync("alert", msg);
            return;
        }

        var hasEdits = mappingForm.Any(m =>
            !string.IsNullOrWhiteSpace(m.SourceAttribute) || !string.IsNullOrWhiteSpace(m.SinkAttribute));

        var replace = !hasEdits;
        if (hasEdits)
        {
            replace = await JS.InvokeAsync<bool>("confirm",
                "Replace the existing mappings with the auto-mapped set? Choose Cancel to append only new (non-duplicate) rows instead.");
        }

        if (replace)
        {
            mappingForm = suggested;
        }
        else
        {
            var existing = new HashSet<string>(
                mappingForm.Select(m => string.Concat(m.SourceAttribute, "", m.SinkAttribute)),
                StringComparer.OrdinalIgnoreCase);
            var next = mappingForm.Count;
            foreach (var m in suggested)
            {
                var key = string.Concat(m.SourceAttribute, "", m.SinkAttribute);
                if (existing.Add(key))
                {
                    m.SortOrder = next++;
                    mappingForm.Add(m);
                }
            }
        }
    }


    // ─── Run-now modal ──────────────────────────────────────────────────────

    private void ShowRunConfirmModal()
    {
        if (selectedProject is null || !selectedProject.IsEnabled || selectedProject.IsRunning) return;
        showRunConfirmModal = true;
    }

    private void CloseRunConfirmModal()
    {
        if (runNowInProgress) return;

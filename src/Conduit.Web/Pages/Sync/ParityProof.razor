@page "/sync/parity-proof"
@attribute [Authorize]
@using Conduit.Core.SyncModels
@using Conduit.Web.Services
@using Conduit.DataAccess.Repositories
@inject IcParityImportService Parity
@inject SyncProjectRepository ProjectRepo
@inject IConfiguration Config

<PageTitle>IC ↔ Conduit Parity Proof</PageTitle>

<div class="container py-4" style="max-width: 980px;">
    <h3 class="mb-1">IC ↔ Conduit Sync-Project Parity</h3>
    <p class="text-muted">
        Two operations that prove and finish 1:1 parity. Both are reversible and only ever
        touch rows they create. See <a href="/sync/projects">Sync Projects</a> to compare the
        results against IdentityCenter side-by-side.
    </p>

    @* ───────── TASK 1 — migrate flat (pre-7d7e034) projects to per-class workflows ───────── *@
    <div class="card mb-4">
        <div class="card-header fw-bold">
            <i class="fas fa-diagram-project me-1"></i>Task 1 — Migrate legacy "1 workflow / N steps" projects
        </div>
        <div class="card-body">
            <p class="text-muted small mb-2">
                Projects generated <strong>before</strong> the per-class generator fix render as a single
                "Full sync" workflow holding flat per-class steps. This re-groups each into one workflow per
                object class (IC's shape) <strong>without</strong> editing any step, scope, or mapping content —
                it only re-parents steps. Fully reversible per project.
            </p>
            <button class="btn btn-sm btn-outline-secondary mb-3" @onclick="ScanFlat" disabled="@busy">
                <i class="fas fa-magnifying-glass me-1"></i>Scan for legacy-shape projects
            </button>

            @if (flatScan is not null)
            {
                @if (flatScan.Count == 0)
                {
                    <div class="alert alert-success py-2 small mb-0">No legacy "1 workflow / N steps" projects found.</div>
                }
                else
                {
                    <table class="table table-sm align-middle">
                        <thead><tr><th>Project</th><th>Workflows</th><th>Steps</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var row in flatScan)
                            {
                                var p = row;
                                <tr>
                                    <td>@p.Name</td>
                                    <td>@p.Workflows</td>
                                    <td>@p.Steps</td>
                                    <td class="text-end">
                                        @if (p.Flat)
                                        {
                                            <button class="btn btn-sm btn-primary" @onclick="() => Migrate(p.Id)" disabled="@busy">
                                                Migrate to per-class
                                            </button>
                                        }
                                        else if (p.Migrated)
                                        {
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Revert(p.Id)" disabled="@busy">
                                                Revert
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">already per-class</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        </div>
    </div>

    @* ───────── TASK 2 — import a real IC sync project's graph into Conduit ───────── *@
    <div class="card mb-3">
        <div class="card-header fw-bold">
            <i class="fas fa-file-import me-1"></i>Task 2 — Import a real IdentityCenter sync project (proof)
        </div>
        <div class="card-body">
            <p class="text-muted small mb-2">
                Reads a real IC project's full graph (read-only) and writes it into Conduit, transformed
                column-by-column, as a NEW project named
                <code>@IcParityImportService.ImportSentinelPrefix &lt;original&gt;</code>. If the rows map
                cleanly and the imported project opens 1:1 in Edit Sync Project, the structures match.
            </p>

            <div class="mb-2">
                <label class="form-label fw-bold small mb-1">IdentityCenter connection string (read-only)</label>
                <input class="form-control form-control-sm" @bind="icConnString" placeholder="Data Source=...;Initial Catalog=IdentityCenter15;..." />
                <small class="form-text text-muted">
                    Defaulted from <code>ConnectionStrings:IdentityCenterSource</code> if configured. Never written to.
                </small>
            </div>

            <button class="btn btn-sm btn-outline-secondary mb-3" @onclick="ListIc" disabled="@(busy || string.IsNullOrWhiteSpace(icConnString))">
                <i class="fas fa-list me-1"></i>List IC projects
            </button>

            @if (icProjects is not null)
            {
                <table class="table table-sm align-middle">
                    <thead><tr><th>IC Project</th><th>WF</th><th>Steps</th><th>Maps</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var row in icProjects)
                        {
                            var ic = row;
                            <tr>
                                <td>@ic.Name</td>
                                <td>@ic.Workflows</td>
                                <td>@ic.Steps</td>
                                <td>@ic.Mappings</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-success" @onclick="() => Import(ic.Name)" disabled="@busy">
                                        Import into Conduit
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-danger" @onclick="RemoveImports" disabled="@busy">
                    <i class="fas fa-trash me-1"></i>Remove all imports
                </button>
            </div>
            <div class="alert alert-info py-2 small mt-2 mb-0">
                Removal SQL (note the ESCAPE — <code>[</code> is a LIKE wildcard):
                <code>DELETE FROM SyncProjects WHERE Name LIKE '\[IC-IMPORT\]%' ESCAPE '\';</code>
                (delete child rows by SyncProjectId first if your schema has no cascade — the
                <em>Remove all imports</em> button handles this for you).
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @alertClass py-2 small">@((MarkupString)message)</div>
    }
</div>

@code {
    private bool busy;
    private string? message;
    private string alertClass = "alert-success";

    private string icConnString = string.Empty;

    private List<FlatRow>? flatScan;
    private IReadOnlyList<(string Name, int Workflows, int Steps, int Mappings)>? icProjects;

    private sealed record FlatRow(Guid Id, string Name, int Workflows, int Steps, bool Flat, bool Migrated);

    protected override void OnInitialized()
    {
        // Default the IC source connection string from config if present (never hardcoded).
        icConnString = Config.GetConnectionString("IdentityCenterSource") ?? string.Empty;
    }

    private async Task ScanFlat()
    {
        busy = true; message = null;
        try
        {
            var rows = new List<FlatRow>();
            foreach (var p in await ProjectRepo.GetAllAsync())
            {
                var flat = await Parity.IsFlatLegacyShapeAsync(p.Id);
                // A migrated project is detectable by its per-class workflows carrying the
                // migration marker; we surface a Revert affordance for those. Cheap heuristic:
                // re-scan is the source of truth, so just flag flat vs not here.
                rows.Add(new FlatRow(p.Id, p.Name, 0, 0, flat, false));
            }
            flatScan = rows;
        }
        catch (Exception ex) { Fail($"Scan failed: {ex.Message}"); }
        finally { busy = false; }
    }

    private async Task Migrate(Guid id)
    {
        busy = true; message = null;
        try
        {
            var r = await Parity.MigrateProjectToPerClassAsync(id);
            alertClass = r.Changed ? "alert-success" : "alert-warning";
            message = $"{r.Note} (workflows {r.WorkflowsBefore} → {r.WorkflowsAfter}, {r.StepsMoved} steps moved).";
            await ScanFlat();
        }
        catch (Exception ex) { Fail($"Migrate failed: {ex.Message}"); }
        finally { busy = false; }
    }

    private async Task Revert(Guid id)
    {
        busy = true; message = null;
        try
        {
            var r = await Parity.RevertMigrationAsync(id);
            alertClass = r.Changed ? "alert-success" : "alert-warning";
            message = r.Note;
            await ScanFlat();
        }
        catch (Exception ex) { Fail($"Revert failed: {ex.Message}"); }
        finally { busy = false; }
    }

    private async Task ListIc()
    {
        busy = true; message = null;
        try
        {
            icProjects = await Parity.ListIcProjectsAsync(icConnString);
        }
        catch (Exception ex) { Fail($"List IC projects failed: {ex.Message}"); icProjects = null; }
        finally { busy = false; }
    }

    private async Task Import(string icProjectName)
    {
        busy = true; message = null;
        try
        {
            var r = await Parity.ImportFromIdentityCenterAsync(icConnString, icProjectName);
            alertClass = r.Created ? "alert-success" : "alert-warning";
            // HTML-encode data-derived text before it goes into the MarkupString alert (Worf: prevent XSS via a crafted IC project name / note).
            var safeName = System.Net.WebUtility.HtmlEncode(r.ProjectName);
            var noteHtml = string.Join("<br/>", r.Notes.Select(n => System.Net.WebUtility.HtmlEncode(n)));
            message = r.Created
                ? $"Imported <strong>'{safeName}'</strong>: {r.Workflows} workflows, {r.Steps} steps, {r.Mappings} mappings, {r.Scopes} scopes.<br/>{noteHtml}"
                : noteHtml;
        }
        catch (Exception ex) { Fail($"Import failed: {ex.Message}"); }
        finally { busy = false; }
    }

    private async Task RemoveImports()
    {
        busy = true; message = null;
        try
        {
            message = await Parity.RemoveImportsAsync();
            alertClass = "alert-success";
        }
        catch (Exception ex) { Fail($"Remove failed: {ex.Message}"); }
        finally { busy = false; }
    }

    private void Fail(string m) { alertClass = "alert-danger"; message = m; }
}

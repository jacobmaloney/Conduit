@*
    CcConfirmationModal — awaitable Bootstrap-styled confirm dialog.

    Usage:
      <CcConfirmationModal @ref="_confirm" />
      ...
      var ok = await _confirm.ShowAsync("Delete user", "Are you sure?", "This cannot be undone.");
      if (ok) { ... }
*@

@implements IDisposable

@if (IsVisible)
{
    <div class="modal-backdrop fade show" @onclick="Cancel"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    <button type="button" class="btn-close" @onclick="Cancel" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(Message1))
                    {
                        <p>@Message1</p>
                    }
                    @if (!string.IsNullOrEmpty(Message2))
                    {
                        <p>@Message2</p>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="Cancel">
                        <i class="bi bi-x-circle me-1"></i>@CancelLabel
                    </button>
                    <button type="button" class="btn @ConfirmButtonClass" @onclick="Confirm">
                        <i class="bi bi-check-circle me-1"></i>@ConfirmLabel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ConfirmLabel { get; set; } = "Confirm";
    [Parameter] public string CancelLabel { get; set; } = "Cancel";

    /// <summary>Bootstrap button class for the confirm button. Defaults to "btn-danger".</summary>
    [Parameter] public string ConfirmButtonClass { get; set; } = "btn-danger";

    private bool IsVisible { get; set; }
    private string Title { get; set; } = "";
    private string Message1 { get; set; } = "";
    private string Message2 { get; set; } = "";
    private TaskCompletionSource<bool>? _resultTcs;

    public Task<bool> ShowAsync(string title, string message1, string message2 = "")
    {
        Title = title;
        Message1 = message1;
        Message2 = message2;
        IsVisible = true;
        _resultTcs = new TaskCompletionSource<bool>();
        StateHasChanged();
        return _resultTcs.Task;
    }

    private void Confirm()
    {
        IsVisible = false;
        _resultTcs?.TrySetResult(true);
        StateHasChanged();
    }

    private void Cancel()
    {
        IsVisible = false;
        _resultTcs?.TrySetResult(false);
        StateHasChanged();
    }

    public void Dispose()
    {
        _resultTcs?.TrySetResult(false);
    }
}

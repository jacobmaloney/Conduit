    private static string Slugify(string s)
    {
        var lower = s.ToLowerInvariant();
        var chars = lower.Select(c => char.IsLetterOrDigit(c) ? c : '-').ToArray();
        var collapsed = new string(chars);
        while (collapsed.Contains("--")) collapsed = collapsed.Replace("--", "-");
        return collapsed.Trim('-');
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.Name) || string.IsNullOrWhiteSpace(form.Slug))
        {
            errorMessage = "Name and Slug are required.";
            return;
        }
        // Phase 6: per-connector required-field gate. AD's Domain is the headline
        // case — the form's Save button can't ship a tenant the adapter would
        // throw on the first time someone tried to run a sync against it.
        var missing = GetMissingRequiredTenantFieldsForForm();
        if (missing.Count > 0)
        {
            errorMessage = $"{form.SystemType} requires: {string.Join(", ", missing)}.";
            return;
        }
        // Connector-shaped credential gate: block Connect when a required
        // credential field is empty (a required secret already stored may be
        // left blank to keep it).
        var missingCreds = GetMissingRequiredCredentialFields();
        if (missingCreds.Count > 0)
        {
            errorMessage = $"Credentials required: {string.Join(", ", missingCreds)}.";
            return;
        }
        saving = true;
        errorMessage = "";
        try
        {
            Guid savedTenantId;
            if (editingId.HasValue)
            {
                form.Id = editingId.Value;
                await TenantRepo.UpdateAsync(form);
                savedTenantId = form.Id;
            }
            else
            {
                var clash = await TenantRepo.GetBySlugAsync(form.Slug);
                if (clash != null)
                {
                    errorMessage = $"A connected system with slug '{form.Slug}' already exists.";
                    return;
                }
                var created = await TenantRepo.CreateAsync(form);
                savedTenantId = created.Id;
            }
            await PersistCreateCredentialsAsync(savedTenantId);
            showModal = false;
            await Load();
        }
        catch (Exception ex)
        {
            errorMessage = $"Save failed: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task DeactivateSystem(TenantStats s)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Deactivate '{s.Name}'? Users and groups in this system stay in the database but it will be hidden from active lists.");
        if (!confirmed) return;
        await TenantRepo.DeactivateAsync(s.TenantId);
        await AuditDestructiveAsync("ConnectedSystem.Deactivate", s,
            details: $"Soft delete — IsActive=0; users ({s.UserCount}) and groups ({s.GroupCount}) preserved.");
        await Load();
    }

    // Centralized audit emit so every destructive action on this page lands in
    // the same shape. Captures the signed-in operator, the request's client IP,
    // the counts that were affected at the time the action ran, AND (when a
    // snapshot is supplied) the full JSON serialization of the data that was
    // about to disappear — so forensic recovery is possible even after a wipe.
    private async Task AuditDestructiveAsync(string action, TenantStats target, string details, string? snapshotJson = null)
    {
        try
        {
            string userName = "unknown";
            try
            {
                var auth = await AuthState.GetAuthenticationStateAsync();
                userName = auth.User?.Identity?.Name ?? "unknown";
            }
            catch { /* best-effort */ }

            var ip = HttpCtx.HttpContext?.Connection.RemoteIpAddress?.ToString() ?? "unknown";
            var ua = HttpCtx.HttpContext?.Request.Headers["User-Agent"].ToString();

            await Audit.LogAsync(
                action: action,
                resourceType: "Tenant",
                resourceId: target.TenantId.ToString(),
                userName: userName,
                ipAddress: ip,
                userAgent: ua,
                statusCode: 200,
                details: $"System '{target.Name}' (slug={target.Slug}). {details}",
                oldValue: snapshotJson,   // full pre-destroy snapshot when supplied — enables recovery
                newValue: $"UserCount={target.UserCount}, GroupCount={target.GroupCount}, TokenCount={target.TokenCount}");
        }
        catch (Exception ex)
        {
            // Audit writes must never block the user-facing flow. Log to console
            // so we know the audit pipeline misbehaved, but don't surface to the
            // operator — the destructive action already succeeded.
            Console.WriteLine($"Audit write failed for {action} on {target.Slug}: {ex.Message}");
        }
    }

    // Toggle the legal-hold flag. Audit-logged on both directions because the
    // act of changing the hold IS evidence — operators flipping a hold off
    // immediately before a wipe is exactly the pattern an investigator would
    // want to see end-to-end in the audit trail.
    private async Task ToggleLegalHold(TenantStats s)
    {
        var turningOn = !s.LegalHold;
        var prompt = turningOn
            ? $"Put '{s.Name}' on legal hold? Clear, Deactivate, and Delete will all be refused until the hold is released."
            : $"Release legal hold on '{s.Name}'? Destructive actions will be possible again.";
        var confirmed = await JS.InvokeAsync<bool>("confirm", prompt);
        if (!confirmed) return;

        try
        {
            await TenantRepo.SetLegalHoldAsync(s.TenantId, turningOn);
            await AuditDestructiveAsync(
                action: turningOn ? "ConnectedSystem.LegalHold.Set" : "ConnectedSystem.LegalHold.Released",
                target: s,
                details: turningOn
                    ? $"Operator placed system on legal hold. Destructive actions now refused at the repository layer."
                    : $"Operator released legal hold. Destructive actions are permitted again — investigate any wipe that follows.");
            await Load();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Could not change legal hold: {ex.Message}");
        }
    }

    // Per-card "clear data" — wipes users + groups in this Connected System but
    // leaves the system itself (and its API tokens and config) alive. Same
    // typed-slug confirmation as Delete-forever; the operator literally has to
    // re-type the system identifier before the button enables.
    private TenantStats? clearingFor;
    private string clearConfirmText = "";
    private bool clearInProgress;
    private string clearError = "";

    private async Task ClearData(TenantStats s)
    {
        if (s.UserCount == 0 && s.GroupCount == 0)
        {
            await JS.InvokeVoidAsync("alert", $"'{s.Name}' is already empty — nothing to clear.");
            return;
        }
        clearingFor = s;
        clearConfirmText = "";
        clearError = "";
        clearInProgress = false;
    }

    private void CloseClearModal()
    {
        if (clearInProgress) return;
        clearingFor = null;
        clearConfirmText = "";
        clearError = "";
    }

    private async Task ConfirmClearData()
    {
        if (clearingFor is null) return;
        if (!string.Equals(clearConfirmText, clearingFor.Slug, StringComparison.Ordinal)) return;

        clearInProgress = true;
        clearError = "";
        StateHasChanged();
        try
        {
            var target = clearingFor;

            // Snapshot every doomed row BEFORE the cascade runs — stored on the
            // audit log entry so a later forensic recovery has the data to work from.
            string? snapshot = null;
            try { snapshot = await Snapshots.BuildAsync(target.TenantId); }
            catch (Exception snapEx)
            {
                Console.WriteLine($"Snapshot failed for {target.Slug}: {snapEx.Message}");
                // Best-effort. We still audit-log the action, just without the recovery JSON.
            }

            var removed = await TenantRepo.ClearDataAsync(target.TenantId);
            if (removed < 0)
            {
                // Repo returns -1 when LegalHold is set. Surface clearly; no audit
                // because nothing happened.
                clearError = "Refused: this Connected System is on legal hold. Clear the hold first via its lock icon.";
                clearInProgress = false;
                return;
            }
            await AuditDestructiveAsync("ConnectedSystem.ClearData", target,
                details: $"Hard wipe of users + groups. {removed} rows removed (snapshot before clear: {target.UserCount} users, {target.GroupCount} groups). System, tokens, and config preserved.",
                snapshotJson: snapshot);
            var name = target.Name;
            clearingFor = null;
            clearConfirmText = "";
            await Load();
            await JS.InvokeVoidAsync("alert", $"Removed {removed} rows from '{name}'.");
        }
        catch (Exception ex)
        {
            clearError = $"Clear failed: {ex.Message}";
        }
        finally
        {
            clearInProgress = false;
        }
    }

    // ─── Hard-delete (forever) ─────────────────────────────────────────────
    // The destructive flow is intentionally awkward: a dedicated modal, a typed-
    // name confirmation, a separate "Deleting…" spinner state. Anyone who reaches
    // the final click was thinking about it long enough to mean it.
    private TenantStats? deletingFor;
    private string deleteConfirmText = "";
    private bool deleteInProgress;
    private string deleteError = "";

    private void ShowDeleteModal(TenantStats s)
    {
        deletingFor = s;
        deleteConfirmText = "";
        deleteError = "";
        deleteInProgress = false;
    }

    private void CloseDeleteModal()
    {
        if (deleteInProgress) return;
        deletingFor = null;
        deleteConfirmText = "";
        deleteError = "";
    }

    // ─── Connector credentials modal ──────────────────────────────────────

    // Phase 3 generic-renderer backing store. Keyed by FieldSpec.Key. Value is
    // string or bool depending on field type. BuildCredentialJson reads this
    // dictionary when the adapter declares CredentialTypes.
    private System.Collections.Generic.Dictionary<string, object?> genericCredValues =
        new(StringComparer.OrdinalIgnoreCase);

    private string GetGenericString(string key, string fallback) =>
        genericCredValues.TryGetValue(key, out var v) && v is string s ? s : fallback;

    private void SetGenericString(string key, string value) => genericCredValues[key] = value;

    private bool GetGenericBool(string key, bool fallback) =>
        genericCredValues.TryGetValue(key, out var v) && v is bool b ? b : fallback;

    private void SetGenericBool(string key, bool value) => genericCredValues[key] = value;

    // ─── Create/Edit modal credential capture ──────────────────────────────
    // Folded into the connect flow so a new system arrives usable. Keyed by
    // credentialType.Name → (field.Key → value). Each credential type the
    // selected adapter declares becomes one StoreAsync blob on Save.
    private const string SecretUnchangedPlaceholder = "•••• unchanged";

    private readonly Dictionary<string, Dictionary<string, object?>> createCredValues =
        new(StringComparer.OrdinalIgnoreCase);

    // Credential-type names that already have a stored blob for the edited
    // tenant. Drives the masked-secret placeholder + leave-blank-to-keep logic.
    private readonly HashSet<string> createExistingCredNames = new(StringComparer.OrdinalIgnoreCase);

    private Dictionary<string, object?> CreateBag(string credTypeName)
    {
        if (!createCredValues.TryGetValue(credTypeName, out var bag))
        {
            bag = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
            createCredValues[credTypeName] = bag;
        }
        return bag;
    }

    private string GetCreateString(string credTypeName, string key, string fallback) =>
        CreateBag(credTypeName).TryGetValue(key, out var v) && v is string s ? s : fallback;

    private void SetCreateString(string credTypeName, string key, string value) =>
        CreateBag(credTypeName)[key] = value;

    private bool GetCreateBool(string credTypeName, string key, bool fallback) =>
        CreateBag(credTypeName).TryGetValue(key, out var v) && v is bool b ? b : fallback;

    private void SetCreateBool(string credTypeName, string key, bool value) =>
        CreateBag(credTypeName)[key] = value;

    private bool IsSecretRevealed(string credTypeName, string key) =>
        revealedSecrets.Contains(string.Concat(credTypeName, "::", key));

    private void ToggleSecret(string credTypeName, string key)
    {
        var k = string.Concat(credTypeName, "::", key);
        if (!revealedSecrets.Add(k)) revealedSecrets.Remove(k);
    }

    private void ResetCreateCredentialState()
    {
        createCredValues.Clear();
        createExistingCredNames.Clear();
        revealedSecrets.Clear();
        formTesting = false;
        formTestSuccess = false;
        formTestMessage = null;
    }

    private void DismissFormTest()
    {
        formTestMessage = null;
        formTestSuccess = false;
    }

    private bool CanTestForm =>
        !string.IsNullOrWhiteSpace(form.SystemType)
        && ConnectorRegistry.Get(form.SystemType) is not null
        && GetMissingRequiredTenantFieldsForForm().Count == 0;

    // Live connectivity probe for the create/edit form. Reuses the same path as
    // the Credentials & test modal: resolve the adapter, build a source (sink
    // fallback), call TestConnectionAsync. The connector resolves the Tenant row
    // and its credentials from the database by tenantId, so the entered values
    // must exist there first:
    //   • Edit   — persist the freshly-entered creds onto the real tenant, probe.
    //   • Create — stand up an inactive scratch tenant + creds, probe, then delete
    //     both so nothing is left behind before the operator actually saves.
    private async Task TestFormConnectionAsync()
    {
        if (formTesting) return;
        formTestMessage = null;
        formTestSuccess = false;

        var adapter = string.IsNullOrEmpty(form.SystemType) ? null : ConnectorRegistry.Get(form.SystemType);
        if (adapter is null)
        {
            formTestMessage = string.Concat("No connector adapter registered for '", form.SystemType, "'.");
            return;
        }
        var missing = GetMissingRequiredTenantFieldsForForm();
        if (missing.Count > 0)
        {
            formTestMessage = string.Concat("Fill in the required fields first: ", string.Join(", ", missing), ".");
            return;
        }

        formTesting = true;
        var scratchId = Guid.Empty;
        try
        {
            Guid probeTenantId;
            if (editingId.HasValue)
            {
                await PersistCreateCredentialsAsync(editingId.Value);
                probeTenantId = editingId.Value;
            }
            else
            {
                var scratch = await TenantRepo.CreateAsync(new Tenant
                {
                    Id = Guid.NewGuid(),
                    Name = string.Concat("__test__", Guid.NewGuid().ToString("N")),
                    Slug = string.Concat("__test__", Guid.NewGuid().ToString("N")),
                    SystemType = form.SystemType,
                    Domain = string.IsNullOrWhiteSpace(form.Domain) ? null : form.Domain.Trim(),
                    IsActive = false
                });
                scratchId = scratch.Id;
                await PersistCreateCredentialsAsync(scratchId);
                probeTenantId = scratchId;
            }

            var result = await ProbeTenantAsync(adapter, probeTenantId);
            formTestMessage = result.Message;
            formTestSuccess = result.IsSuccessful;
        }
        catch (Exception ex)
        {
            formTestMessage = string.Concat("Test failed: ", ex.Message);
            formTestSuccess = false;
        }
        finally
        {
            if (scratchId != Guid.Empty)
            {
                try
                {
                    foreach (var ctype in adapter.CredentialTypes)
                        await CredentialProtector.DeleteAsync(scratchId, ctype.Name);
                    await TenantRepo.DeleteAsync(scratchId);
                }
                catch { /* best-effort cleanup of the throw-away tenant */ }
            }
            formTesting = false;
        }
    }

    private static async Task<Conduit.Sync.Connectors.ConnectorTestResult> ProbeTenantAsync(
        Conduit.Sync.Connectors.IConnectorAdapter adapter, Guid tenantId)
    {
        var source = adapter.CreateSource(tenantId);
        if (source is not null)
            return await source.TestConnectionAsync(CancellationToken.None);
        var sink = adapter.CreateSink(tenantId);
        if (sink is not null)
            return await sink.TestConnectionAsync(CancellationToken.None);
        return new Conduit.Sync.Connectors.ConnectorTestResult
        {
            IsSuccessful = false,
            Message = string.Concat("Adapter for '", adapter.SystemType, "' exposes neither source nor sink — cannot test.")
        };
    }

    // On edit: pre-fill non-secret fields from the decrypted blob; leave secret
    // fields blank (never echo a stored secret to the DOM).
    private async Task LoadCreateCredentialsAsync(Guid tenantId, string systemType)
    {
        ResetCreateCredentialState();
        var adapter = string.IsNullOrEmpty(systemType) ? null : ConnectorRegistry.Get(systemType);
        if (adapter is null) return;

        foreach (var ctype in adapter.CredentialTypes)
        {
            string? raw;
            try { raw = await CredentialProtector.RetrieveAsync(tenantId, ctype.Name); }
            catch { raw = null; }
            if (string.IsNullOrEmpty(raw)) continue;

            createExistingCredNames.Add(ctype.Name);

            System.Text.Json.JsonDocument? doc = null;
            try { doc = System.Text.Json.JsonDocument.Parse(raw); }
            catch { doc = null; }
            if (doc is null) continue;

            using (doc)
            {
                var bag = CreateBag(ctype.Name);
                foreach (var field in ctype.Fields)
                {
                    if (field.IsSecret) continue;
                    if (!doc.RootElement.TryGetProperty(field.Key, out var el)) continue;
                    if (field.IsBoolean)
                    {
                        bag[field.Key] = el.ValueKind == System.Text.Json.JsonValueKind.True;
                    }
                    else
                    {
                        bag[field.Key] = el.ValueKind == System.Text.Json.JsonValueKind.String
                            ? el.GetString()
                            : el.ToString();
                    }
                }
            }
        }
    }

    // Required-field gate across every credential type of the selected adapter.
    // A required secret that already has a stored blob may be left blank (keep).
    private List<string> GetMissingRequiredCredentialFields()
    {
        var missing = new List<string>();
        var adapter = string.IsNullOrEmpty(form.SystemType) ? null : ConnectorRegistry.Get(form.SystemType);
        if (adapter is null) return missing;

        foreach (var ctype in adapter.CredentialTypes)
        {
            var typeHasStored = editingId.HasValue && createExistingCredNames.Contains(ctype.Name);
            foreach (var field in ctype.Fields)
            {
                if (!field.IsRequired || field.IsBoolean) continue;
                var entered = GetCreateString(ctype.Name, field.Key, string.Empty);
                if (!string.IsNullOrWhiteSpace(entered)) continue;
                if (field.IsSecret && typeHasStored) continue;
                missing.Add(field.Label);
            }
        }
        return missing;
    }

    // Build the JSON blob for one credential type from the create-modal store.
    // A blank secret on an existing blob is dropped from the payload so the
    // caller can merge it with the stored value (leave-blank = keep existing).
    private string BuildCreateCredentialJson(CredentialTypeInfo ctype, bool typeHasStored)
    {
        var jo = new System.Text.Json.Nodes.JsonObject();
        foreach (var field in ctype.Fields)
        {
            if (field.IsBoolean)
            {
                jo[field.Key] = GetCreateBool(ctype.Name, field.Key, field.DefaultValue == "true");
                continue;
            }
            var val = GetCreateString(ctype.Name, field.Key, field.DefaultValue ?? string.Empty);
            if (field.IsSecret && string.IsNullOrEmpty(val) && typeHasStored) continue;
            if (!field.IsRequired && string.IsNullOrWhiteSpace(val)) continue;
            jo[field.Key] = val;
        }
        return jo.ToJsonString();
    }

    // Persist each credential type the operator filled. Merges with the stored
    // blob on edit so untouched secrets survive.
    private async Task PersistCreateCredentialsAsync(Guid tenantId)
    {
        var adapter = string.IsNullOrEmpty(form.SystemType) ? null : ConnectorRegistry.Get(form.SystemType);
        if (adapter is null) return;

        foreach (var ctype in adapter.CredentialTypes)
        {
            var typeHasStored = createExistingCredNames.Contains(ctype.Name);

            // Did the operator enter anything for this type? On a fresh create with
            // no input, skip — don't write an empty blob.
            var hasInput = false;
            foreach (var field in ctype.Fields)
            {
                if (field.IsBoolean) { hasInput = true; break; }
                if (!string.IsNullOrEmpty(GetCreateString(ctype.Name, field.Key, string.Empty))) { hasInput = true; break; }
            }
            if (!hasInput && !typeHasStored) continue;

            var jsonNode = System.Text.Json.Nodes.JsonNode.Parse(BuildCreateCredentialJson(ctype, typeHasStored)) as System.Text.Json.Nodes.JsonObject
                           ?? new System.Text.Json.Nodes.JsonObject();

            if (typeHasStored)
            {
                // Merge entered values over the existing blob so untouched (esp.
                // secret) fields are preserved.
                string? existingRaw;
                try { existingRaw = await CredentialProtector.RetrieveAsync(tenantId, ctype.Name); }
                catch { existingRaw = null; }
                if (!string.IsNullOrEmpty(existingRaw)
                    && System.Text.Json.Nodes.JsonNode.Parse(existingRaw) is System.Text.Json.Nodes.JsonObject existing)
                {
                    foreach (var kv in jsonNode)
                        existing[kv.Key] = kv.Value?.DeepClone();
                    jsonNode = existing;
                }
            }

            await CredentialProtector.StoreAsync(tenantId, ctype.Name, jsonNode.ToJsonString());
        }
    }

    private sealed class CredentialFormModel
    {
        // AD / Real
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        // EntraID / SharePoint (M365)
        public string TenantId { get; set; } = string.Empty;
        public string ClientId { get; set; } = string.Empty;
        public string ClientSecret { get; set; } = string.Empty;
        // Okta
        public string OrgUrl { get; set; } = string.Empty;
        public string ApiToken { get; set; } = string.Empty;
        // Google
        public string ServiceAccountJson { get; set; } = string.Empty;
        public string AdminEmail { get; set; } = string.Empty;
        public string Domain { get; set; } = string.Empty;
        // Generic LDAP
        public string ServerUrl { get; set; } = string.Empty;
        public string BindDN { get; set; } = string.Empty;
        public string BindPassword { get; set; } = string.Empty;
        public bool UseTls { get; set; }
        // SCIM
        public string BaseUrl { get; set; } = string.Empty;
        public string BearerToken { get; set; } = string.Empty;
        public string UserEndpoint { get; set; } = string.Empty;
        public string GroupEndpoint { get; set; } = string.Empty;
        // Database
        public string ConnectionString { get; set; } = string.Empty;
        public string UserQuery { get; set; } = string.Empty;
        public string GroupQuery { get; set; } = string.Empty;
        public string UpsertUserStatement { get; set; } = string.Empty;
        // CSV
        public string FilePath { get; set; } = string.Empty;
        public string Delimiter { get; set; } = ",";
        public bool HasHeader { get; set; } = true;
        public string IdColumn { get; set; } = string.Empty;
        // AWS
        public string AccessKeyId { get; set; } = string.Empty;
        public string SecretAccessKey { get; set; } = string.Empty;
        public string Region { get; set; } = "us-east-1";
        // AWS Identity Center (in addition to the AWS fields above)
        public string IdentityStoreId { get; set; } = string.Empty;
        public string SSOInstanceArn { get; set; } = string.Empty;
        // IdentityCenter (reuses BaseUrl above)
        public string ApiKey { get; set; } = string.Empty;
        // Phase 2 multi-cred override
        public string CredentialName { get; set; } = string.Empty;
    }

    private static string CredentialNameFor(string systemType) => systemType switch
    {
        "ActiveDirectory" or "Real" or "GenericLdap" => "ldap",
        "EntraID" => "entraid",
        "Okta" => "okta",
        "GoogleWorkspace" => "google",
        "Scim" => "scim",
        "Database" => "database",
        "CSV" => "csv",
        "AWS" => "aws",
        "AWSIdentityCenter" => "awssso",
        "SharePoint" => "sharepoint",
        "IdentityCenter" => "identitycenter",
        _ => "credential"
    };

    private string BuildCredentialJson()
    {
        if (credentialsFor is null) return "{}";

        // Phase 3: prefer generic when the adapter declares CredentialTypes.
        var adapter = ConnectorRegistry.Get(credentialsFor.SystemType);
        var credTypes = adapter?.CredentialTypes;
        if (credTypes is { Count: > 0 })
        {
            var goj = new System.Text.Json.Nodes.JsonObject();
            foreach (var field in credTypes[0].Fields)
            {
                if (field.IsBoolean)
                {
                    goj[field.Key] = GetGenericBool(field.Key, field.DefaultValue == "true");
                }
                else
                {
                    var val = GetGenericString(field.Key, field.DefaultValue ?? string.Empty);
                    // Omit empty optional strings (match legacy behavior for Database/CSV).
                    if (!field.IsRequired && string.IsNullOrWhiteSpace(val)) continue;
                    goj[field.Key] = val;
                }
            }
            return goj.ToJsonString();
        }

        var jo = new System.Text.Json.Nodes.JsonObject();
        switch (credentialsFor.SystemType)
        {
            case "ActiveDirectory":
            case "Real":
                jo["Username"] = credForm.Username;
                jo["Password"] = credForm.Password;
                break;
            case "GenericLdap":
                jo["ServerUrl"] = credForm.ServerUrl;
                jo["BindDN"] = credForm.BindDN;
                jo["BindPassword"] = credForm.BindPassword;
                jo["UseTls"] = credForm.UseTls;
                break;
            case "EntraID":
            case "SharePoint":
                jo["TenantId"] = credForm.TenantId;
                jo["ClientId"] = credForm.ClientId;
                jo["ClientSecret"] = credForm.ClientSecret;
                break;
            case "Okta":
                jo["OrgUrl"] = credForm.OrgUrl;
                jo["ApiToken"] = credForm.ApiToken;
                break;
            case "GoogleWorkspace":
                jo["ServiceAccountJson"] = credForm.ServiceAccountJson;
                jo["AdminEmail"] = credForm.AdminEmail;
                if (!string.IsNullOrWhiteSpace(credForm.Domain)) jo["Domain"] = credForm.Domain;
                break;
            case "Scim":
                jo["BaseUrl"] = credForm.BaseUrl;
                jo["BearerToken"] = credForm.BearerToken;
                if (!string.IsNullOrWhiteSpace(credForm.UserEndpoint)) jo["UserEndpoint"] = credForm.UserEndpoint;
                if (!string.IsNullOrWhiteSpace(credForm.GroupEndpoint)) jo["GroupEndpoint"] = credForm.GroupEndpoint;
                break;
            case "Database":
                jo["ConnectionString"] = credForm.ConnectionString;
                if (!string.IsNullOrWhiteSpace(credForm.UserQuery)) jo["UserQuery"] = credForm.UserQuery;
                if (!string.IsNullOrWhiteSpace(credForm.GroupQuery)) jo["GroupQuery"] = credForm.GroupQuery;
                if (!string.IsNullOrWhiteSpace(credForm.UpsertUserStatement)) jo["UpsertUserStatement"] = credForm.UpsertUserStatement;
                break;
            case "CSV":
                jo["FilePath"] = credForm.FilePath;
                if (!string.IsNullOrWhiteSpace(credForm.Delimiter)) jo["Delimiter"] = credForm.Delimiter;
                jo["HasHeader"] = credForm.HasHeader;
                if (!string.IsNullOrWhiteSpace(credForm.IdColumn)) jo["IdColumn"] = credForm.IdColumn;
                break;
            case "AWS":
                jo["AccessKeyId"] = credForm.AccessKeyId;
                jo["SecretAccessKey"] = credForm.SecretAccessKey;
                jo["Region"] = string.IsNullOrWhiteSpace(credForm.Region) ? "us-east-1" : credForm.Region;
                break;
            case "AWSIdentityCenter":
                jo["AccessKeyId"] = credForm.AccessKeyId;
                jo["SecretAccessKey"] = credForm.SecretAccessKey;
                jo["Region"] = string.IsNullOrWhiteSpace(credForm.Region) ? "us-east-1" : credForm.Region;
                if (!string.IsNullOrWhiteSpace(credForm.IdentityStoreId)) jo["IdentityStoreId"] = credForm.IdentityStoreId;
                if (!string.IsNullOrWhiteSpace(credForm.SSOInstanceArn)) jo["SSOInstanceArn"] = credForm.SSOInstanceArn;
                break;
            case "IdentityCenter":
                jo["BaseUrl"] = credForm.BaseUrl;
                jo["ApiKey"] = credForm.ApiKey;
                break;
        }
        return jo.ToJsonString();
    }

    private System.Collections.Generic.List<string> storedCredentialNames = new();

    private TenantStats? credentialsFor;
    private CredentialFormModel credForm = new();
    private string credSaveMessage = string.Empty;
    private string credTestMessage = string.Empty;
    private bool credTestSuccess;
    private bool credBusy;

    private async Task ShowCredentialsModal(TenantStats s)
    {
        credentialsFor = s;
        credForm = new CredentialFormModel();
        genericCredValues = new(StringComparer.OrdinalIgnoreCase);
        credSaveMessage = string.Empty;
        credTestMessage = string.Empty;
        credTestSuccess = false;
        credBusy = false;
        try
        {
            storedCredentialNames = await CredRepo.ListNamesByTenantAsync(s.TenantId);
        }
        catch
        {
            storedCredentialNames = new();
        }
    }

    private void CloseCredentialsModal()
    {
        if (credBusy) return;
        credentialsFor = null;
    }

    private async Task TestCredentialsAsync()
    {
        if (credentialsFor is null) return;
        credBusy = true;
        credSaveMessage = string.Empty;
        credTestMessage = string.Empty;
        try
        {
            // Phase 2: per-form credential-name override; default to per-system name.
            var credName = string.IsNullOrWhiteSpace(credForm.CredentialName)
                ? CredentialNameFor(credentialsFor.SystemType)
                : credForm.CredentialName!.Trim();
            var json = BuildCredentialJson();
            await CredentialProtector.StoreAsync(credentialsFor.TenantId, credName, json);
            credSaveMessage = $"Credentials saved (AES-GCM under name '{credName}').";
            try
            {
                storedCredentialNames = await CredRepo.ListNamesByTenantAsync(credentialsFor.TenantId);
            }
            catch { /* non-fatal */ }

            var adapter = ConnectorRegistry.Get(credentialsFor.SystemType);
            if (adapter is null)
            {
                credTestMessage = $"No connector adapter registered for '{credentialsFor.SystemType}'.";
                credTestSuccess = false;
                return;
            }
            // Prefer source for testing; fall back to sink for sink-only adapters.
            var probe = adapter.CreateSource(credentialsFor.TenantId)
                     ?? (Conduit.Sync.Connectors.IConnectorSource?)null;
            if (probe is not null)
            {
                var test = await probe.TestConnectionAsync(CancellationToken.None);
                credTestMessage = test.Message;
                credTestSuccess = test.IsSuccessful;
                return;
            }
            var sink = adapter.CreateSink(credentialsFor.TenantId);
            if (sink is null)
            {
                credTestMessage = $"Adapter for '{credentialsFor.SystemType}' exposes neither source nor sink — cannot test.";
                credTestSuccess = false;
                return;
            }
            var sinkTest = await sink.TestConnectionAsync(CancellationToken.None);
            credTestMessage = sinkTest.Message;
            credTestSuccess = sinkTest.IsSuccessful;
        }
        catch (Exception ex)
        {
            credTestMessage = $"Test failed: {ex.Message}";
            credTestSuccess = false;
        }
        finally
        {
            credBusy = false;
        }
    }

    private async Task ConfirmDeleteSystem()
    {
        if (deletingFor is null) return;
        if (!string.Equals(deleteConfirmText, deletingFor.Slug, StringComparison.Ordinal)) return;

        deleteInProgress = true;
        deleteError = "";
        StateHasChanged();
        try
        {
            var target = deletingFor;

            // Snapshot before the cascade — same forensic-recovery contract as Clear.
            string? snapshot = null;
            try { snapshot = await Snapshots.BuildAsync(target.TenantId); }
            catch (Exception snapEx)
            {
                Console.WriteLine($"Snapshot failed for {target.Slug}: {snapEx.Message}");
            }

            if (target.LegalHold)
            {
                deleteError = "Refused: this Connected System is on legal hold. Clear the hold first via its lock icon.";
                return;
            }

            var ok = await TenantRepo.DeleteAsync(target.TenantId);
            if (!ok)
            {
                deleteError = "Delete refused — the Default system cannot be removed.";
                return;
            }

            await AuditDestructiveAsync("ConnectedSystem.DeleteForever", target,
                details: $"Hard delete of Connected System and ALL referencing rows: {target.UserCount} users, {target.GroupCount} groups, {target.TokenCount} tokens, plus the Tenant row itself. Irreversible.",
                snapshotJson: snapshot);

            // If the active sidebar selection was the one we just nuked, drop it
            // so the rest of the app doesn't keep pointing at a dead Connected System.
            if (ActiveSystem.ActiveSystem?.Id == target.TenantId)
            {
                await ActiveSystem.SetAsync(null);
            }

            deletingFor = null;
            deleteConfirmText = "";
            await Load();
        }
        catch (Exception ex)
        {
            deleteError = $"Delete failed: {ex.Message}";
        }
        finally
        {
            deleteInProgress = false;
        }
    }
}

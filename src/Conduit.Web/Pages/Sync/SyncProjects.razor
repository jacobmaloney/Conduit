    }

    private async Task RunNowConfirmed()
    {
        if (selectedProject is null || selectedProject.IsRunning) return;

        var projectId = selectedProject.Id;
        var projectName = selectedProject.Name;

        // IC SystemCenter Run-Now pattern (WebPortal/Pages/Admin/SystemCenter.razor
        // RunProjectNow): close the confirm, flip the project to Running, and start
        // the run in the BACKGROUND so the UI thread is never blocked on the full
        // (synchronous) orchestrator pass. The old code awaited ExecuteAsync inline,
        // so the modal sat open with a spinner for the entire run — looking "stuck".
        //
        // Conduit twist over IC: the orchestrator is a SCOPED service tied to THIS
        // circuit, and we navigate away to the live-progress view below. A bare
        // Task.Run over the injected Orchestrator would have its scope (and DB
        // connections) disposed out from under the run. So the background task
        // resolves a FRESH orchestrator from a dedicated DI scope it owns and
        // disposes itself — never the circuit's scoped services.
        showRunConfirmModal = false;
        runNowInProgress = false;

        // Fix 3: pre-claim the single-run flag (atomic IsRunning 0→1 CAS) BEFORE
        // firing the background run. Guid.Empty is the placeholder run id — the
        // orchestrator stamps the real one once the run row exists. Losing the
        // CAS means a run started between the modal opening and Confirm (another
        // operator, the scheduler, the API): show the already-running message and
        // do NOT fire a second run.
        var claimed = await ProjectRepo.SetRunningAsync(projectId, Guid.Empty);
        if (!claimed)
        {
            toastError = $"'{projectName}' already has a run in progress — view its live progress in Sync History.";
            await Reload();
            return;
        }

        // Local flip so the project shows Running the instant the modal closes;
        // the CAS above already persisted IsRunning=1 authoritatively.
        selectedProject.IsRunning = true;
        await Reload();

        _ = Task.Run(async () =>
        {
            try
            {
                using var scope = ScopeFactory.CreateScope();
                var orchestrator = scope.ServiceProvider.GetRequiredService<SyncProjectOrchestrator>();
                // preClaimed: this page won the CAS above; the orchestrator owns
                // the release from here on every exit path.
                await orchestrator.ExecuteAsync(projectId, "Manual", CancellationToken.None, preClaimed: true);
            }
            catch (Exception ex)
            {
                // The orchestrator stamps the SyncRun Failed and releases IsRunning
                // on every exit path; surfacing here is best-effort logging only.
                // The page has navigated away, so do NOT touch circuit-scoped UI
                // state from this background context.
                Logger.LogError(ex, "Background Run-Now failed for project {ProjectId} ({ProjectName})", projectId, projectName);

                // Defense in depth for the pre-claim: free the project if the
                // orchestrator threw before its own release could run.
                try
                {
                    using var cleanupScope = ScopeFactory.CreateScope();
                    await cleanupScope.ServiceProvider.GetRequiredService<SyncProjectRepository>()
                        .ClearRunningAsync(projectId);
                }
                catch (Exception clearEx)
                {
                    Logger.LogError(clearEx, "Failed to release IsRunning for project {ProjectId} after a failed Run-Now", projectId);
                }
            }
        });

        // Take the user to the project's live run history — the Running run row
        // (and its per-step counts) updates there. This is Conduit's existing
        // "View Live Progress" destination for an in-flight project.
        Navigation.NavigateTo($"/sync-history?project={projectId}");
    }

    // ─── Stop-Sync modal ────────────────────────────────────────────────────

    private void ShowStopConfirmModal()
    {
        if (selectedProject is null || !selectedProject.IsRunning) return;
        stopError = string.Empty;
        stopForceReleaseOffered = false;
        showStopConfirmModal = true;
    }

    private void CloseStopConfirmModal()
    {
        if (stopInProgress) return;
        showStopConfirmModal = false;
        stopError = string.Empty;
        stopForceReleaseOffered = false;
    }

    private async Task StopSyncConfirmed()
    {
        if (selectedProject is null) return;
        stopInProgress = true;
        stopError = string.Empty;
        try
        {
            // Trip the SAME cancellation token the orchestrator threads through
            // every step / sink loop. The orchestrator's existing
            // OperationCanceledException handler marks the run "Cancelled" and
            // releases IsRunning — no parallel stop path. A false return means the
            // run is not executing in this process (e.g. a scheduler tick on
            // another node, single-node assumption aside, or it already finished).
            var signalled = CancellationRegistry.RequestCancel(selectedProject.Id);
            if (signalled)
            {
                var name = selectedProject.Name;
                showStopConfirmModal = false;
                toastSuccess = $"Stop requested for '{name}'. The run will cancel at its next checkpoint.";
            }
            else
            {
                // Fix 4: nothing to cancel in-process, but the DB row may STILL
                // say Running (e.g. a previous process died mid-run before the
                // startup sweep, or the flag got orphaned). Re-check the
                // authoritative row; if it is still flagged, offer Force release.
                var fresh = await ProjectRepo.GetByIdAsync(selectedProject.Id);
                if (fresh is not null && fresh.IsRunning)
                {
                    stopError = "No in-flight run was found for this project in this process, but the project is still marked Running. If you are sure no run is executing, use Force release to clear the flag.";
                    stopForceReleaseOffered = true;
                }
                else
                {
                    stopError = "No in-flight run was found for this project in this process. It may have already finished — refresh to confirm.";
                }
            }
            await Reload();
        }
        catch (Exception ex)
        {
            stopError = $"Stop failed: {ex.Message}";
        }
        finally
        {
            stopInProgress = false;
        }
    }

    /// <summary>
    /// Fix 4: operator-confirmed recovery for a project whose IsRunning flag is
    /// orphaned (no run executing in this process, row still flagged). Stamps any
    /// dangling 'Running' run(s) Interrupted and releases the project flag via
    /// FinishRunAsync (which also sets LastRunStatus). Never touches a healthy
    /// run: the button is only offered after RequestCancel found nothing to cancel.
    /// </summary>
    private async Task ForceReleaseConfirmed()
    {
        if (selectedProject is null) return;
        stopInProgress = true;
        stopError = string.Empty;
        try
        {
            var projectId = selectedProject.Id;
            var name = selectedProject.Name;

            // Stamp dangling run rows first so history agrees with the project row.
            var recent = await RunRepo.GetByProjectAsync(projectId, take: 25);
            foreach (var dangling in recent.Where(r => r.Status == "Running"))
            {
                await RunRepo.FinishAsync(dangling.Id, "Interrupted", "Force-released by operator.", 0);
            }

            await ProjectRepo.FinishRunAsync(projectId, "Interrupted");

            showStopConfirmModal = false;
            stopForceReleaseOffered = false;
            toastSuccess = $"'{name}' force-released. Dangling run(s) marked Interrupted; Run Now is available again.";
            await Reload();
        }
        catch (Exception ex)
        {
            stopError = $"Force release failed: {ex.Message}";
        }
        finally
        {
            stopInProgress = false;
        }
    }


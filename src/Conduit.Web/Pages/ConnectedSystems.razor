@page "/connected-systems"
@attribute [Authorize]
@using System.Net.Http.Json
@using Microsoft.Extensions.Configuration
@using Conduit.Core.Models
@using Conduit.DataAccess.Repositories
@using Conduit.Sync.Connectors
@using Conduit.Web.Services
@inject TenantRepository TenantRepo
@inject ApiTokenService Tokens
@inject DemoSeedService DemoSeed
@inject ActiveSystemState ActiveSystem
@inject DataChangeNotifier DataChange
@inject AuditLogService Audit
@inject TenantSnapshotService Snapshots
@inject AuthenticationStateProvider AuthState
@inject IHttpContextAccessor HttpCtx
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IWebHostEnvironment Environment
@inject IHttpClientFactory HttpFactory
@inject IConfiguration Configuration
@inject Conduit.Sync.Security.CredentialProtector CredentialProtector
@inject Conduit.Sync.Connectors.ConnectorRegistry ConnectorRegistry
@inject Conduit.DataAccess.Repositories.ConnectionCredentialRepository CredRepo
@inject Conduit.DataAccess.Repositories.SyncProjectRepository ProjectRepo
@inject Conduit.DataAccess.Repositories.SinkConnectionCredentialMapRepository CredMapRepo
@inject IServiceScopeFactory ScopeFactory
@inject Microsoft.Extensions.Logging.ILogger<ConnectedSystems> Logger

<PageTitle>Connections - Conduit</PageTitle>

<div class="container-fluid conn-operations">
    @* Connections page rebuilt 2026-06-20 to MATCH IdentityCenter's
       "Directory Connections" surface (SystemCenter.razor §connections):
       Directory-Connections header + New Connection, the sync-summary-card
       stat row, and the sync-project-card vertical LIST of rows. Class names
       mirror IC's center-shared.css; the ported rules live in conduit.css
       under .conn-operations and re-source IC's cyan accent to the OPERATIONS
       orange token (--sec-operations) from the shared brand-tokens.css. The
       old .head-row/.cards/.sys-card grid was replaced. All real Conduit
       actions (Test/Edit/Rename/Deactivate/Delete + dev chrome) are preserved. *@
    <div class="conn-head">
        <div>
            <h2><i class="fas fa-plug"></i>Directory Connections</h2>
            <p class="conn-sub">Directory and target systems Conduit syncs identities to and from.</p>
        </div>
        <div class="head-actions d-flex gap-2">
            <button class="btn" @onclick="SeedDemo" disabled="@seeding">
                @if (seeding)
                {
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                }
                else
                {
                    <i class="oi oi-data-transfer-download"></i>
                }
                <span>Seed Demo Data</span>
            </button>
            <button class="conn-new-btn" @onclick="ShowCreateModal">
                <i class="fas fa-plus"></i>
                <span>New Connection</span>
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(toastError))
    {
        <div class="alert alert-danger alert-dismissible">
            <i class="fas fa-exclamation-circle me-2"></i>@toastError
            <button type="button" class="btn-close" @onclick="() => toastError = string.Empty"></button>
        </div>
    }

    @if (lastSeedResult != null)
    {
        <div class="alert alert-success">
            <h5 class="alert-heading">Demo seed complete</h5>
            <p class="mb-1">
                Created: <strong>@lastSeedResult.ConnectedSystemsCreated</strong> connected systems,
                <strong>@lastSeedResult.UsersCreated</strong> users,
                <strong>@lastSeedResult.GroupsCreated</strong> groups,
                <strong>@lastSeedResult.MembershipsCreated</strong> memberships,
                <strong>@lastSeedResult.TokensCreated</strong> tokens.
            </p>
            @if (lastSeedResult.Notes.Any())
            {
                <details class="mt-2">
                    <summary>Details</summary>
                    <ul class="small mb-0">
                        @foreach (var n in lastSeedResult.Notes)
                        {
                            <li>@n</li>
                        }
                    </ul>
                </details>
            }
        </div>
    }

    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!stats.Any())
    {
        <div class="alert alert-info">
            <h4 class="alert-heading">No connected systems yet</h4>
            <p>Connect one to get started.</p>
            <button class="btn btn-primary btn-sm" @onclick="ShowCreateModal">
                <i class="oi oi-plus"></i> Connect a system
            </button>
        </div>
    }
    else
    {
        @* ── Stat row (IC sync-summary-card parity) ──────────────────────────
           Total Connections + Active are direct IC equivalents. IC's third/
           fourth cards (Authoritative / Test Passed) have NO honest Conduit
           per-connection field — authoritative is decided per sync project,
           and test results aren't persisted on TenantStats — so rather than
           fake them, cards 3 & 4 map to real Conduit directory metrics that
           are already tracked per connection: Users synced and Groups synced. *@
        <div class="sync-summary-cards">
            <div class="sync-summary-card">
                <div class="sync-summary-icon orange"><i class="fas fa-plug"></i></div>
                <div class="sync-summary-content">
                    <div class="sync-summary-value">@stats.Count</div>
                    <div class="sync-summary-label">Total Connections</div>
                </div>
            </div>
            <div class="sync-summary-card">
                <div class="sync-summary-icon green"><i class="fas fa-check-circle"></i></div>
                <div class="sync-summary-content">
                    <div class="sync-summary-value">@stats.Count(c => c.IsActive)</div>
                    <div class="sync-summary-label">Active</div>
                </div>
            </div>
            <div class="sync-summary-card">
                <div class="sync-summary-icon blue"><i class="fas fa-user"></i></div>
                <div class="sync-summary-content">
                    <div class="sync-summary-value">@stats.Sum(c => c.UserCount)</div>
                    <div class="sync-summary-label">Users</div>
                </div>
            </div>
            <div class="sync-summary-card">
                <div class="sync-summary-icon purple"><i class="fas fa-users"></i></div>
                <div class="sync-summary-content">
                    <div class="sync-summary-value">@stats.Sum(c => c.GroupCount)</div>
                    <div class="sync-summary-label">Groups</div>
                </div>
            </div>
        </div>

        @* ── Connection LIST (IC sync-project-card rows) ─────────────────────
           One vertical row per connection: title + type subline, last-sync /
           never-synced note on the right, a badge row (type + active state +
           config-incomplete), and the inline action set. Every action is a
           real Conduit operation — none are stubs. *@
        @foreach (var s in stats)
        {
            var missing = GetMissingRequiredTenantFields(s);
            <div class="sync-project-card @(s.IsActive ? "" : "is-inactive")">
                <div class="sync-project-header">
                    <div>
                        <h5 class="sync-project-title">
                            <i class="fas fa-plug"></i>
                            @s.Name
                        </h5>
                        <p class="sync-project-description">@s.SystemType Connection · @(string.IsNullOrWhiteSpace(s.Domain) ? s.Slug : s.Domain)</p>
                    </div>
                    <div class="sync-project-meta">
                        <span><i class="fas fa-sync me-1"></i>Never synced</span>
                    </div>
                </div>

                <div class="sync-project-badges">
                    <span class="sync-badge sync-badge-connection">
                        <i class="fas fa-plug"></i>
                        @s.SystemType
                    </span>
                    @if (s.IsActive)
                    {
                        <span class="sync-badge sync-badge-enabled">
                            <i class="fas fa-check-circle"></i>
                            Active
                        </span>
                    }
                    else
                    {
                        <span class="sync-badge sync-badge-disabled">
                            <i class="fas fa-pause-circle"></i>
                            Inactive
                        </span>
                    }
                    @if (missing.Count > 0)
                    {
                        <span class="sync-badge sync-badge-warn" title="@($"Configuration incomplete — missing: {string.Join(", ", missing)}. Open Edit to fix.")">
                            <i class="fas fa-exclamation-triangle"></i>
                            Config incomplete
                        </span>
                    }
                </div>

                <div class="sync-project-actions">
                    @* History → real /sync-history route. Edit → real edit modal.
                       Test → real adapter bind. Active → real soft-delete toggle.
                       Rename + Delete → real. Dev chrome (Quick Sync/Endpoints/
                       Legal Hold/Clear) preserved behind the existing flag. *@
                    <button class="btn btn-history" @onclick="GoToSyncHistory" title="View sync history">
                        <i class="fas fa-history"></i> History
                    </button>
                    <button class="btn btn-manage" @onclick="() => EditSystem(s.TenantId)" title="Edit connection">
                        <i class="fas fa-edit"></i> Edit
                    </button>
                    @if (HasAdapter(s.SystemType))
                    {
                        <button class="btn btn-test"
                                @onclick="() => TestCardConnectionAsync(s)"
                                disabled="@(cardTestBusyId == s.TenantId)"
                                title="Test Connection — perform a real bind against this system using its stored credentials">
                            @if (cardTestBusyId == s.TenantId)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                            }
                            else
                            {
                                <i class="fas fa-bolt"></i>
                            }
                            <span>Test</span>
                        </button>
                    }
                    @if (HasCredentialFields(s.SystemType))
                    {
                        <button class="btn btn-manage" @onclick="() => ShowCredentialsModal(s)" title="Credentials & test (directory bind)">
                            <i class="fas fa-key"></i> Credentials
                        </button>
                    }
                    <button class="btn btn-manage" @onclick="() => ShowRenameModal(s)" title="Rename connection (updates credential map + sync project names)">
                        <i class="fas fa-tag"></i> Rename
                    </button>
                    @if (ShowDevChrome)
                    {
                        @if (IsConnectorType(s.SystemType))
                        {
                            <button class="btn btn-manage" @onclick="() => ShowQuickSyncModal(s)" title="[Dev] Quick Sync — clone this system into a local browser tenant">
                                <i class="fas fa-download"></i> Quick Sync
                            </button>
                        }
                        <button class="btn btn-manage" @onclick="() => ShowEndpoints(s)" title="[Dev] View SCIM/REST endpoints + tokens">
                            <i class="fas fa-external-link-alt"></i> Endpoints
                        </button>
                        <button class="btn btn-manage" @onclick="() => ToggleLegalHold(s)"
                                title="@(s.LegalHold ? "[Dev] Legal hold ON — destructive actions are refused. Click to release." : "[Dev] Put on legal hold — refuses Clear/Deactivate/Delete.")">
                            <i class="fas @(s.LegalHold ? "fa-lock" : "fa-lock-open")"></i>
                        </button>
                        <button class="btn btn-manage" @onclick="() => ClearData(s)"
                                disabled="@(clearInProgress || s.LegalHold)"
                                title="@(s.LegalHold ? "[Dev] Refused — system is on legal hold." : "[Dev] Clear users + groups (keeps the system, tokens, config)")">
                            <i class="fas fa-eraser"></i>
                        </button>
                    }
                    @if (s.TenantId != TenantRepository.DefaultTenantId)
                    {
                        <button class="btn btn-manage" @onclick="() => DeactivateSystem(s)"
                                disabled="@s.LegalHold"
                                title="@(s.LegalHold ? "Refused — system is on legal hold." : (s.IsActive ? "Deactivate (soft delete — data stays)" : "Already inactive"))">
                            <i class="fas @(s.IsActive ? "fa-toggle-on" : "fa-toggle-off")"></i> Active
                        </button>
                        <button class="btn btn-delete" @onclick="() => ShowDeleteModal(s)"
                                disabled="@s.LegalHold"
                                title="@(s.LegalHold ? "Refused — system is on legal hold." : "Delete forever (purges users, groups, tokens, memberships)")">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    }
                </div>

                @if (cardTestResultId == s.TenantId && !string.IsNullOrEmpty(cardTestMessage))
                {
                    <div class="card-test-result @(cardTestSuccess ? "ok" : "err")">
                        <i class="fas @(cardTestSuccess ? "fa-check-circle" : "fa-times-circle")"></i>
                        <span>@cardTestMessage</span>
                    </div>
                }
            </div>
        }
    }
</div>

<!-- Rename connection modal — self-service rename (one Conduit-local txn) -->
@if (showRenameModal && renameTarget is not null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="oi oi-tag me-2"></i>Rename connection</h5>
                    <button type="button" class="btn-close" @onclick="CloseRenameModal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">
                        Renaming <strong>@renameTarget.Name</strong> updates the connection name and slug,
                        migrates its write-back credential mapping, and rewrites the names of sync projects
                        that reference it. Synced object history is not rewritten.
                    </p>
                    <div class="mb-3">
                        <label class="form-label">New name *</label>
                        <input class="form-control" maxlength="100" autocomplete="off"
                               @bind="renameNewName" @bind:event="oninput" placeholder="@renameTarget.Name" />
                        <small class="form-text text-muted">
                            Credential-map key will become: <code>@renameSanitizedPreview</code>
                        </small>
                    </div>
                    @if (!string.IsNullOrEmpty(renameError))
                    {
                        <div class="alert alert-danger py-2 mb-0">@renameError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseRenameModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="RenameConnectionAsync" disabled="@renameBusy">
                        @if (renameBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        <span>Rename</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Create / Edit modal — IC "New Connection" parity (Cc-styled, Test-gated) -->
<div class="modal conn-editor-modal @(showModal ? "show d-block" : "")" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header conn-editor-head">
                <div class="conn-editor-head-row">
                    <div class="cc-template1-icon-tile cc-template1-accent-cyan conn-editor-icon">
                        <i class="@ConnectorGlyph(form.SystemType)"></i>
                    </div>
                    <div>
                        <h5 class="modal-title mb-0">@(editingId.HasValue ? "Edit Connection" : "New Connection")</h5>
                        <div class="conn-editor-sub">@(editingId.HasValue ? "Update this connected system's settings, credentials, and test the bind." : "Pick a connection type, enter credentials, and test the bind before you connect.")</div>
                    </div>
                </div>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2">@errorMessage</div>
                }
                <div class="mb-3">
                    <label class="form-label">Name *</label>
                    <input class="form-control" @bind="form.Name" @bind:event="oninput" @bind:after="OnNameChanged" placeholder="e.g. IT Helpdesk Portal" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Slug *</label>
                    <input class="form-control" @bind="form.Slug" placeholder="it-helpdesk" />
                    <small class="form-text text-muted">URL-safe identifier. Auto-derived from the name; edit if needed. Unique across all systems.</small>
                </div>
                @{
                    // Phase 6: per-connector required-field enforcement. The adapter
                    // for the currently-selected SystemType tells the form which
                    // Tenant fields it cares about. AD requires Domain; most others
                    // declare nothing (their requirements live in credentials).
                    var domainReq = GetTenantFieldRequirement(form.SystemType, "Domain");
                    var domainRequired = domainReq?.Required == true;
                    var domainPlaceholder = domainReq?.Placeholder ?? "e.g. it.demo.local (optional)";
                    var domainHelp = domainReq?.HelpText;
                }
                <div class="mb-3">
                    <label class="form-label">
                        Domain@(domainRequired ? " *" : string.Empty)
                    </label>
                    <input class="form-control" @bind="form.Domain" @bind:after="InvalidateFormTest" placeholder="@domainPlaceholder" />
                    @if (!string.IsNullOrEmpty(domainHelp))
                    {
                        <small class="form-text text-muted">@domainHelp</small>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label">Connection Type *</label>
                    <select class="form-select" @bind="form.SystemType" @bind:after="OnSystemTypeChanged">
                        <option value="Emulator">Emulator (test/demo target)</option>
                        <option value="ActiveDirectory">Active Directory</option>
                        <option value="ActiveRoles">Active Roles</option>
                        <option value="EntraID">Entra ID (Microsoft 365)</option>
                        <option value="AzureResourceGraph">Azure Resource Graph</option>
                        <option value="Okta">Okta</option>
                        <option value="GoogleWorkspace">Google Workspace</option>
                        <option value="GenericLdap">Generic LDAP</option>
                        <option value="Scim">SCIM 2.0</option>
                        <option value="Database">Database (SQL)</option>
                        <option value="SqlDiscovery">SQL Server Discovery</option>
                        <option value="CSV">CSV File</option>
                        <option value="AWS">AWS IAM</option>
                        <option value="SharePoint">SharePoint Online</option>
                        <option value="IdentityCenter">IdentityCenter</option>
                        <option value="Real">Real (legacy / generic)</option>
                    </select>
                    @{
                        var typeAdapter = string.IsNullOrEmpty(form.SystemType) ? null : ConnectorRegistry.Get(form.SystemType);
                        var typeCaps = typeAdapter?.Capabilities;
                    }
                    <small class="form-text text-muted">
                        @if (typeAdapter is not null)
                        {
                            <span>The credential fields below are driven by the <strong>@typeAdapter.DisplayName</strong> connector.</span>
                            @if (typeCaps is not null)
                            {
                                <span class="conn-cap-pills">
                                    @if (typeAdapter.SupportsSource)
                                    {
                                        <span class="conn-cap-pill">Source</span>
                                    }
                                    @if (typeAdapter.SupportsSink)
                                    {
                                        <span class="conn-cap-pill">Sink</span>
                                    }
                                    @if (typeCaps.SupportsIncremental)
                                    {
                                        <span class="conn-cap-pill">Incremental</span>
                                    }
                                </span>
                            }
                        }
                        else
                        {
                            <span>Emulator systems show an amber badge. Real connectors are green.</span>
                        }
                    </small>
                </div>
                @{
                    // Connector-shaped credential capture, folded into create/edit so a
                    // newly-connected system is immediately usable. The adapter for the
                    // selected SystemType declares its credential types + field specs;
                    // we render one labeled section per type and persist each as an
                    // encrypted JSON blob on Save. On edit, non-secret values are
                    // pre-filled from the decrypted store; secrets render blank with a
                    // "leave blank to keep" placeholder and are never echoed to the DOM.
                    var createAdapter = string.IsNullOrEmpty(form.SystemType) ? null : ConnectorRegistry.Get(form.SystemType);
                    var createCredTypes = createAdapter?.CredentialTypes;
                }
                @* Per-connector "what you need before you start" guidance. Renders for the
                   cloud connectors whose setup has prerequisites that aren't obvious from the
                   fields alone. Placeholders only — never echo real/secret values here. *@
                @if (form.SystemType == "EntraID" || form.SystemType == "SharePoint")
                {
                    var entraScopes = "Application.Read.All RoleManagement.Read.Directory Device.Read.All AdministrativeUnit.Read.All Policy.Read.All Directory.Read.All Domain.Read.All";
                    var m365Scopes = "Reports.Read.All Sites.Read.All Group.Read.All";
                    <div class="alert alert-info py-2">
                        <div class="fw-bold mb-1"><i class="oi oi-info"></i> What you need before you start</div>
                        <div class="mb-2">An <strong>App Registration</strong> in Entra ID with a client secret, and the Microsoft Graph <strong>application</strong> scopes below granted with admin consent.</div>
                        <div class="mb-1"><small class="text-muted">Directory governance scopes</small></div>
                        <span class="url-cell mb-2">
                            <code>@entraScopes</code>
                            <button class="url-copy" type="button" title="Copy scopes" @onclick="@(() => CopyAsync(entraScopes, "entra-scopes"))">
                                <i class="oi oi-clipboard"></i> @(copiedKey == "entra-scopes" ? "Copied" : "")
                            </button>
                        </span>
                        <div class="mb-2"><small><code>oAuth2PermissionGrant</code> requires <code>Directory.Read.All</code> — this is unavoidably broad.</small></div>
                        <div class="mb-1"><small class="text-muted">Add these for Microsoft 365 license &amp; usage on this same connection</small></div>
                        <span class="url-cell mb-2">
                            <code>@m365Scopes</code>
                            <button class="url-copy" type="button" title="Copy scopes" @onclick="@(() => CopyAsync(m365Scopes, "m365-scopes"))">
                                <i class="oi oi-clipboard"></i> @(copiedKey == "m365-scopes" ? "Copied" : "")
                            </button>
                        </span>
                        <div class="alert alert-warning py-1 px-2 mb-2 mt-1">
                            <small><strong>M365 usage prerequisite:</strong> an admin must PATCH <code>https://graph.microsoft.com/v1.0/admin/reportSettings</code> with <code>@M365ReportSettingsBody</code> or usage data comes back silently empty.</small>
                        </div>
                        <ul class="mb-0 ps-3"><small>
                            <li><strong>Tenant ID</strong> = your Azure tenant GUID (Entra &gt; Overview).</li>
                            <li><strong>Client ID</strong> = the App Registration application (client) ID.</li>
                            <li><strong>Client Secret</strong> = a secret you created on that app-reg (copy it at creation — it is shown once).</li>
                        </small></ul>
                    </div>
                }
                else if (form.SystemType == "AzureResourceGraph")
                {
                    <div class="alert alert-info py-2">
                        <div class="fw-bold mb-1"><i class="oi oi-info"></i> What you need before you start</div>
                        <div class="mb-2">An <strong>App Registration</strong> (Tenant ID / Client ID / Client Secret) <strong>plus</strong> the Azure <strong>RBAC Reader</strong> role assigned to that service principal at the subscription or management-group scope you want to inventory.</div>
                        <ul class="mb-0 ps-3"><small>
                            <li><strong>Tenant ID / Client ID / Client Secret</strong> = same App Registration values as any Entra app-reg.</li>
                            <li><strong>Scope Filter</strong> = comma-separated subscription GUIDs or a management-group id; leave blank for all subscriptions the service principal can read.</li>
                        </small></ul>
                    </div>
                }
                else if (form.SystemType == "AWS" || form.SystemType == "AWSIdentityCenter")
                {
                    var awsIamActions = "iam:ListUsers iam:ListGroups iam:GetGroup iam:ListRoles iam:ListPolicies iam:ListAccountAliases";
                    var awsSsoActions = "identitystore:ListUsers identitystore:ListGroups sso:ListInstances sso:ListPermissionSets sso:DescribePermissionSet";
                    var isSso = form.SystemType == "AWSIdentityCenter";
                    <div class="alert alert-info py-2">
                        <div class="fw-bold mb-1"><i class="oi oi-info"></i> What you need before you start</div>
                        <div class="mb-2">An <strong>IAM user with programmatic access</strong> (Access Key ID + Secret Access Key) and a <strong>Region</strong>@(isSso ? " — the Identity Store ID and SSO Instance ARN auto-resolve when left blank." : ".")</div>
                        <div class="mb-1"><small class="text-muted">@(isSso ? "Read-only Identity Center actions" : "Read-only IAM actions")</small></div>
                        <span class="url-cell mb-2">
                            <code>@(isSso ? awsSsoActions : awsIamActions)</code>
                            <button class="url-copy" type="button" title="Copy permissions" @onclick="@(() => CopyAsync(isSso ? awsSsoActions : awsIamActions, "aws-actions"))">
                                <i class="oi oi-clipboard"></i> @(copiedKey == "aws-actions" ? "Copied" : "")
                            </button>
                        </span>
                        <ol class="mb-0 ps-3"><small>
                            <li>Create an <strong>IAM user</strong> (or role) with <strong>programmatic access</strong> — no console login needed.</li>
                            <li>Attach a <strong>read-only policy</strong> granting the actions above (resource <code>*</code> is fine — they are all list/describe).</li>
                            <li>Generate an access key for that user and paste the <strong>Access Key ID</strong> + <strong>Secret Access Key</strong> below, with your <strong>Region</strong>.</li>
                        </small></ol>
                    </div>
                }
                else if (form.SystemType == "GoogleWorkspace")
                {
                    var gwsScopes = "https://www.googleapis.com/auth/admin.directory.user.readonly https://www.googleapis.com/auth/admin.directory.group.readonly https://www.googleapis.com/auth/admin.directory.group.member.readonly https://www.googleapis.com/auth/admin.directory.orgunit.readonly https://www.googleapis.com/auth/admin.directory.rolemanagement.readonly https://www.googleapis.com/auth/admin.directory.domain.readonly";
                    <div class="alert alert-info py-2">
                        <div class="fw-bold mb-1"><i class="oi oi-info"></i> What you need before you start</div>
                        <div class="mb-2">A <strong>GCP service account</strong> with a <strong>JSON key</strong>, <strong>domain-wide delegation</strong> enabled, and a Workspace <strong>admin email to impersonate</strong>.</div>
                        <div class="mb-1"><small class="text-muted">Read-only Admin SDK Directory scopes (paste these into the domain-wide delegation entry in the Admin console)</small></div>
                        <span class="url-cell mb-2">
                            <code>@gwsScopes</code>
                            <button class="url-copy" type="button" title="Copy scopes" @onclick="@(() => CopyAsync(gwsScopes, "gws-scopes"))">
                                <i class="oi oi-clipboard"></i> @(copiedKey == "gws-scopes" ? "Copied" : "")
                            </button>
                        </span>
                        <ol class="mb-0 ps-3"><small>
                            <li>Create a <strong>service account</strong> in a GCP project and download its <strong>JSON key</strong>.</li>
                            <li>Enable the <strong>Admin SDK API</strong> for that project.</li>
                            <li>In the Workspace <strong>Admin console &gt; Security &gt; API controls &gt; Domain-wide delegation</strong>, add the service account's client ID with the read-only scopes above.</li>
                            <li>Supply the service-account JSON, the <strong>admin email to impersonate</strong>, and your primary <strong>domain</strong> below.</li>
                        </small></ol>
                    </div>
                }
                @if (createCredTypes is { Count: > 0 })
                {
                    @foreach (var ctype in createCredTypes)
                    {
                        var typeHasStored = editingId.HasValue && createExistingCredNames.Contains(ctype.Name);
                        <div class="cred-section mb-3">
                            <div class="cred-section-head">
                                <span class="cred-section-title">@ctype.DisplayName</span>
                                @if (typeHasStored)
                                {
                                    <span class="badge bg-secondary">stored</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(ctype.Description))
                            {
                                <small class="form-text text-muted d-block mb-2">@ctype.Description</small>
                            }
                            @foreach (var field in ctype.Fields)
                            {
                                var secretMasked = field.IsSecret && typeHasStored;
                                <div class="@(field.IsBoolean ? "form-check mb-3" : "mb-3")">
                                    @if (field.IsBoolean)
                                    {
                                        <input class="form-check-input" type="checkbox" id="@($"create_{ctype.Name}_{field.Key}")"
                                               checked="@GetCreateBool(ctype.Name, field.Key, field.DefaultValue == "true")"
                                               @onchange="e => SetCreateBool(ctype.Name, field.Key, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label" for="@($"create_{ctype.Name}_{field.Key}")">@field.Label</label>
                                    }
                                    else
                                    {
                                        <label class="form-label">@field.Label@(field.IsRequired ? " *" : string.Empty)</label>
                                        @if (field.IsMultiline)
                                        {
                                            <textarea class="form-control" rows="4"
                                                      placeholder="@(secretMasked ? SecretUnchangedPlaceholder : field.Placeholder)"
                                                      value="@GetCreateString(ctype.Name, field.Key, field.DefaultValue ?? string.Empty)"
                                                      @oninput="e => SetCreateString(ctype.Name, field.Key, e.Value?.ToString() ?? string.Empty)"></textarea>
                                        }
                                        else if (field.IsSecret)
                                        {
                                            <div class="input-group">
                                                <input class="form-control"
                                                       type="@(IsSecretRevealed(ctype.Name, field.Key) ? "text" : "password")"
                                                       autocomplete="new-password"
                                                       placeholder="@(secretMasked ? SecretUnchangedPlaceholder : field.Placeholder)"
                                                       value="@GetCreateString(ctype.Name, field.Key, field.DefaultValue ?? string.Empty)"
                                                       @oninput="e => SetCreateString(ctype.Name, field.Key, e.Value?.ToString() ?? string.Empty)" />
                                                <button class="btn btn-outline-secondary" type="button"
                                                        @onclick="() => ToggleSecret(ctype.Name, field.Key)"
                                                        title="@(IsSecretRevealed(ctype.Name, field.Key) ? "Hide" : "Show")">
                                                    <i class="bi @(IsSecretRevealed(ctype.Name, field.Key) ? "bi-eye-slash" : "bi-eye")"></i>
                                                </button>
                                            </div>
                                        }
                                        else if (field.AllowedValues.Count > 0)
                                        {
                                            <select class="form-select"
                                                    value="@GetCreateString(ctype.Name, field.Key, field.DefaultValue ?? string.Empty)"
                                                    @onchange="e => SetCreateString(ctype.Name, field.Key, e.Value?.ToString() ?? string.Empty)">
                                                @foreach (var opt in field.AllowedValues)
                                                {
                                                    <option value="@opt">@opt</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <input class="form-control"
                                                   type="text"
                                                   autocomplete="off"
                                                   placeholder="@field.Placeholder"
                                                   value="@GetCreateString(ctype.Name, field.Key, field.DefaultValue ?? string.Empty)"
                                                   @oninput="e => SetCreateString(ctype.Name, field.Key, e.Value?.ToString() ?? string.Empty)" />
                                        }
                                        @if (!string.IsNullOrEmpty(field.Help))
                                        {
                                            <small class="form-text text-muted">@field.Help</small>
                                        }
                                    }
                                </div>
                            }
                        </div>
                    }
                }
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="3" @bind="form.Description"></textarea>
                </div>

                @* Active + Authoritative toggles (IC "New Connection" parity). Active is
                   the real Tenant.IsActive flag. Authoritative has NO Tenant column today
                   — Conduit's symmetric router decides "which side wins" per sync project /
                   per attribute, not per connection. Rendered disabled + explained until
                   Jacob decides the data-model mapping (see the flagged decision). *@
                <div class="conn-toggle-row">
                    <div class="conn-toggle">
                        <label class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" @bind="form.IsActive" />
                            <span class="form-check-label">Active</span>
                        </label>
                        <small class="form-text text-muted">Inactive connections are hidden from active lists and won't run scheduled syncs.</small>
                    </div>
                    <div class="conn-toggle is-disabled" title="Authoritative source is decided per sync project / per attribute in Conduit's symmetric router, not per connection. Pending data-model decision.">
                        <label class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" disabled />
                            <span class="form-check-label">Authoritative <span class="conn-soon">soon</span></span>
                        </label>
                        <small class="form-text text-muted">Set the winning side in the Sync Project (per-attribute), not here — see Sync Projects.</small>
                    </div>
                </div>

                @* ── Test Connection gate (IC parity + this-session's save-trap fix) ──
                   The green test state is the gate: Connect/Save is blocked until a real
                   adapter bind succeeds, and ANY field change (type, domain, credential)
                   invalidates that green state so you can never save a credential that
                   wasn't the one that passed the test. *@
                @if (CanTestForm)
                {
                    <div class="conn-test-strip @(formTestSuccess ? "ok" : (formTestMessage is not null ? "err" : ""))">
                        <div class="conn-test-left">
                            @if (formTestSuccess)
                            {
                                <i class="oi oi-circle-check"></i>
                                <span>Connection verified — you can connect now.</span>
                            }
                            else if (formTestMessage is not null)
                            {
                                <i class="oi oi-circle-x"></i>
                                <span>@formTestMessage</span>
                            }
                            else
                            {
                                <i class="oi oi-pulse"></i>
                                <span>Test the connection before you @(editingId.HasValue ? "save" : "connect").</span>
                            }
                        </div>
                        <button class="btn btn-outline-primary btn-sm" type="button" @onclick="TestFormConnectionAsync" disabled="@formTesting">
                            @if (formTesting)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <span>Testing…</span>
                            }
                            else
                            {
                                <i class="oi oi-pulse"></i>
                                <span class="ms-1">Test Connection</span>
                            }
                        </button>
                    </div>
                    @if (formTestSuccess && formTestMessage is not null)
                    {
                        <div class="conn-test-detail">@formTestMessage</div>
                    }
                }

                @* Day 5: IdentityCenter auto-registration status. Non-fatal — the
                   connection is already saved when this shows. Retry re-runs the
                   registration against the saved connection (no re-save). *@
                @if (autoRegStatus is not null)
                {
                    <div class="conn-test-strip @(autoRegSuccess ? "ok" : "err")">
                        <div class="conn-test-left">
                            <i class="oi @(autoRegSuccess ? "oi-circle-check" : "oi-warning")"></i>
                            <span>@autoRegStatus</span>
                        </div>
                        @if (!autoRegSuccess)
                        {
                            <button class="btn btn-outline-primary btn-sm" type="button"
                                    @onclick="RetryAutoRegisterAsync" disabled="@autoRegInProgress">
                                @if (autoRegInProgress)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Retrying…</span>
                                }
                                else
                                {
                                    <i class="oi oi-loop-circular"></i>
                                    <span class="ms-1">Retry registration</span>
                                }
                            </button>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@(saving || !CanSaveForm)"
                        title="@(CanSaveForm ? null : (RequiresTestBeforeSave ? "Test the connection successfully before you can " + (editingId.HasValue ? "save." : "connect.") : null))">
                    @if (saving)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    @(editingId.HasValue ? "Save changes" : "Connect")
                </button>
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal-backdrop fade show"></div>
}

<!-- Endpoints modal (SCIM-server chrome — dev-only) -->
@if (ShowDevChrome && endpointsFor != null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        Endpoints — @endpointsFor.Name
                        @if (endpointsFor.SystemType == "Real")
                        {
                            <span class="badge bg-success ms-2">REAL</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark ms-2">EMULATOR</span>
                        }
                    </h5>
                    <button class="btn-close" @onclick="CloseEndpoints"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">
                        POST here from your ARS PowerShell workflows or any external app. Two URL forms work —
                        <strong>slug-scoped</strong> (recommended, URL identifies the Connected System) and
                        <strong>token-scoped</strong> (legacy, bearer token decides). When you use the slug form,
                        a token that's scoped to a <em>different</em> system is rejected with 403.
                    </p>

                    <div class="section-eyebrow">URLs</div>
                    <div class="table-responsive">
                        <table class="endpoints-table">
                            <thead>
                                <tr><th class="col-pct-24">Surface</th><th>URL</th><th class="col-pct-16">Method</th><th class="col-pct-14">Scope</th></tr>
                            </thead>
                            <tbody>
                                @{
                                    string scimUsersUrl   = $"{baseUrl}/scim/v2/t/{endpointsFor.Slug}/Users";
                                    string scimGroupsUrl  = $"{baseUrl}/scim/v2/t/{endpointsFor.Slug}/Groups";
                                    string genericUsers   = $"{baseUrl}/api/v1/users";
                                    string genericGroups  = $"{baseUrl}/api/v1/groups";
                                    string sqlAccounts    = $"{baseUrl}/sql/v1/accounts";
                                }
                                <tr>
                                    <td><strong>SCIM 2.0 · Users</strong></td>
                                    <td>
                                        <span class="url-cell">
                                            <code>@scimUsersUrl</code>
                                            <button class="url-copy" title="Copy URL" @onclick="@(() => CopyAsync(scimUsersUrl, "scim-users"))">
                                                <i class="oi oi-clipboard"></i> @(copiedKey == "scim-users" ? "Copied" : "")
                                            </button>
                                        </span>
                                        <br /><small class="text-muted">Legacy: <code>@baseUrl/scim/v2/Users</code></small>
                                    </td>
                                    <td class="text-muted">POST / GET / PATCH</td>
                                    <td><span class="kind-pill">Slug + Token</span></td>
                                </tr>
                                <tr>
                                    <td><strong>SCIM 2.0 · Groups</strong></td>
                                    <td>
                                        <span class="url-cell">
                                            <code>@scimGroupsUrl</code>
                                            <button class="url-copy" title="Copy URL" @onclick="@(() => CopyAsync(scimGroupsUrl, "scim-groups"))">
                                                <i class="oi oi-clipboard"></i> @(copiedKey == "scim-groups" ? "Copied" : "")
                                            </button>
                                        </span>
                                        <br /><small class="text-muted">Legacy: <code>@baseUrl/scim/v2/Groups</code></small>
                                    </td>
                                    <td class="text-muted">POST / GET / PATCH</td>
                                    <td><span class="kind-pill">Slug + Token</span></td>
                                </tr>
                                <tr>
                                    <td><strong>Generic REST · Users</strong></td>
                                    <td>
                                        <span class="url-cell">
                                            <code>@genericUsers</code>
                                            <button class="url-copy" title="Copy URL" @onclick="@(() => CopyAsync(genericUsers, "rest-users"))">
                                                <i class="oi oi-clipboard"></i> @(copiedKey == "rest-users" ? "Copied" : "")
                                            </button>
                                        </span>
                                    </td>
                                    <td class="text-muted">POST / GET / PATCH / DELETE</td>
                                    <td><span class="kind-pill">Tenant</span></td>
                                </tr>
                                <tr>
                                    <td><strong>Generic REST · Groups</strong></td>
                                    <td>
                                        <span class="url-cell">
                                            <code>@genericGroups</code>
                                            <button class="url-copy" title="Copy URL" @onclick="@(() => CopyAsync(genericGroups, "rest-groups"))">
                                                <i class="oi oi-clipboard"></i> @(copiedKey == "rest-groups" ? "Copied" : "")
                                            </button>
                                        </span>
                                    </td>
                                    <td class="text-muted">POST / GET / DELETE</td>
                                    <td><span class="kind-pill">Tenant</span></td>
                                </tr>
                                <tr>
                                    <td><strong>SQL emulator</strong></td>
                                    <td>
                                        <span class="url-cell">
                                            <code>@sqlAccounts</code>
                                            <button class="url-copy" title="Copy URL" @onclick="@(() => CopyAsync(sqlAccounts, "sql"))">
                                                <i class="oi oi-clipboard"></i> @(copiedKey == "sql" ? "Copied" : "")
                                            </button>
                                        </span>
                                    </td>
                                    <td class="text-muted">POST / GET / PATCH / DELETE</td>
                                    <td><span class="kind-pill">Tenant</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="section-eyebrow">Tokens scoped to this Connected System</div>
                    @if (endpointTokens.Count == 0)
                    {
                        <div class="alert alert-warning py-2">
                            No tokens are scoped to this system yet. Go to <a href="/tokens">API Tokens</a> to create one
                            (choose <strong>@endpointsFor.Name</strong> from the Connected System dropdown).
                        </div>
                    }
                    else
                    {
                        <table class="endpoints-table">
                            <thead>
                                <tr><th>Name</th><th>Scope</th><th>Created</th><th>Bearer header</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var t in endpointTokens)
                                {
                                    var demoRaw = LookupDemoToken(t.Name);
                                    <tr>
                                        <td>
                                            <strong>@t.Name</strong>
                                            @if (!string.IsNullOrEmpty(t.Description))
                                            {
                                                <br /><small class="text-muted">@t.Description</small>
                                            }
                                        </td>
                                        <td><span class="kind-pill">@(string.IsNullOrEmpty(t.Scope) ? "Tenant" : t.Scope)</span></td>
                                        <td class="mono-date">@t.CreatedAt.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            @if (demoRaw != null)
                                            {
                                                <span class="url-cell">
                                                    <code>Bearer scim_@demoRaw</code>
                                                    <button class="url-copy" title="Copy header" @onclick="@(() => CopyAsync($"Bearer scim_{demoRaw}", $"tok-{t.Id}"))">
                                                        <i class="oi oi-clipboard"></i> @(copiedKey == $"tok-{t.Id}" ? "Copied" : "")
                                                    </button>
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Raw token shown only at creation time — see <a href="/tokens">API Tokens</a> to mint a new one.</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @{
                        var scimExample = ScimCurlExample();
                        var genericExample = GenericCurlExample();
                        var powershellExample = PowershellExample();
                    }

                    <div class="section-eyebrow">Example: create a user via SCIM</div>
                    <div class="code-block">
                        <button class="code-copy" title="Copy" @onclick="@(() => CopyAsync(scimExample, "SCIM cURL"))">
                            <i class="oi oi-clipboard"></i>
                            <span>@(copiedKey == "SCIM cURL" ? "Copied" : "Copy")</span>
                        </button>
                        <pre><code>@scimExample</code></pre>
                    </div>

                    <div class="section-eyebrow">Example: create a user via Generic REST</div>
                    <div class="code-block">
                        <button class="code-copy" title="Copy" @onclick="@(() => CopyAsync(genericExample, "Generic cURL"))">
                            <i class="oi oi-clipboard"></i>
                            <span>@(copiedKey == "Generic cURL" ? "Copied" : "Copy")</span>
                        </button>
                        <pre><code>@genericExample</code></pre>
                    </div>

                    <div class="section-eyebrow">Example: PowerShell <code>Invoke-RestMethod</code> from ARS workflow</div>
                    <div class="code-block">
                        <button class="code-copy" title="Copy" @onclick="@(() => CopyAsync(powershellExample, "PowerShell"))">
                            <i class="oi oi-clipboard"></i>
                            <span>@(copiedKey == "PowerShell" ? "Copied" : "Copy")</span>
                        </button>
                        <pre><code>@powershellExample</code></pre>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseEndpoints">Close</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (deletingFor is not null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger">
                        <i class="oi oi-warning"></i>
                        Delete Connected System forever
                    </h5>
                    <button class="btn-close" @onclick="CloseDeleteModal" disabled="@deleteInProgress"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger">
                        <strong>This cannot be undone.</strong>
                        Hard-delete <strong>@deletingFor.Name</strong> and every row that references it.
                    </div>

                    <div class="section-eyebrow">What will be deleted</div>
                    <div class="table-responsive mb-3">
                        <table class="endpoints-table">
                            <thead>
                                <tr><th class="col-pct-60">Surface</th><th>Rows</th></tr>
                            </thead>
                            <tbody>
                                <tr><td>Users (with their emails, phone numbers, addresses)</td><td><code>@deletingFor.UserCount</code></td></tr>
                                <tr><td>Groups (with all memberships)</td><td><code>@deletingFor.GroupCount</code></td></tr>
                                <tr><td>API tokens scoped to this system</td><td><code>@deletingFor.TokenCount</code></td></tr>
                                <tr><td>The Connected System row itself</td><td><code>1</code></td></tr>
                            </tbody>
                        </table>
                    </div>

                    <p>Type the system's <strong>slug</strong> (<code>@deletingFor.Slug</code>) below to enable the delete button:</p>
                    <input class="form-control mono"
                           @bind="deleteConfirmText"
                           @bind:event="oninput"
                           placeholder="@deletingFor.Slug"
                           disabled="@deleteInProgress"
                           autocomplete="off" />

                    @if (!string.IsNullOrEmpty(deleteError))
                    {
                        <div class="alert alert-danger mt-3 mb-0 py-2">@deleteError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseDeleteModal" disabled="@deleteInProgress">Cancel</button>
                    <button class="btn btn-danger"
                            @onclick="ConfirmDeleteSystem"
                            disabled="@(deleteInProgress || !string.Equals(deleteConfirmText, deletingFor.Slug, StringComparison.Ordinal))">
                        @if (deleteInProgress)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Deleting…</span>
                        }
                        else
                        {
                            <i class="oi oi-trash"></i>
                            <span class="ms-1">Delete forever</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (clearingFor is not null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">

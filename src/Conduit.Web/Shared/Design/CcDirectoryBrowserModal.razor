@*
    CcDirectoryBrowserModal — shared live directory/OU container browser.

    Ports IdentityCenter's OU browser UX into Conduit. Given a source tenant id,
    it resolves that tenant's connector adapter, asks for an IConnectorContainerBrowser,
    and lazy-loads OUs/containers one level at a time via a live bind against the
    source. The operator drills down, picks a container, and the chosen DN is
    returned to the caller — used by the Sync wizard's Base DN field.

    Usage:
      <CcDirectoryBrowserModal @ref="_dnBrowser" OnSelected="dn => { scopeForm.BaseDN = dn; }" />
      ...
      await _dnBrowser.ShowAsync(form.SourceTenantId, form.SourceCredentialName);

    Reusable: any future "pick a container/Base DN" need (sink target OU, etc.)
    can take a @ref to this same component.
*@

@implements IDisposable
@using Conduit.Shared.SyncUI
@using Conduit.Web.Shared.Design
@inject Conduit.Sync.Connectors.ConnectorRegistry ConnectorRegistry
@inject Conduit.DataAccess.Repositories.TenantRepository TenantRepo

@if (IsVisible)
{
    <div class="modal-backdrop fade show" @onclick="Cancel"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-diagram-3 me-2"></i>@(ScopeMode ? "Select Scope Locations" : "Select Base DN")
                    </h5>
                    <button type="button" class="btn-close" @onclick="Cancel" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (ScopeMode)
                    {
                        @* OPTION-A PILOT: scope mode now renders the SHARED ScopeTree
                           (Conduit.Shared.SyncUI) — the same component IC runs — driven by
                           a ConduitScopeDataSource over the live container browser. The
                           component carries its own legend, 4-state icons (self-contained
                           inline SVG, no font dependency → fixes the blank-icon drift), and
                           the "N included, M blocked" summary. *@
                        @if (IsLoadingRoot)
                        {
                            <div class="text-center p-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading…</span>
                                </div>
                                <p class="mt-2 mb-0 text-muted">Binding to the source directory…</p>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="alert alert-danger mb-0" role="alert">
                                <i class="bi bi-exclamation-triangle me-2"></i>@ErrorMessage
                            </div>
                        }
                        else if (_scopeDataSource is not null)
                        {
                            <ScopeTree DataSource="_scopeDataSource"
                                       SelectedScopes="includedScopes"
                                       BlockedScopes="blockedScopes"
                                       DefaultRootWhenEmpty="false"
                                       ContextKey="@_scopeContextKey" />
                        }
                    }
                    else
                    {
                        @* Single-select Base DN picker — the SAME shared ScopeTree as the
                           scope modal, in Single mode (radio-style, exactly one container,
                           no Blocked state). Picking a node sets selectedDn; the text field
                           in the wizard stays editable for manual entry. *@
                        <p class="text-muted small mb-3">
                            Select a single container to use as the Base DN for this read.
                            Only objects within it (and its children) are synchronized.
                        </p>

                        @if (IsLoadingRoot)
                        {
                            <div class="text-center p-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading…</span>
                                </div>
                                <p class="mt-2 mb-0 text-muted">Binding to the source directory…</p>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="alert alert-danger mb-0" role="alert">
                                <i class="bi bi-exclamation-triangle me-2"></i>@ErrorMessage
                            </div>
                        }
                        else if (_scopeDataSource is not null)
                        {
                            <ScopeTree DataSource="_scopeDataSource"
                                       SelectionMode="ScopeSelectionMode.Single"
                                       SelectedDistinguishedName="selectedDn"
                                       SelectedDistinguishedNameChanged="OnSingleDnChanged"
                                       DefaultRootWhenEmpty="false"
                                       ContextKey="@_scopeContextKey" />
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="Cancel">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                    @if (ScopeMode)
                    {
                        <button type="button" class="btn btn-primary" @onclick="ApplyScopes">
                            <i class="bi bi-check-circle me-1"></i>Apply Scopes
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" disabled="@(string.IsNullOrEmpty(selectedDn))" @onclick="Apply">
                            <i class="bi bi-check-circle me-1"></i>Use this DN
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>Fires with the chosen distinguished name when the operator clicks "Use this container" (single-pick mode).</summary>
    [Parameter] public EventCallback<string> OnSelected { get; set; }

    /// <summary>
    /// Fires with (Included DNs, Blocked DNs) when the operator clicks "Apply Scopes"
    /// in multi-select scope mode. Inherited is not returned — it is the computed
    /// state of a child whose ancestor is Included, derived in the UI and re-derived
    /// at read time, never persisted as its own entry. Mirrors IC's MultiScopeBrowser.
    /// </summary>
    [Parameter] public EventCallback<(HashSet<string> Included, HashSet<string> Blocked)> OnScopesSelected { get; set; }

    private bool IsVisible { get; set; }
    private bool IsLoadingRoot { get; set; }
    private string? ErrorMessage { get; set; }
    private string? selectedDn;

    // Multi-select scope mode (IC parity). When true, the tree shows a 4-state
    // cycle icon per node instead of single-select rows. The two sets ARE the
    // model the caller persists; Inherited is computed, never stored.
    private bool ScopeMode { get; set; }
    private readonly HashSet<string> includedScopes = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> blockedScopes = new(StringComparer.OrdinalIgnoreCase);

    private Guid _tenantId;
    private string? _credentialName;
    private Conduit.Sync.Connectors.IConnectorContainerBrowser? _browser;

    // Option-A pilot: in scope mode the shared ScopeTree owns the loading via this
    // adapter. _scopeContextKey changes per open so ScopeTree reloads from root.
    private IScopeDataSource? _scopeDataSource;
    private string? _scopeContextKey;

    /// <summary>
    /// Open the browser for the given source tenant. <paramref name="credentialName"/>
    /// is the per-project source credential override (may be null/blank for the
    /// default 'ldap' credential).
    /// </summary>
    public async Task ShowAsync(Guid tenantId, string? credentialName = null)
    {
        ScopeMode = false;
        includedScopes.Clear();
        blockedScopes.Clear();
        _tenantId = tenantId;
        _credentialName = credentialName;
        selectedDn = null;
        ErrorMessage = null;
        _browser = null;
        _scopeDataSource = null;
        IsVisible = true;
        IsLoadingRoot = true;
        StateHasChanged();

        await ResolveBrowserAndLoadRootAsync();

        IsLoadingRoot = false;
        StateHasChanged();
    }

    /// <summary>
    /// Open the browser in IC-style multi-select scope mode, pre-seeded with the
    /// currently-Included and currently-Blocked DN sets. The tree shows the 4-state
    /// cycle and returns the edited sets via <see cref="OnScopesSelected"/>.
    /// </summary>
    public async Task ShowForScopeAsync(
        Guid tenantId,
        string? credentialName,
        IEnumerable<string>? included,
        IEnumerable<string>? blocked)
    {
        ScopeMode = true;
        includedScopes.Clear();
        blockedScopes.Clear();
        if (included is not null)
            foreach (var dn in included.Where(d => !string.IsNullOrWhiteSpace(d)))
                includedScopes.Add(dn.Trim());
        if (blocked is not null)
            foreach (var dn in blocked.Where(d => !string.IsNullOrWhiteSpace(d)))
                blockedScopes.Add(dn.Trim());

        _tenantId = tenantId;
        _credentialName = credentialName;
        selectedDn = null;
        ErrorMessage = null;
        _browser = null;
        _scopeDataSource = null;
        IsVisible = true;
        IsLoadingRoot = true;
        StateHasChanged();

        await ResolveBrowserAndLoadRootAsync();

        IsLoadingRoot = false;
        StateHasChanged();
    }

    private async Task ResolveBrowserAndLoadRootAsync()
    {
        if (_tenantId == Guid.Empty)
        {
            ErrorMessage = "No source system selected.";
            return;
        }

        var tenant = await TenantRepo.GetByIdAsync(_tenantId);
        if (tenant is null)
        {
            ErrorMessage = "Source system not found.";
            return;
        }

        var adapter = ConnectorRegistry.Get(tenant.SystemType);
        if (adapter is null)
        {
            ErrorMessage = string.Concat("No connector registered for '", tenant.SystemType, "'.");
            return;
        }

        // Phase 3 honors per-project credential-name override during the live bind.
        using var scope = Conduit.Sync.Security.CredentialNameContext.Push(_credentialName, null);

        _browser = adapter.CreateContainerBrowser(_tenantId);
        if (_browser is null)
        {
            ErrorMessage = string.Concat(tenant.SystemType, " does not support container browsing. Enter the Base DN manually.");
            return;
        }

        // Option-A pilot: BOTH modes now delegate ALL loading + rendering to the shared
        // ScopeTree via the adapter — multi-select scope mode AND single-select Base DN
        // mode run the SAME component code (Single just flips SelectionMode). The modal
        // no longer hand-loads/renders its own tree.
        _scopeDataSource = new ConduitScopeDataSource(_browser, _credentialName);
        _scopeContextKey = Guid.NewGuid().ToString("N");
    }

    /// <summary>
    /// Single-select callback from the shared ScopeTree (Base DN mode). The tree is
    /// radio-style, so this is the one chosen DN (or null when cleared).
    /// </summary>
    private void OnSingleDnChanged(string? dn)
    {
        selectedDn = dn;
        StateHasChanged();
    }

    private async Task Apply()
    {
        if (string.IsNullOrEmpty(selectedDn)) return;
        IsVisible = false;
        var dn = selectedDn;
        StateHasChanged();
        await OnSelected.InvokeAsync(dn);
    }

    private async Task ApplyScopes()
    {
        IsVisible = false;
        StateHasChanged();
        await OnScopesSelected.InvokeAsync(
            (new HashSet<string>(includedScopes, StringComparer.OrdinalIgnoreCase),
             new HashSet<string>(blockedScopes, StringComparer.OrdinalIgnoreCase)));
    }

    private void Cancel()
    {
        IsVisible = false;
        StateHasChanged();
    }

    public void Dispose() { }
}

<style>
    .cc-dn-tree {
        border: 1px solid var(--border, rgba(120,160,220,0.10));
        border-radius: 10px;
        padding: .4rem;
        max-height: 440px;
        overflow-y: auto;
        background: var(--surface-inset, var(--panel-2, #131F36));
    }

    /* Row: comfortable height, whole row is the select target, clear hover/selected. */
    .cc-dn-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .45rem .55rem;
        border-radius: 8px;
        cursor: pointer;
        white-space: nowrap;
        transition: background-color .12s ease;
    }
    .cc-dn-row:hover {
        background: var(--accent-50, rgba(34,211,238,0.06));
    }
    .cc-dn-row.selected {
        background: var(--accent-100, rgba(34,211,238,0.14));
        box-shadow: inset 2px 0 0 var(--accent, #22d3ee);
    }

    /* Chevron: obvious hit target, rotates open/closed, dims when no children. */
    .cc-dn-chevron {
        flex: 0 0 auto;
        width: 1.4rem;
        height: 1.4rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        cursor: pointer;
        color: var(--text-secondary, var(--text-2, #9DB0CC));
        transition: background-color .12s ease, color .12s ease;
    }
    .cc-dn-chevron:hover {
        background: var(--accent-100, rgba(34,211,238,0.14));
        color: var(--accent, #22d3ee);
    }
    .cc-dn-chevron-empty {
        cursor: inherit;
        pointer-events: none;
    }
    .cc-dn-chevron-empty:hover {
        background: transparent;
    }

    /* Folder/container icon — distinct, warm, sized to read as a node marker. */
    .cc-dn-icon {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        color: #f0b450;
        font-size: 1.02rem;
    }

    /* Text block: name on top (primary), description demoted to a legible second line. */
    .cc-dn-text {
        display: flex;
        flex-direction: column;
        line-height: 1.25;
        min-width: 0;
        overflow: hidden;
    }
    .cc-dn-name {
        font-weight: 600;
        font-size: .92rem;
        color: var(--text-primary, var(--text, #E4EDFB));
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .cc-dn-desc {
        font-size: .78rem;
        color: var(--text-secondary, var(--text-2, #9DB0CC));
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Loading / status rows */
    .cc-dn-status { cursor: default; color: var(--text-secondary, var(--text-2, #9DB0CC)); }
    .cc-dn-status:hover { background: transparent; }
    .cc-dn-statustext { font-size: .85rem; }
    .cc-dn-spin { animation: cc-dn-spin 1s linear infinite; display: inline-block; }
    @@keyframes cc-dn-spin { to { transform: rotate(360deg); } }

    /* Error row + retry */
    .cc-dn-error {
        color: var(--bs-danger, #f1707a);
        white-space: normal;
        cursor: default;
    }
    .cc-dn-error:hover { background: transparent; }
    .cc-dn-errtext { font-size: .82rem; }
    .cc-dn-retry { font-size: .82rem; font-weight: 600; }

    /* Selected-DN confirmation strip in the modal body. */
    .cc-dn-selected {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .55rem .7rem;
        border-radius: 8px;
        background: var(--accent-100, rgba(34,211,238,0.14));
        border: 1px solid var(--accent-200, rgba(34,211,238,0.22));
    }
    .cc-dn-selected-icon { color: var(--accent, #22d3ee); font-size: 1.05rem; flex: 0 0 auto; }
    .cc-dn-selected-label {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--accent, #22d3ee);
        flex: 0 0 auto;
    }
    .cc-dn-selected-dn {
        font-size: .85rem;
        color: var(--text-primary, var(--text, #E4EDFB));
        background: transparent;
        padding: 0;
        word-break: break-all;
        white-space: normal;
    }

    /* ─── Multi-select scope mode ─── */
    .cc-scope-legend {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem 1rem;
        padding: .6rem .7rem;
        border-radius: 8px;
        background: var(--surface-inset, var(--panel-2, #131F36));
        border: 1px solid var(--border, rgba(120,160,220,0.10));
    }
    .cc-scope-legend-item {
        font-size: .8rem;
        color: var(--text-secondary, var(--text-2, #9DB0CC));
        display: inline-flex;
        align-items: center;
        gap: .35rem;
    }
    .cc-scope-legend-hint {
        flex-basis: 100%;
        font-size: .76rem;
        color: var(--text-secondary, var(--text-2, #9DB0CC));
        opacity: .85;
        margin-top: .15rem;
    }
    /* The 4-state cycle icon — obvious hit target, sits before the folder icon. */
    .cc-dn-scope {
        flex: 0 0 auto;
        width: 1.5rem;
        height: 1.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        cursor: pointer;
        font-size: 1.02rem;
        transition: background-color .12s ease;
    }
    .cc-dn-scope:hover {
        background: var(--accent-100, rgba(34,211,238,0.14));
    }
</style>
